---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/tool', label: 'Tool' },
  { href: '/blog', label: 'Blog' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-white/80 backdrop-blur-md border-b border-apple-light-gray sticky top-0 z-50">
  <div class="max-w-content mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="nav-logo">
        <div class="logo-icon">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M2 12 Q6 4 10 12 Q14 20 18 12 Q22 4 22 12"/>
          </svg>
        </div>
        <span class="logo-text">AudioSRT</span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-apple-blue bg-[#EEEFFD]'
                : 'text-apple-gray hover:text-apple-dark hover:bg-gray-100'
            }`}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg text-apple-gray hover:text-apple-dark hover:bg-gray-100 transition-colors"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6" x2="19" y2="6"/>
          <line x1="3" y1="11" x2="19" y2="11"/>
          <line x1="3" y1="16" x2="19" y2="16"/>
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="md:hidden hidden pb-4 border-t border-apple-light-gray mt-2 pt-4">
      <nav class="flex flex-col gap-1" aria-label="Mobile navigation">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`px-4 py-2.5 rounded-lg text-sm font-medium transition-colors ${
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-apple-blue bg-[#EEEFFD]'
                : 'text-apple-gray hover:text-apple-dark hover:bg-gray-100'
            }`}
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const open = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', open);
    btn.setAttribute('aria-expanded', String(!open));
  });
</script>

<style>
.nav-logo { display: flex; align-items: center; gap: 8px; text-decoration: none; }
.logo-icon { width: 28px; height: 28px; background: #6366F1; border-radius: 7px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.logo-text { font-size: 15px; font-weight: 600; color: #1D1D1F; letter-spacing: -0.3px; }
.nav-cta { background: #6366F1; color: #ffffff; padding: 8px 18px; border-radius: 8px; font-size: 13px; font-weight: 500; text-decoration: none; transition: background 0.15s ease; }
.nav-cta:hover { background: #4F46E5; }
</style>
