---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/tool', label: 'Tool' },
  { href: '/blog', label: 'Blog' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-white/80 backdrop-blur-md border-b border-apple-light-gray sticky top-0 z-50">
  <div class="max-w-content mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 font-semibold text-xl text-apple-dark hover:text-apple-blue transition-colors">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect width="28" height="28" rx="8" fill="#0071E3"/>
          <path d="M8 14C8 10.686 10.686 8 14 8C17.314 8 20 10.686 20 14" stroke="white" stroke-width="2" stroke-linecap="round"/>
          <path d="M6 14C6 9.582 9.582 6 14 6C18.418 6 22 9.582 22 14" stroke="white" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
          <circle cx="14" cy="17" r="3" fill="white"/>
          <rect x="13" y="20" width="2" height="3" rx="1" fill="white"/>
        </svg>
        AudioSRT
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-apple-blue bg-blue-50'
                : 'text-apple-gray hover:text-apple-dark hover:bg-gray-100'
            }`}
          >
            {link.label}
          </a>
        ))}
        <a
          href="/tool"
          class="ml-4 px-5 py-2 bg-apple-blue text-white text-sm font-semibold rounded-full hover:bg-apple-blue-hover transition-colors"
        >
          Try Free →
        </a>
      </nav>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg text-apple-gray hover:text-apple-dark hover:bg-gray-100 transition-colors"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6" x2="19" y2="6"/>
          <line x1="3" y1="11" x2="19" y2="11"/>
          <line x1="3" y1="16" x2="19" y2="16"/>
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="md:hidden hidden pb-4 border-t border-apple-light-gray mt-2 pt-4">
      <nav class="flex flex-col gap-1" aria-label="Mobile navigation">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`px-4 py-2.5 rounded-lg text-sm font-medium transition-colors ${
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-apple-blue bg-blue-50'
                : 'text-apple-gray hover:text-apple-dark hover:bg-gray-100'
            }`}
          >
            {link.label}
          </a>
        ))}
        <a
          href="/tool"
          class="mt-2 px-5 py-2.5 bg-apple-blue text-white text-sm font-semibold rounded-full text-center hover:bg-apple-blue-hover transition-colors"
        >
          Try Free →
        </a>
      </nav>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const open = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', open);
    btn.setAttribute('aria-expanded', String(!open));
  });
</script>
