---
const year = new Date().getFullYear();
---

<footer class="bg-white border-t border-apple-light-gray mt-20">
  <div class="max-w-content mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-10">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="flex items-center gap-2 font-semibold text-lg text-apple-dark mb-3">
          <svg width="24" height="24" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect width="28" height="28" rx="8" fill="#0071E3"/>
            <path d="M8 14C8 10.686 10.686 8 14 8C17.314 8 20 10.686 20 14" stroke="white" stroke-width="2" stroke-linecap="round"/>
            <path d="M6 14C6 9.582 9.582 6 14 6C18.418 6 22 9.582 22 14" stroke="white" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
            <circle cx="14" cy="17" r="3" fill="white"/>
            <rect x="13" y="20" width="2" height="3" rx="1" fill="white"/>
          </svg>
          AudioSRT
        </a>
        <p class="text-sm text-apple-gray leading-relaxed">
          Free audio transcription and SRT subtitle generator. 100% browser-based. Your files never leave your device.
        </p>
      </div>

      <!-- Tool -->
      <div>
        <h3 class="text-sm font-semibold text-apple-dark mb-4">Tool</h3>
        <ul class="space-y-2">
          <li><a href="/tool" class="text-sm text-apple-gray hover:text-apple-blue transition-colors">Transcription Tool</a></li>
          <li><a href="/tool" class="text-sm text-apple-gray hover:text-apple-blue transition-colors">SRT Generator</a></li>
          <li><a href="/tool" class="text-sm text-apple-gray hover:text-apple-blue transition-colors">Subtitle Editor</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="text-sm font-semibold text-apple-dark mb-4">Resources</h3>
        <ul class="space-y-2">
          <li><a href="/blog" class="text-sm text-apple-gray hover:text-apple-blue transition-colors">Blog</a></li>
          <li><a href="/about" class="text-sm text-apple-gray hover:text-apple-blue transition-colors">About</a></li>
          <li><a href="/contact" class="text-sm text-apple-gray hover:text-apple-blue transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="text-sm font-semibold text-apple-dark mb-4">Legal</h3>
        <ul class="space-y-2">
          <li><a href="/privacy" class="text-sm text-apple-gray hover:text-apple-blue transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="text-sm text-apple-gray hover:text-apple-blue transition-colors">Terms of Service</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-apple-light-gray pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-apple-gray">
        &copy; {year} AudioSRT. All rights reserved.
      </p>
      <p class="text-sm text-apple-gray">
        Built with privacy in mind. Your audio stays on your device.
      </p>
    </div>
  </div>
</footer>
