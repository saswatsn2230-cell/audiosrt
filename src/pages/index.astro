---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Does my audio or video get uploaded to a server?", "acceptedAnswer": { "@type": "Answer", "text": "No. AudioSRT processes everything locally in your browser using asynchronous Web Workers. Your files never leave your device. Zero cloud storage, zero upload latency, zero privacy risk." } },
    { "@type": "Question", "name": "How do I import subtitles into Adobe Premiere Pro?", "acceptedAnswer": { "@type": "Answer", "text": "Export the Premiere Pro JSON file from AudioSRT. In Premiere Pro, open the Text panel → click (...) → Import → Import Static Transcript. Your subtitles will load frame-accurately onto your timeline." } },
    { "@type": "Question", "name": "How accurate is the transcription?", "acceptedAnswer": { "@type": "Answer", "text": "AudioSRT uses OpenAI's Whisper model — one of the most accurate open-source speech recognition systems available. It handles multiple languages, accents, background noise, and technical vocabulary well." } },
    { "@type": "Question", "name": "Will my browser freeze on large video files?", "acceptedAnswer": { "@type": "Answer", "text": "No. We use asynchronous Web Workers and WebGPU memory-chunking that completely separates AI processing from the browser UI thread. Long files process in chunks so you can edit earlier sections while later sections are still transcribing." } },
    { "@type": "Question", "name": "What is the difference between Free and Starter?", "acceptedAnswer": { "@type": "Answer", "text": "Free supports audio-only transcription with SRT and TXT export — no signup needed. Starter ($3/month or ₹99/month) adds video uploads, custom font injection, advanced typography controls, VTT export, and Premiere Pro JSON. Start with a 14-day free trial — no credit card required." } },
    { "@type": "Question", "name": "Is there a desktop app?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — coming soon. Our free Tauri desktop app bypasses browser memory limits and uses your system's native GPU for 15-20x faster transcription. Available for Windows and Mac." } }
  ]
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "AudioSRT",
  "description": "Professional subtitle editor and audio transcription tool. Runs entirely in your browser — no uploads, no account required.",
  "url": "https://audiosrt.com",
  "applicationCategory": "MultimediaApplication",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<BaseLayout
  title="AudioSRT — Free Subtitle Editor & SRT Generator for Video Editors"
  description="Transcribe audio and video locally with Whisper AI. Edit subtitles with professional typography controls. Export SRT, VTT, and Premiere Pro JSON — free to start, no signup needed."
  jsonLd={jsonLd}
>
  <Header />

  <!-- Hero -->
  <section class="hero">
    <div class="hero-badge">⭐ 14-Day Free Trial — No Credit Card Required</div>
    <h1 class="hero-title">
      The Professional Subtitle Editor<br>
      <span class="hero-accent">Built for Video Editors</span>
    </h1>
    <p class="hero-sub">
      Transcribe audio and video locally. Edit subtitles with professional typography controls.
      Export SRT, VTT, and native Premiere Pro JSON files — all free to start.
    </p>
    <div class="hero-btns">
      <a href="/tool" class="btn-primary">Start Transcribing Free →</a>
      <a href="/auth" class="btn-secondary" id="hero-trial-btn">Start 14-Day Free Trial</a>
    </div>
    <div class="hero-trust">
      <span>🔒 Audio never uploaded</span>
      <span>⚡ Powered by Whisper AI</span>
      <span>🎬 Works with Premiere Pro</span>
      <span>∞ No file size limits</span>
    </div>
  </section>

  <!-- Features -->
  <section class="features">
    <h2>Everything a video editor needs</h2>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">🎵</div>
        <h3>Audio &amp; Video Transcription</h3>
        <p>Upload MP3, WAV, M4A, MP4, MOV, WebM. Whisper AI transcribes locally on your device — no cloud upload, no queue, no waiting.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">✏️</div>
        <h3>Professional Subtitle Editor</h3>
        <p>Edit transcript word by word. Adjust timestamps. Split and merge lines. Custom fonts, stroke, shadow, and position controls — all in real time.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">👁️</div>
        <h3>Live Preview Window</h3>
        <p>See your subtitles on a real video preview as you edit. Switch between 16:9 and 9:16 canvas sizes. Preview exactly what your audience will see.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🎨</div>
        <h3>Typography Controls</h3>
        <p>Upload your own brand fonts (.ttf, .otf). Control stroke width, shadow opacity, blur, X/Y offsets. Bold, position, color — full creative control.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">📦</div>
        <h3>Export for Any NLE</h3>
        <p>Download frame-accurate SRT, VTT, plain text, and native Adobe Premiere Pro JSON — imports directly into Premiere's Text-Based Editing panel.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🔒</div>
        <h3>100% Private</h3>
        <p>All processing happens in your browser using Web Workers and WebGPU. Your video and audio data never leaves your device. Zero cloud storage.</p>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="pricing" id="pricing">
    <h2>Simple, transparent pricing</h2>
    <p class="pricing-sub">Start with the free plan. Upgrade when you need more power.</p>

    <div class="pricing-grid">

      <div class="pricing-card">
        <div class="plan-name">Free</div>
        <div class="plan-price">$0<span>/forever</span></div>
        <div class="plan-desc">No signup required. Start immediately.</div>
        <ul class="plan-features">
          <li>Audio file transcription (MP3, WAV, M4A)</li>
          <li>Full transcript text editor</li>
          <li>Subtitle timestamp editor</li>
          <li>Waveform timeline</li>
          <li>Live video preview window</li>
          <li>SRT subtitle export</li>
          <li>Plain text (.txt) export</li>
        </ul>
        <a href="/tool" class="plan-btn plan-btn-free">Start for free →</a>
      </div>

      <div class="pricing-card pricing-card-featured">
        <div class="plan-badge">⭐ Most Popular</div>
        <div class="plan-name">Starter</div>
        <div class="plan-price">$3<span>/month</span></div>
        <div class="plan-price-inr">or ₹99/month for India</div>
        <div class="plan-desc">14-day free trial. No credit card required.</div>
        <ul class="plan-features">
          <li>Everything in Free</li>
          <li>Video file uploads (MP4, MOV, WebM)</li>
          <li>Custom font uploads (.ttf, .otf, .woff)</li>
          <li>Typography controls — stroke, shadow, offsets</li>
          <li>VTT subtitle export</li>
          <li>Premiere Pro JSON export</li>
          <li>Full subtitle styling panel</li>
          <li>Priority processing</li>
        </ul>
        <a href="/auth" class="plan-btn plan-btn-starter" id="pricing-trial-btn">Start 14-day free trial →</a>
        <div class="plan-note">Sign in with Google · No credit card · Cancel anytime</div>
      </div>

      <div class="pricing-card">
        <div class="plan-name">Pro</div>
        <div class="plan-price">$16<span>/month</span></div>
        <div class="plan-desc">For power users and agencies.</div>
        <ul class="plan-features">
          <li>Everything in Starter</li>
          <li>Cloud transcription via Groq (instant)</li>
          <li>45-min audio transcribed in under 60 seconds</li>
          <li>AI Viral Segment Finder</li>
          <li>Animated caption templates</li>
          <li>Auto video clipping by AI timestamps</li>
          <li>Priority support</li>
        </ul>
        <a href="/tool" class="plan-btn plan-btn-pro">Coming soon →</a>
      </div>

    </div>
  </section>

  <!-- How it works -->
  <section class="how-it-works">
    <h2>How it works</h2>
    <div class="steps-grid">
      <div class="step">
        <div class="step-num">01</div>
        <h3>Upload your file</h3>
        <p>Drop any audio or video file. MP3, WAV, M4A, MP4, MOV, WebM. Any file size. Processed entirely on your device.</p>
      </div>
      <div class="step">
        <div class="step-num">02</div>
        <h3>AI transcribes locally</h3>
        <p>Whisper AI runs in your browser using Web Workers. No upload. No queue. Results appear in real time as each chunk completes.</p>
      </div>
      <div class="step">
        <div class="step-num">03</div>
        <h3>Edit, style and export</h3>
        <p>Fix words, adjust timestamps, style subtitles, preview on video. Export SRT, VTT, plain text, or Premiere Pro JSON — ready to import.</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section" id="faq">
    <h2>Frequently Asked Questions</h2>
    <div class="faq-list">
      <div class="faq-item">
        <h3>Does my audio or video get uploaded to a server?</h3>
        <p>No. AudioSRT processes everything locally in your browser using asynchronous Web Workers. Your files never leave your device. Zero cloud storage, zero upload latency, zero privacy risk.</p>
      </div>
      <div class="faq-item">
        <h3>How do I import subtitles into Adobe Premiere Pro?</h3>
        <p>Export the Premiere Pro JSON file from AudioSRT. In Premiere Pro, open the Text panel → click (...) → Import → Import Static Transcript. Your subtitles will load frame-accurately onto your timeline.</p>
      </div>
      <div class="faq-item">
        <h3>How accurate is the transcription?</h3>
        <p>AudioSRT uses OpenAI's Whisper model — one of the most accurate open-source speech recognition systems available. It handles multiple languages, accents, background noise, and technical vocabulary well.</p>
      </div>
      <div class="faq-item">
        <h3>Will my browser freeze on large video files?</h3>
        <p>No. We use asynchronous Web Workers and WebGPU memory-chunking that completely separates AI processing from the browser UI thread. Long files process in chunks so you can edit earlier sections while later sections are still transcribing.</p>
      </div>
      <div class="faq-item">
        <h3>What is the difference between Free and Starter?</h3>
        <p>Free supports audio-only transcription with SRT and TXT export — no signup needed. Starter ($3/month or ₹99/month) adds video uploads, custom font injection, advanced typography controls, VTT export, and Premiere Pro JSON. Start with a 14-day free trial — no credit card required.</p>
      </div>
      <div class="faq-item">
        <h3>Is there a desktop app?</h3>
        <p>Yes — coming soon. Our free Tauri desktop app bypasses browser memory limits and uses your system's native GPU for 15-20x faster transcription. Available for Windows and Mac.</p>
      </div>
    </div>
  </section>

  <!-- Technical GEO copy -->
  <article class="technical-article">
    <h3>Under the Hood: Client-Side Media Processing Architecture</h3>
    <p>AudioSRT is a browser-native subtitle editor and NLE companion utility supporting MP3, WAV, M4A, MP4, MOV, and WebM. All processing executes inside local browser runtime environments using asynchronous Web Workers and WebGPU memory-chunking pipelines. Files never transmit to external cloud networks. The platform generates frame-accurate SRT, VTT, plain text, and Adobe Premiere Pro JSON session files compatible with Premiere Pro Text-Based Editing, DaVinci Resolve, and Final Cut Pro. Custom brand typography is injected via the HTML5 FontFace API with real-time canvas rendering. The Web Worker architecture separates Whisper AI inference from the browser's primary UI thread — guaranteeing zero freezes during multi-hour podcast transcription.</p>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  <Footer />
</BaseLayout>

<style>
/* Hero */
.hero { text-align: center; padding: 80px 20px 60px; max-width: 800px; margin: 0 auto; }
.hero-badge { display: inline-flex; align-items: center; gap: 6px; background: #EEEFFD; color: #6366F1; font-size: 12px; font-weight: 500; padding: 5px 14px; border-radius: 20px; border: 0.5px solid #C7C8F9; margin-bottom: 24px; }
.hero-title { font-size: clamp(32px, 5vw, 52px); font-weight: 700; color: #1D1D1F; line-height: 1.15; letter-spacing: -1px; margin-bottom: 16px; }
.hero-accent { color: #6366F1; }
.hero-sub { font-size: 16px; color: #6E6E73; line-height: 1.7; margin-bottom: 32px; max-width: 560px; margin-left: auto; margin-right: auto; }
.hero-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-bottom: 28px; }
.btn-primary { background: #6366F1; color: #fff; padding: 12px 24px; border-radius: 10px; font-size: 14px; font-weight: 500; text-decoration: none; transition: background 0.15s; }
.btn-primary:hover { background: #4F46E5; }
.btn-secondary { background: #F5F5F7; color: #1D1D1F; padding: 12px 24px; border-radius: 10px; font-size: 14px; font-weight: 500; text-decoration: none; border: 0.5px solid #E5E5E7; transition: border-color 0.15s; }
.btn-secondary:hover { border-color: #6366F1; color: #6366F1; }
.hero-trust { display: flex; gap: 20px; justify-content: center; flex-wrap: wrap; font-size: 12px; color: #6E6E73; }

/* Features */
.features { padding: 80px 20px; max-width: 1000px; margin: 0 auto; }
.features h2 { font-size: 32px; font-weight: 700; color: #1D1D1F; text-align: center; margin-bottom: 48px; letter-spacing: -0.5px; }
.features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
@media (max-width: 768px) { .features-grid { grid-template-columns: 1fr; } }
.feature-card { background: #FFFFFF; border: 0.5px solid #E5E5E7; border-radius: 14px; padding: 24px; }
.feature-icon { font-size: 24px; margin-bottom: 12px; }
.feature-card h3 { font-size: 15px; font-weight: 600; color: #1D1D1F; margin-bottom: 8px; }
.feature-card p { font-size: 13px; color: #6E6E73; line-height: 1.6; }

/* Pricing */
.pricing { padding: 80px 20px; max-width: 1000px; margin: 0 auto; text-align: center; }
.pricing h2 { font-size: 32px; font-weight: 700; color: #1D1D1F; margin-bottom: 12px; letter-spacing: -0.5px; }
.pricing-sub { font-size: 15px; color: #6E6E73; margin-bottom: 48px; }
.pricing-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; text-align: left; }
@media (max-width: 768px) { .pricing-grid { grid-template-columns: 1fr; } }
.pricing-card { border: 0.5px solid #E5E5E7; border-radius: 16px; padding: 28px 24px; background: #FFFFFF; position: relative; display: flex; flex-direction: column; gap: 8px; }
.pricing-card-featured { border: 1.5px solid #6366F1; background: #FAFAFE; box-shadow: 0 4px 32px rgba(99,102,241,0.12); }
.plan-badge { position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: #6366F1; color: #fff; font-size: 11px; font-weight: 600; padding: 4px 12px; border-radius: 20px; white-space: nowrap; }
.plan-name { font-size: 12px; font-weight: 600; color: #6E6E73; text-transform: uppercase; letter-spacing: 0.5px; }
.plan-price { font-size: 36px; font-weight: 700; color: #1D1D1F; }
.plan-price span { font-size: 14px; font-weight: 400; color: #6E6E73; }
.plan-price-inr { font-size: 11px; color: #6E6E73; margin-top: -4px; }
.plan-desc { font-size: 12px; color: #6E6E73; margin-bottom: 8px; }
.plan-features { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; flex: 1; }
.plan-features li { font-size: 12px; color: #3D3D3F; padding-left: 18px; position: relative; line-height: 1.5; }
.plan-features li::before { content: '✓'; position: absolute; left: 0; color: #6366F1; font-weight: 600; }
.plan-btn { display: block; text-align: center; padding: 10px 16px; border-radius: 9px; font-size: 13px; font-weight: 500; text-decoration: none; margin-top: 16px; transition: all 0.15s; }
.plan-btn-free { background: #F5F5F7; color: #1D1D1F; border: 0.5px solid #E5E5E7; }
.plan-btn-free:hover { border-color: #6366F1; color: #6366F1; }
.plan-btn-starter { background: #6366F1; color: #fff; }
.plan-btn-starter:hover { background: #4F46E5; }
.plan-btn-pro { background: #F5F5F7; color: #6E6E73; border: 0.5px solid #E5E5E7; }
.plan-note { font-size: 10px; color: #A0A0A5; text-align: center; }

/* How it works */
.how-it-works { padding: 80px 20px; max-width: 900px; margin: 0 auto; text-align: center; background: #F5F5F7; border-radius: 24px; }
.how-it-works h2 { font-size: 32px; font-weight: 700; color: #1D1D1F; margin-bottom: 40px; letter-spacing: -0.5px; }
.steps-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; text-align: left; }
@media (max-width: 768px) { .steps-grid { grid-template-columns: 1fr; } }
.step-num { font-size: 48px; font-weight: 800; color: #EEEFFD; letter-spacing: -2px; margin-bottom: 12px; }
.step h3 { font-size: 16px; font-weight: 600; color: #1D1D1F; margin-bottom: 8px; }
.step p { font-size: 13px; color: #6E6E73; line-height: 1.6; }

/* FAQ */
.faq-section { max-width: 760px; margin: 80px auto; padding: 0 20px; }
.faq-section h2 { font-size: 32px; font-weight: 700; color: #1D1D1F; text-align: center; margin-bottom: 40px; letter-spacing: -0.5px; }
.faq-item { padding: 20px 0; border-bottom: 0.5px solid #E5E5E7; }
.faq-item:first-child { border-top: 0.5px solid #E5E5E7; }
.faq-item h3 { font-size: 15px; font-weight: 500; color: #1D1D1F; margin-bottom: 8px; }
.faq-item p { font-size: 13px; color: #6E6E73; line-height: 1.7; }

/* Technical article */
.technical-article { max-width: 760px; margin: 40px auto 80px; padding: 24px 20px; border-top: 0.5px solid #E5E5E7; }
.technical-article h3 { font-size: 13px; font-weight: 600; color: #A0A0A5; margin-bottom: 12px; }
.technical-article p { font-size: 11px; color: #B0B0B5; line-height: 1.8; }
</style>

<!-- Auth navbar update handled globally by BaseLayout.astro -->
