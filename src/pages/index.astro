---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Does my audio or video get uploaded to a server?", "acceptedAnswer": { "@type": "Answer", "text": "No. AudioSRT processes everything locally in your browser using asynchronous Web Workers. Your files never leave your device. Zero cloud storage, zero upload latency, zero privacy risk." } },
    { "@type": "Question", "name": "How do I import subtitles into Adobe Premiere Pro?", "acceptedAnswer": { "@type": "Answer", "text": "Export the Premiere Pro JSON file from AudioSRT. In Premiere Pro, open the Text panel, click the (...) menu, choose Import, then Import Static Transcript. Your subtitles will load frame-accurately onto your timeline." } },
    { "@type": "Question", "name": "How accurate is the transcription?", "acceptedAnswer": { "@type": "Answer", "text": "AudioSRT uses OpenAI's Whisper model, one of the most accurate open-source speech recognition systems available. It handles multiple languages, accents, background noise, and technical vocabulary well." } },
    { "@type": "Question", "name": "Will my browser freeze on large video files?", "acceptedAnswer": { "@type": "Answer", "text": "No. AudioSRT uses asynchronous Web Workers and WebGPU memory-chunking that completely separates AI processing from the browser UI thread. Long files process in chunks so you can edit earlier sections while later sections are still transcribing." } },
    { "@type": "Question", "name": "Is AudioSRT really free?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, everything in AudioSRT is free with no account required. Transcribe unlimited audio and video, edit subtitles, upload custom fonts, and export SRT, VTT, TXT, and Premiere Pro JSON — all at no cost." } },
    { "@type": "Question", "name": "Is there a desktop app for AudioSRT?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, coming soon. The free Tauri-based desktop app bypasses browser memory limits and uses the system's native GPU for 15 to 20 times faster transcription. It will be available for Windows and Mac." } }
  ]
};

const howToJsonLd = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to convert audio or video to SRT subtitles with AudioSRT",
  "description": "Convert any audio or video file into accurate SRT subtitles using AudioSRT's free browser-based transcription tool.",
  "step": [
    { "@type": "HowToStep", "name": "Upload your file", "text": "Drop any audio or video file in MP3, WAV, M4A, MP4, MOV, or WebM format. There is no file size limit, and the file is processed entirely on your device." },
    { "@type": "HowToStep", "name": "AI transcribes locally", "text": "Whisper AI runs directly in your browser using Web Workers. There is no upload and no queue. Results appear in real time as each chunk completes." },
    { "@type": "HowToStep", "name": "Edit, style, and export", "text": "Fix words, adjust timestamps, style subtitles, and preview on the video. Export as SRT, VTT, plain text, or Premiere Pro JSON, ready to import into any editor." }
  ]
};

const softwareJsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "AudioSRT",
  "applicationCategory": "MultimediaApplication",
  "operatingSystem": "Web Browser",
  "offers": [
    { "@type": "Offer", "price": "0", "priceCurrency": "USD", "description": "Full-featured transcription, subtitle editing, custom fonts, all exports (SRT, VTT, TXT, Premiere Pro JSON). No signup required, no limits." }
  ]
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "AudioSRT",
  "description": "Professional subtitle editor and audio transcription tool. Runs entirely in your browser — no uploads, no account required.",
  "url": "https://audiosrt.com",
  "applicationCategory": "MultimediaApplication",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<BaseLayout
  title="AudioSRT — Free Audio to SRT Converter, Video to SRT, No Limits"
  description="Convert audio to SRT or video to SRT free, with no upload limits and no signup. Export Premiere Pro JSON, VTT, and plain text. Advanced subtitle editor, fully browser-based."
  jsonLd={jsonLd}
>
  <Header />

  <!-- Hero -->
  <section class="hero">
    <h1 class="hero-title">
      Free Audio to SRT Converter<br>
      <span class="hero-accent">& Online Subtitle Editor</span>
    </h1>
    <p class="hero-sub">
      Completely free, forever. No signup. No duration limit — transcribe a 10-hour file if you want. Upload audio or video, get accurate AI subtitles, edit and style them, then export SRT, TXT, Premiere Pro JSON, or MP4 with burned-in captions.
    </p>
    <div class="hero-btns">
      <a href="/tool" class="btn-primary">Start Transcribing Free →</a>
    </div>
    <div class="hero-trust">
      <span>🔒 Files never leave your device</span>
      <span>⚡ Powered by Whisper AI</span>
      <span>∞ No duration limit</span>
      <span>∞ No file limit</span>
      <span>🎬 Premiere Pro export</span>
    </div>
  </section>

  <!-- Features -->
  <section class="features">
    <h2>Everything a video editor needs</h2>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">🎵</div>
        <h3>Upload Any Audio or Video Format</h3>
        <p>MP3, WAV, M4A, OGG, OPUS, FLAC — any audio format works. For video: MP4, MOV, WebM. No duration limit, no file size limit, no conversion needed.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">📂</div>
        <h3>Pick Up Right Where You Left Off</h3>
        <p>Every project is saved locally on your device for 24 hours. Close the tab, come back anytime within that window, and your transcript, subtitles, and audio are exactly as you left them.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">✂️</div>
        <h3>Split, Merge, and Re-time Lines</h3>
        <p>Click any word to split a subtitle line instantly. Select multiple words to move them between lines. Timestamps recalculate automatically — no manual math.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🔠</div>
        <h3>Single or Double Line Subtitles</h3>
        <p>Choose single-line or double-line subtitle formatting. Export as SRT and import into any editor — fully time-synced, ready to use.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🎨</div>
        <h3>Typography You Control</h3>
        <p>Upload your own brand font. Adjust stroke width, shadow blur, color, and position — see every change live in the preview.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">📦</div>
        <h3>Every Export Format You Need</h3>
        <p>SRT (properly timed), plain TXT, VTT, native Adobe Premiere Pro JSON, and MP4 with subtitles burned directly into the video — no round-trip through another editor required.</p>
      </div>
    </div>
  </section>

  <!-- Product Showcase -->
  <section class="product-showcase">
    <h2>See it in action</h2>
    <p class="showcase-sub">A real editing workflow, start to finish.</p>

    <div class="showcase-grid">
      <div class="showcase-item">
        <div class="showcase-image-slot" data-screenshot="transcript-highlight">
          <img src="/screenshots/transcript-editor.png" alt="Audio to SRT transcript editor with word-synced highlighting" />
        </div>
        <h3>Word-synced transcript editing</h3>
        <p>Click any word to jump to that moment in your audio. As playback runs, the active word highlights in real time. Works the same whether you're converting audio to SRT or video to SRT.</p>
      </div>

      <div class="showcase-item">
        <div class="showcase-image-slot" data-screenshot="subtitle-split">
          <img src="/screenshots/subtitle-editor.png" alt="Video to SRT subtitle editor with timestamp and line-splitting controls" />
        </div>
        <h3>Precise subtitle control, no limits</h3>
        <p>Split lines at any word, move text between lines, and recalculate timestamps automatically. No line caps, no character limits, no length restrictions on the file you upload.</p>
      </div>

      <div class="showcase-item">
        <div class="showcase-image-slot" data-screenshot="styling-panel">
          <img src="/screenshots/styling-panel.png" alt="Subtitle typography editor with font, stroke, shadow, and position controls" />
        </div>
        <h3>Full typography control</h3>
        <p>Upload your own font, then tune stroke, shadow, size, and position. Every change updates the preview instantly.</p>
      </div>

      <div class="showcase-item">
        <div class="showcase-image-slot" data-screenshot="export-modal">
          <img src="/screenshots/export-modal.png" alt="Export audio to SRT, VTT, or Premiere Pro JSON from one menu" />
        </div>
        <h3>Export to SRT, VTT, or Premiere Pro JSON</h3>
        <p>Convert audio to SRT, video to SRT, or export directly as a Premiere Pro JSON file ready to drop into your timeline. Free transcription, no signup, no file limits.</p>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="pricing" id="pricing">
    <h2>100% Free — No account required</h2>
    <p class="pricing-sub">Every feature, zero cost. No file limits, no duration limits, no signup.</p>

    <div class="pricing-grid pricing-grid-2">

      <div class="pricing-card pricing-card-featured">
        <div class="plan-name">Free — Forever</div>
        <div class="plan-price">$0<span>/forever</span></div>
        <div class="plan-desc">No signup required. Start immediately. No limits of any kind.</div>
        <ul class="plan-features">
          <li><strong>No duration limit</strong> — transcribe a 10-hour audio or video</li>
          <li><strong>No file limit</strong> — transcribe as many files as you want</li>
          <li>Audio + video uploads (MP3, WAV, M4A, MP4, MOV, WebM)</li>
          <li>3 AI models — Fast (90%), Balanced (95%), Most Accurate (98%)</li>
          <li>Full transcript text editor — fix words, clean up errors</li>
          <li>Advanced subtitle editor — split lines, move words up/down</li>
          <li>Single-line or double-line subtitle toggle</li>
          <li>Upload your own custom font (.TTF, .OTF, .WOFF)</li>
          <li>Shadow, stroke, color and position controls</li>
          <li>Live video preview window</li>
          <li>Waveform timeline editor</li>
          <li>Export SRT (properly timed subtitles)</li>
          <li>Export plain TXT (full transcription)</li>
          <li>Export Premiere Pro JSON (drop into timeline)</li>
          <li>Export MP4 with burned-in captions</li>
        </ul>
        <a href="/tool" class="plan-btn plan-btn-indigo">Start transcribing free →</a>
      </div>

      <div class="pricing-card">
        <div class="plan-name">Desktop App</div>
        <div class="plan-price" style="font-size:28px;">15–20×<span style="font-size:14px;"> faster</span></div>
        <div class="plan-desc">Native GPU acceleration. No browser limits. 100% offline.</div>
        <ul class="plan-features">
          <li>Everything in the free web app</li>
          <li>Native GPU / CPU acceleration (15–20× faster transcription)</li>
          <li>No browser memory limits — handle any file size</li>
          <li>Works 100% offline — no internet required</li>
          <li>Faster model loading (cached locally)</li>
          <li>Windows &amp; Mac support</li>
        </ul>
        <div class="plan-btn plan-btn-coming">Coming soon →</div>
      </div>

    </div>
  </section>

  <!-- How it works -->
  <section class="how-it-works">
    <h2>How it works</h2>
    <div class="steps-grid">
      <div class="step">
        <div class="step-num">01</div>
        <h3>Upload your file</h3>
        <p>Drop any audio or video file. MP3, WAV, M4A, MP4, MOV, WebM. Any file size. Processed entirely on your device.</p>
      </div>
      <div class="step">
        <div class="step-num">02</div>
        <h3>AI transcribes locally</h3>
        <p>Whisper AI runs in your browser using Web Workers. No upload. No queue. Results appear in real time as each chunk completes.</p>
      </div>
      <div class="step">
        <div class="step-num">03</div>
        <h3>Edit, style and export</h3>
        <p>Fix words, adjust timestamps, style subtitles, preview on video. Export SRT, VTT, plain text, or Premiere Pro JSON — ready to import.</p>
      </div>
    </div>
  </section>

  <!-- 3-Way Comparison Table -->
  <section class="compare3-section" id="compare">
    <div class="compare3-header">
      <h2 class="compare3-h2">Built for Editors Who Hate Cloud Queues<br>and $20 Subscriptions</h2>
      <p class="compare3-sub">How AudioSRT obliterates traditional cloud tools on actual editing workflows.</p>
    </div>

    <div class="compare3-wrap">
      <table class="compare3-table">
        <thead>
          <tr>
            <th class="c3-th-feature">Feature / Workflow</th>
            <th class="c3-th-rival">🌀 TurboScribe</th>
            <th class="c3-th-rival">🎙️ Descript</th>
            <th class="c3-th-us">⚡ AudioSRT <span class="c3-us-badge">Us</span></th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="c3-feat">Time to Start Editing</td>
            <td class="c3-rival">⏳ Wait 3–4 min for cloud processing</td>
            <td class="c3-rival">⏳ Wait for full upload &amp; cloud queue</td>
            <td class="c3-us">🚀 <strong>15 Seconds (Instant Stream)</strong></td>
          </tr>
          <tr class="c3-alt">
            <td class="c3-feat">Data Privacy</td>
            <td class="c3-rival">☁️ Uploads files to external servers</td>
            <td class="c3-rival">☁️ Uploads files to external cloud</td>
            <td class="c3-us">🔒 <strong>100% Local — files never leave device</strong></td>
          </tr>
          <tr>
            <td class="c3-feat">Monthly Cost</td>
            <td class="c3-rival">$20 / month</td>
            <td class="c3-rival">$15+ / month</td>
            <td class="c3-us">💚 <strong>Free — always</strong></td>
          </tr>
          <tr class="c3-alt">
            <td class="c3-feat">Free Plan Limits</td>
            <td class="c3-rival">Strict cap — 3 files / day</td>
            <td class="c3-rival">1 hour / month</td>
            <td class="c3-us">✅ <strong>Infinite Files — no daily caps</strong></td>
          </tr>
          <tr>
            <td class="c3-feat">Export Formats</td>
            <td class="c3-rival">Basic text export only</td>
            <td class="c3-rival">Requires complex software round-trip</td>
            <td class="c3-us">🎬 <strong>Premiere Pro JSON · SRT · TXT · MP4 with burned subtitles</strong></td>
          </tr>
          <tr class="c3-alt">
            <td class="c3-feat">Typography Controls</td>
            <td class="c3-rival">None — plain document text</td>
            <td class="c3-rival">Limited layout styling presets</td>
            <td class="c3-us">🅰️ <strong>Full Brand Font (.TTF/.OTF) Injection</strong></td>
          </tr>
        </tbody>
      </table>
    </div>

    <ul class="compare3-bullets">
      <li>
        <span class="c3-bullet-icon">⚡</span>
        <div>
          <strong>Total Time vs. Active Time:</strong> Don't be fooled by cloud processing speeds. TurboScribe takes 3 minutes and 51 seconds of dead waiting time before you can edit. AudioSRT uses a 30-second rolling VAD chunking pipeline — giving you your first lines to review and style within 15 seconds while the rest finishes in the background.
        </div>
      </li>
      <li>
        <span class="c3-bullet-icon">🔒</span>
        <div>
          <strong>Complete Privacy Moat:</strong> Both Descript and TurboScribe force you to upload your clients' private, unreleased footage to their cloud servers, wasting massive upload bandwidth. AudioSRT processes everything locally via Web Workers right inside your browser. Zero data risks, zero upload lag.
        </div>
      </li>
      <li>
        <span class="c3-bullet-icon">💰</span>
        <div>
          <strong>Zero Cost, Full Power:</strong> Why drop $180–$240 a year just to get unlimited transcripts? AudioSRT gives you everything — unlimited audio and video transcription, custom fonts, all export formats — completely free with no account required.
        </div>
      </li>
    </ul>

    <div style="text-align:center;margin-top:36px;">
      <a href="/tool" class="hero-cta">Try AudioSRT Free — No Upload Required →</a>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section" id="faq">
    <h2>Frequently Asked Questions</h2>
    <div class="faq-list">
      <div class="faq-item">
        <h3>Does my audio or video get uploaded to a server?</h3>
        <p>No. AudioSRT processes everything locally in your browser using asynchronous Web Workers. Your files never leave your device. Zero cloud storage, zero upload latency, zero privacy risk.</p>
      </div>
      <div class="faq-item">
        <h3>How do I import subtitles into Adobe Premiere Pro?</h3>
        <p>Export the Premiere Pro JSON file from AudioSRT. In Premiere Pro, open the Text panel → click (...) → Import → Import Static Transcript. Your subtitles will load frame-accurately onto your timeline. <a href="/integrations/adobe-premiere-pro" style="color:#6366F1;text-decoration:none;">See the full Premiere Pro integration guide →</a></p>
      </div>
      <div class="faq-item">
        <h3>How accurate is the transcription?</h3>
        <p>AudioSRT uses OpenAI's Whisper model — one of the most accurate open-source speech recognition systems available. It handles multiple languages, accents, background noise, and technical vocabulary well.</p>
      </div>
      <div class="faq-item">
        <h3>Will my browser freeze on large video files?</h3>
        <p>No. We use asynchronous Web Workers and WebGPU memory-chunking that completely separates AI processing from the browser UI thread. Long files process in chunks so you can edit earlier sections while later sections are still transcribing.</p>
      </div>
      <div class="faq-item">
        <h3>Is AudioSRT really free?</h3>
        <p>Yes — everything is free with no account required. Transcribe unlimited audio and video files, edit subtitles, upload custom fonts, and export to SRT, VTT, TXT, and Premiere Pro JSON. No signup, no limits, no credit card.</p>
      </div>
      <div class="faq-item">
        <h3>Is there a desktop app?</h3>
        <p>Yes — coming soon. Our free Tauri desktop app bypasses browser memory limits and uses your system's native GPU for 15-20x faster transcription. Available for Windows and Mac.</p>
      </div>
    </div>
  </section>

  <!-- Popular searches -->
  <section class="popular-searches">
    <p class="popular-searches-label">Popular tools:</p>
    <div class="popular-searches-links">
      <a href="/tools/free-srt-generator">Free SRT Generator</a>
      <a href="/tools/audio-to-text">Audio to Text</a>
      <a href="/tools/speech-to-text">Speech to Text</a>
      <a href="/tools/podcast-transcription">Podcast Transcription</a>
      <a href="/tools/youtube-captions">YouTube Captions</a>
      <a href="/tools/closed-caption-generator">Closed Captions</a>
      <a href="/integrations/adobe-premiere-pro">Premiere Pro</a>
      <a href="/integrations/davinci-resolve">DaVinci Resolve</a>
      <a href="/compare/browser-based-subtitle-tools">Browser vs Cloud</a>
    </div>
  </section>

  <!-- Positioning note -->
  <section class="positioning-note">
    <p>Most subtitle and captioning tools require uploading your media to a remote server, capping free transcription length, or charging monthly fees before you can export a usable SRT file. AudioSRT runs entirely in your browser: audio to SRT, video to SRT, or audio to Premiere Pro JSON, with no file length limit and no account needed to start. For editors who want an advanced subtitle editor without recurring software costs or upload restrictions, AudioSRT handles transcription, subtitle styling, and timeline-ready export entirely client-side.</p>
  </section>

  <!-- Technical GEO copy -->
  <article class="technical-article">
    <h3>Under the Hood: Client-Side Media Processing Architecture</h3>
    <p>AudioSRT is a browser-native subtitle editor and NLE companion utility supporting MP3, WAV, M4A, MP4, MOV, and WebM. All processing executes inside local browser runtime environments using asynchronous Web Workers and WebGPU memory-chunking pipelines. Files never transmit to external cloud networks. The platform generates frame-accurate SRT, VTT, plain text, and Adobe Premiere Pro JSON session files compatible with Premiere Pro Text-Based Editing, DaVinci Resolve, and Final Cut Pro. Custom brand typography is injected via the HTML5 FontFace API with real-time canvas rendering. The Web Worker architecture separates Whisper AI inference from the browser's primary UI thread — guaranteeing zero freezes during multi-hour podcast transcription.</p>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(howToJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(softwareJsonLd)} />
  <Footer />
</BaseLayout>

<style>
/* Hero */
.hero { text-align: center; padding: 80px 20px 60px; max-width: 800px; margin: 0 auto; }
.hero-badge { display: inline-flex; align-items: center; gap: 6px; background: #EEEFFD; color: #6366F1; font-size: 12px; font-weight: 500; padding: 5px 14px; border-radius: 20px; border: 0.5px solid #C7C8F9; margin-bottom: 24px; }
.hero-title { font-size: clamp(32px, 5vw, 52px); font-weight: 700; color: #1D1D1F; line-height: 1.15; letter-spacing: -1px; margin-bottom: 16px; }
.hero-accent { color: #6366F1; }
.hero-sub { font-size: 16px; color: #6E6E73; line-height: 1.7; margin-bottom: 32px; max-width: 560px; margin-left: auto; margin-right: auto; }
.hero-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-bottom: 28px; }
.btn-primary { background: #6366F1; color: #fff; padding: 12px 24px; border-radius: 10px; font-size: 14px; font-weight: 500; text-decoration: none; transition: background 0.15s; }
.btn-primary:hover { background: #4F46E5; }
.btn-secondary { background: #F5F5F7; color: #1D1D1F; padding: 12px 24px; border-radius: 10px; font-size: 14px; font-weight: 500; text-decoration: none; border: 0.5px solid #E5E5E7; transition: border-color 0.15s; }
.btn-secondary:hover { border-color: #6366F1; color: #6366F1; }
.hero-trust { display: flex; gap: 20px; justify-content: center; flex-wrap: wrap; font-size: 12px; color: #6E6E73; }

/* Features */
.features { padding: 80px 20px; max-width: 1000px; margin: 0 auto; }
.features h2 { font-size: 32px; font-weight: 700; color: #1D1D1F; text-align: center; margin-bottom: 48px; letter-spacing: -0.5px; }
.features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
@media (max-width: 768px) { .features-grid { grid-template-columns: 1fr; } }
.feature-card { background: #FFFFFF; border: 0.5px solid #E5E5E7; border-radius: 14px; padding: 24px; }
.feature-icon { font-size: 24px; margin-bottom: 12px; }
.feature-card h3 { font-size: 15px; font-weight: 600; color: #1D1D1F; margin-bottom: 8px; }
.feature-card p { font-size: 13px; color: #6E6E73; line-height: 1.6; }

.product-showcase { padding: 80px 20px; max-width: 1000px; margin: 0 auto; }
.product-showcase h2 { font-size: 32px; font-weight: 700; color: #1D1D1F; text-align: center; margin-bottom: 8px; letter-spacing: -0.5px; }
.showcase-sub { font-size: 15px; color: #6E6E73; text-align: center; margin-bottom: 48px; }
.showcase-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 32px; }
@media (max-width: 768px) { .showcase-grid { grid-template-columns: 1fr; } }
.showcase-item h3 { font-size: 15px; font-weight: 600; color: #1D1D1F; margin-bottom: 6px; }
.showcase-item p { font-size: 13px; color: #6E6E73; line-height: 1.6; }
.showcase-image-slot { width: 100%; aspect-ratio: 16/10; background: #F5F5F7; border: 0.5px solid #E5E5E7; border-radius: 12px; margin-bottom: 14px; overflow: hidden; display: flex; align-items: center; justify-content: center; }
.showcase-image-slot img { width: 100%; height: 100%; object-fit: cover; display: block; }

/* Pricing */
.pricing { padding: 80px 20px; max-width: 1000px; margin: 0 auto; text-align: center; }
.pricing h2 { font-size: 32px; font-weight: 700; color: #1D1D1F; margin-bottom: 12px; letter-spacing: -0.5px; }
.pricing-sub { font-size: 15px; color: #6E6E73; margin-bottom: 48px; }
