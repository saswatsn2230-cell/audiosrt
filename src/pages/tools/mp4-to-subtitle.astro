---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const howToJsonLd = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to convert MP4 video to SRT or VTT subtitles",
  "description": "Convert any MP4 video file into frame-accurate SRT or VTT subtitle files using AudioSRT's free browser-based tool.",
  "step": [
    { "@type": "HowToStep", "name": "Upload your MP4", "text": "Drop your MP4 (or MOV, WebM) file into AudioSRT. The video stays on your device — no upload to any server." },
    { "@type": "HowToStep", "name": "Transcribe with Whisper AI", "text": "Whisper AI runs in your browser and generates a word-level transcript synced to the video timeline. Preview playback in a live 16:9 or 9:16 canvas as it processes." },
    { "@type": "HowToStep", "name": "Edit and export SRT or VTT", "text": "Fix words, split lines, adjust timestamps, style the subtitles, then export as SRT, VTT, or Premiere Pro JSON — frame-accurate and import-ready." }
  ]
};
---

<BaseLayout
  title="Convert MP4 to Subtitles Free — SRT, VTT, Premiere JSON | AudioSRT"
  description="Convert MP4 video files to SRT or VTT subtitles online, free. Edit subtitle timing and styling before exporting, all in your browser."
  canonical="https://audiosrt.com/tools/mp4-to-subtitle"
  jsonLd={howToJsonLd}
>
  <Header />

  <main class="lp-main">

    <section class="lp-hero">
      <div class="lp-badge">MP4 · MOV · WebM — Video Supported</div>
      <h1 class="lp-h1">Convert MP4 to Subtitles<br><span class="lp-accent">Free Online Tool</span></h1>
      <p class="lp-intro">Drop any MP4 video file and AudioSRT generates frame-accurate SRT or VTT subtitle files directly in your browser. Preview subtitles on the video before exporting. No upload, no account, no file size cap.</p>
      <a href="/tool" class="lp-cta">Convert MP4 to SRT Free →</a>
    </section>

    <section class="lp-steps-section">
      <h2>How MP4-to-subtitle conversion works</h2>
      <div class="lp-steps">
        <div class="lp-step">
          <div class="lp-step-num">01</div>
          <h3>Upload your MP4</h3>
          <p>Drop your .mp4, .mov, or .webm file. AudioSRT extracts the audio track locally — your video is never sent to a server. Any resolution, any length.</p>
        </div>
        <div class="lp-step">
          <div class="lp-step-num">02</div>
          <h3>Whisper transcribes the audio</h3>
          <p>OpenAI's Whisper model runs in a background Web Worker. The transcript builds progressively — each 30-second segment is available for editing as soon as it completes.</p>
        </div>
        <div class="lp-step">
          <div class="lp-step-num">03</div>
          <h3>Style and export your subtitles</h3>
          <p>Preview subtitles burned onto your video in real time. Adjust font, size, stroke, shadow, and position. Export SRT, VTT, Premiere Pro JSON, or a fully-rendered MP4 with subtitles burned in.</p>
        </div>
      </div>
    </section>

    <section class="lp-features">
      <h2>What you get from an MP4-to-subtitle conversion</h2>
      <div class="lp-feature-grid">
        <div class="lp-feature-card">
          <div class="lp-feature-icon">🎬</div>
          <h3>Live video preview</h3>
          <p>As you edit subtitle text or timing, the preview canvas updates instantly. Switch between 16:9 and 9:16 canvas sizes to check how subtitles sit in either aspect ratio.</p>
        </div>
        <div class="lp-feature-card">
          <div class="lp-feature-icon">✂️</div>
          <h3>Split lines by word</h3>
          <p>Click any word in the transcript to split a subtitle line at that exact point. Timestamps recalculate automatically — no manual time-code editing.</p>
        </div>
        <div class="lp-feature-card">
          <div class="lp-feature-icon">📦</div>
          <h3>Four export formats</h3>
          <p>SRT, VTT, plain text, and native Adobe Premiere Pro JSON — all from one export menu. Import the JSON directly into Premiere's Text-Based Editing panel.</p>
        </div>
        <div class="lp-feature-card">
          <div class="lp-feature-icon">🔒</div>
          <h3>Entirely client-side</h3>
          <p>The MP4 never leaves your machine. All processing — audio extraction, transcription, subtitle rendering — happens inside your browser using Web Workers and WASM.</p>
        </div>
      </div>
    </section>

    <section class="lp-cta-section">
      <h2>Convert your MP4 to subtitles now</h2>
      <p>Free to use. No signup. No upload. Works on any modern browser.</p>
      <a href="/tool" class="lp-cta">Open the Subtitle Converter →</a>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
.lp-main { font-family: 'Inter', sans-serif; color: #1D1D1F; }
.lp-hero { text-align: center; padding: 80px 20px 60px; max-width: 760px; margin: 0 auto; }
.lp-badge { display: inline-flex; align-items: center; background: #EEEFFD; color: #6366F1; font-size: 12px; font-weight: 500; padding: 5px 14px; border-radius: 20px; border: 0.5px solid #C7C8F9; margin-bottom: 24px; }
.lp-h1 { font-size: clamp(28px, 4.5vw, 46px); font-weight: 700; line-height: 1.15; letter-spacing: -0.8px; margin-bottom: 16px; }
.lp-accent { color: #6366F1; }
.lp-intro { font-size: 15px; color: #6E6E73; line-height: 1.7; margin-bottom: 32px; max-width: 560px; margin-left: auto; margin-right: auto; }
.lp-cta { display: inline-block; background: #6366F1; color: #fff; padding: 13px 28px; border-radius: 10px; font-size: 15px; font-weight: 500; text-decoration: none; transition: background 0.15s; }
.lp-cta:hover { background: #4F46E5; }
.lp-steps-section { padding: 64px 20px; max-width: 900px; margin: 0 auto; background: #F5F5F7; border-radius: 24px; text-align: center; }
.lp-steps-section h2 { font-size: 26px; font-weight: 700; margin-bottom: 40px; letter-spacing: -0.5px; }
.lp-steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; text-align: left; }
@media (max-width: 768px) { .lp-steps { grid-template-columns: 1fr; } }
.lp-step-num { font-size: 44px; font-weight: 800; color: #EEEFFD; letter-spacing: -2px; margin-bottom: 12px; }
.lp-step h3 { font-size: 15px; font-weight: 600; margin-bottom: 8px; }
.lp-step p { font-size: 13px; color: #6E6E73; line-height: 1.6; }
.lp-features { padding: 64px 20px; max-width: 900px; margin: 0 auto; }
.lp-features h2 { font-size: 26px; font-weight: 700; text-align: center; margin-bottom: 36px; letter-spacing: -0.5px; }
.lp-feature-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
@media (max-width: 600px) { .lp-feature-grid { grid-template-columns: 1fr; } }
.lp-feature-card { background: #fff; border: 0.5px solid #E5E5E7; border-radius: 14px; padding: 24px; }
.lp-feature-icon { font-size: 24px; margin-bottom: 12px; }
.lp-feature-card h3 { font-size: 15px; font-weight: 600; margin-bottom: 8px; }
.lp-feature-card p { font-size: 13px; color: #6E6E73; line-height: 1.6; }
.lp-cta-section { text-align: center; padding: 64px 20px 80px; }
.lp-cta-section h2 { font-size: 24px; font-weight: 700; margin-bottom: 8px; }
.lp-cta-section p { font-size: 14px; color: #6E6E73; margin-bottom: 24px; }
</style>
