---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const howToJsonLd = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to generate an SRT file free with AudioSRT",
  "description": "Create a frame-accurate SRT subtitle file from any audio or video file, entirely in your browser — no upload, no account.",
  "step": [
    { "@type": "HowToStep", "name": "Upload your file", "text": "Open AudioSRT and drop any MP3, WAV, M4A, MP4, MOV, or WebM file. No file size limit. Nothing leaves your device." },
    { "@type": "HowToStep", "name": "Whisper AI transcribes locally", "text": "OpenAI's Whisper model runs in your browser using Web Workers. No upload, no queue, no waiting for a server. Transcription begins immediately." },
    { "@type": "HowToStep", "name": "Download your SRT file", "text": "Review and edit the transcript, then click Export and download a frame-accurate .srt file ready to import into any video editor or player." }
  ]
};
---

<BaseLayout
  title="Free SRT Generator Online — No Signup, No Upload | AudioSRT"
  description="Generate accurate SRT subtitle files from any audio or video for free. No account, no upload, no file limits. Runs entirely in your browser."
  canonical="https://audiosrt.com/tools/free-srt-generator"
  jsonLd={howToJsonLd}
>
  <Header />

  <main class="lp-main">

    <!-- Hero -->
    <section class="lp-hero">
      <div class="lp-badge">Free — No Account Required</div>
      <h1 class="lp-h1">Free SRT Generator<br><span class="lp-accent">Create Subtitle Files Online</span></h1>
      <p class="lp-intro">AudioSRT generates frame-accurate SRT files from any audio or video file, entirely inside your browser. No upload to a server, no account, no file size limit — just accurate subtitles ready to drop into any editor or player.</p>
      <a href="/tool" class="lp-cta">Generate SRT Free →</a>
    </section>

    <!-- How it works -->
    <section class="lp-steps-section">
      <h2>How to auto-create SRT files</h2>
      <div class="lp-steps">
        <div class="lp-step">
          <div class="lp-step-num">01</div>
          <h3>Upload your file</h3>
          <p>Drop any MP3, WAV, M4A, MP4, MOV, or WebM file. Any length, any size. AudioSRT reads the file locally — nothing is sent to a server.</p>
        </div>
        <div class="lp-step">
          <div class="lp-step-num">02</div>
          <h3>AI transcribes in your browser</h3>
          <p>OpenAI's Whisper model runs inside a Web Worker, completely off the UI thread. Transcription starts in seconds and updates progressively as each 30-second segment completes.</p>
        </div>
        <div class="lp-step">
          <div class="lp-step-num">03</div>
          <h3>Download your SRT</h3>
          <p>Edit any word or timestamp, then export a clean, frame-accurate .srt file. Compatible with Premiere Pro, DaVinci Resolve, Final Cut Pro, VLC, and any SRT-compatible player.</p>
        </div>
      </div>
    </section>

    <!-- Feature list -->
    <section class="lp-features">
      <h2>What makes this SRT generator different</h2>
      <div class="lp-feature-grid">
        <div class="lp-feature-card">
          <div class="lp-feature-icon">🔒</div>
          <h3>Zero upload</h3>
          <p>Your media never leaves your device. Whisper AI inference runs entirely inside your browser's Web Worker thread using WASM.</p>
        </div>
        <div class="lp-feature-card">
          <div class="lp-feature-icon">∞</div>
          <h3>No file limits</h3>
          <p>No cap on file size or duration. Hour-long podcasts, full-length films — AudioSRT processes them in natural VAD-split segments without freezing your browser.</p>
        </div>
        <div class="lp-feature-card">
          <div class="lp-feature-icon">✏️</div>
          <h3>Edit before export</h3>
          <p>Fix misheard words, adjust timestamps, split or merge subtitle lines — then generate the final SRT. You get a clean file, not a raw dump of the AI output.</p>
        </div>
        <div class="lp-feature-card">
          <div class="lp-feature-icon">🎬</div>
          <h3>NLE-ready output</h3>
          <p>The exported SRT uses millisecond-accurate timestamps in the standard <code>HH:MM:SS,mmm</code> format, importable directly into any professional NLE.</p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="lp-cta-section">
      <h2>Ready to generate your first SRT file?</h2>
      <p>No signup. No upload. Free to start.</p>
      <a href="/tool" class="lp-cta">Open the SRT Generator →</a>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
.lp-main { font-family: 'Inter', sans-serif; color: #1D1D1F; }

.lp-hero { text-align: center; padding: 80px 20px 60px; max-width: 760px; margin: 0 auto; }
.lp-badge { display: inline-flex; align-items: center; background: #EEEFFD; color: #6366F1; font-size: 12px; font-weight: 500; padding: 5px 14px; border-radius: 20px; border: 0.5px solid #C7C8F9; margin-bottom: 24px; }
.lp-h1 { font-size: clamp(28px, 4.5vw, 46px); font-weight: 700; line-height: 1.15; letter-spacing: -0.8px; margin-bottom: 16px; }
.lp-accent { color: #6366F1; }
.lp-intro { font-size: 15px; color: #6E6E73; line-height: 1.7; margin-bottom: 32px; max-width: 560px; margin-left: auto; margin-right: auto; }
.lp-cta { display: inline-block; background: #6366F1; color: #fff; padding: 13px 28px; border-radius: 10px; font-size: 15px; font-weight: 500; text-decoration: none; transition: background 0.15s; }
.lp-cta:hover { background: #4F46E5; }

.lp-steps-section { padding: 64px 20px; max-width: 900px; margin: 0 auto; background: #F5F5F7; border-radius: 24px; text-align: center; }
.lp-steps-section h2 { font-size: 26px; font-weight: 700; margin-bottom: 40px; letter-spacing: -0.5px; }
.lp-steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; text-align: left; }
@media (max-width: 768px) { .lp-steps { grid-template-columns: 1fr; } }
.lp-step-num { font-size: 44px; font-weight: 800; color: #EEEFFD; letter-spacing: -2px; margin-bottom: 12px; }
.lp-step h3 { font-size: 15px; font-weight: 600; margin-bottom: 8px; }
.lp-step p { font-size: 13px; color: #6E6E73; line-height: 1.6; }

.lp-features { padding: 64px 20px; max-width: 900px; margin: 0 auto; }
.lp-features h2 { font-size: 26px; font-weight: 700; text-align: center; margin-bottom: 36px; letter-spacing: -0.5px; }
.lp-feature-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
@media (max-width: 600px) { .lp-feature-grid { grid-template-columns: 1fr; } }
.lp-feature-card { background: #fff; border: 0.5px solid #E5E5E7; border-radius: 14px; padding: 24px; }
.lp-feature-icon { font-size: 24px; margin-bottom: 12px; }
.lp-feature-card h3 { font-size: 15px; font-weight: 600; margin-bottom: 8px; }
.lp-feature-card p { font-size: 13px; color: #6E6E73; line-height: 1.6; }
.lp-feature-card code { font-size: 11px; background: #F5F5F7; padding: 1px 5px; border-radius: 4px; }

.lp-cta-section { text-align: center; padding: 64px 20px 80px; }
.lp-cta-section h2 { font-size: 24px; font-weight: 700; margin-bottom: 8px; }
.lp-cta-section p { font-size: 14px; color: #6E6E73; margin-bottom: 24px; }
</style>
