---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---
<BaseLayout title="Video Transcription Software Free — No Upload, Browser-Based | AudioSRT" description="Free video transcription software that runs entirely in your browser. Transcribe, style subtitles, and export burned-in video or SRT files." canonical="https://audiosrt.com/tools/video-transcription-software">
  <Header />
  <main class="lp-main">

    <section class="lp-hero">
      <span class="lp-badge">MP4 · MOV · WebM — Full Workflow</span>
      <h1 class="lp-h1">Video Transcription Software<br><span class="lp-accent">Free, Browser-Based</span></h1>
      <p class="lp-intro">
        Most "video transcription" tools stop at the transcript. You get text — and then you're on your own to find a subtitle editor, format the SRT, import it into your NLE, and style it for output. AudioSRT is the full loop in one place: upload the video, watch the preview while Whisper transcribes, edit the subtitles, style them, and export the finished file — whether that's SRT, VTT, Premiere JSON, or a burned-in MP4.
      </p>
      <p class="lp-intro">
        Nothing uploads. Your video is processed locally in the browser, which makes this appropriate for client footage, pre-release content, and anything where you'd ordinarily hesitate before putting a file into a cloud tool. For simpler MP4-specific subtitle workflows, see <a href="/tools/mp4-to-subtitle" class="lp-inline-link">MP4 to subtitle</a>. For the Adobe Premiere Pro integration specifically, the <a href="/integrations/adobe-premiere-pro" class="lp-inline-link">Premiere Pro page</a> covers the JSON export path.
      </p>
      <a href="/tool" class="lp-cta">Start video transcription →</a>
    </section>

    <section class="lp-steps-section" style="margin: 0 auto 48px;">
      <h2>The complete video subtitle workflow</h2>
      <div class="lp-steps">
        <div class="lp-step">
          <div class="lp-step-num">01</div>
          <h3>Upload your video file</h3>
          <p>Load an MP4, MOV, or WebM file of any length. The video is processed entirely on your device — no upload, no server, no waiting for a remote queue to pick up your job.</p>
        </div>
        <div class="lp-step">
          <div class="lp-step-num">02</div>
          <h3>Transcribe and preview</h3>
          <p>Whisper AI transcribes the audio track while the video plays in the preview panel. Active words highlight in sync with playback, so you can spot transcription errors in context without reading the full text separately.</p>
        </div>
        <div class="lp-step">
          <div class="lp-step-num">03</div>
          <h3>Style and export</h3>
          <p>Set font, size, color, and position for your subtitles, then choose your export format: SRT for most platforms, VTT for web, Premiere JSON for NLE import, or burned-in MP4 for a finished standalone file.</p>
        </div>
      </div>
    </section>

    <section class="lp-features">
      <h2>One tool for the full workflow</h2>
      <div class="lp-feature-grid">
        <div class="lp-feature-card">
          <div class="lp-feature-icon">🎬</div>
          <h3>Full video preview while transcribing</h3>
          <p>Preview your video in a 16:9 or 9:16 canvas with synchronized subtitle highlighting. Review accuracy in the context of the actual video, not just the raw text.</p>
        </div>
        <div class="lp-feature-card">
          <div class="lp-feature-icon">🎨</div>
          <h3>Subtitle styling built in</h3>
          <p>Typography controls — font, size, weight, color, stroke, position — are part of the same tool, not a separate step in a different application. Style once, export to any format.</p>
        </div>
        <div class="lp-feature-card">
          <div class="lp-feature-icon">📦</div>
          <h3>Every export format</h3>
          <p>SRT for universal compatibility, VTT for web players, Premiere JSON for direct NLE import, and burned-in MP4 for finished standalone delivery. All from the same project.</p>
        </div>
        <div class="lp-feature-card">
          <div class="lp-feature-icon">🔒</div>
          <h3>Video stays on your device</h3>
          <p>No upload at any point. Client footage, pre-release cuts, and confidential recordings never leave your machine during transcription or export.</p>
        </div>
      </div>
    </section>

    <section class="lp-cta-section">
      <h2>Start your video transcription</h2>
      <p>Completely free — video transcription, no account required.</p>
      <a href="/tool" class="lp-cta">Start free trial →</a>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
.lp-main { font-family: 'Inter', sans-serif; color: #1D1D1F; }
.lp-hero { text-align: center; padding: 80px 20px 60px; max-width: 760px; margin: 0 auto; }
.lp-badge { display: inline-flex; align-items: center; background: #EEEFFD; color: #6366F1; font-size: 12px; font-weight: 500; padding: 5px 14px; border-radius: 20px; border: 0.5px solid #C7C8F9; margin-bottom: 24px; }
.lp-h1 { font-size: clamp(28px, 4.5vw, 46px); font-weight: 700; line-height: 1.15; letter-spacing: -0.8px; margin-bottom: 16px; }
.lp-accent { color: #6366F1; }
.lp-intro { font-size: 15px; color: #6E6E73; line-height: 1.7; margin-bottom: 32px; max-width: 560px; margin-left: auto; margin-right: auto; }
.lp-cta { display: inline-block; background: #6366F1; color: #fff; padding: 13px 28px; border-radius: 10px; font-size: 15px; font-weight: 500; text-decoration: none; transition: background 0.15s; }
.lp-cta:hover { background: #4F46E5; }
.lp-steps-section { padding: 64px 20px; max-width: 900px; margin: 0 auto; background: #F5F5F7; border-radius: 24px; text-align: center; }
.lp-steps-section h2 { font-size: 26px; font-weight: 700; margin-bottom: 40px; letter-spacing: -0.5px; }
.lp-steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; text-align: left; }
@media (max-width: 768px) { .lp-steps { grid-template-columns: 1fr; } }
.lp-step-num { font-size: 44px; font-weight: 800; color: #EEEFFD; letter-spacing: -2px; margin-bottom: 12px; }
.lp-step h3 { font-size: 15px; font-weight: 600; margin-bottom: 8px; }
.lp-step p { font-size: 13px; color: #6E6E73; line-height: 1.6; }
.lp-features { padding: 64px 20px; max-width: 900px; margin: 0 auto; }
.lp-features h2 { font-size: 26px; font-weight: 700; text-align: center; margin-bottom: 36px; letter-spacing: -0.5px; }
.lp-feature-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
@media (max-width: 600px) { .lp-feature-grid { grid-template-columns: 1fr; } }
.lp-feature-card { background: #fff; border: 0.5px solid #E5E5E7; border-radius: 14px; padding: 24px; }
.lp-feature-icon { font-size: 24px; margin-bottom: 12px; }
.lp-feature-card h3 { font-size: 15px; font-weight: 600; margin-bottom: 8px; }
.lp-feature-card p { font-size: 13px; color: #6E6E73; line-height: 1.6; }
.lp-cta-section { text-align: center; padding: 64px 20px 80px; }
.lp-cta-section h2 { font-size: 24px; font-weight: 700; margin-bottom: 8px; }
.lp-cta-section p { font-size: 14px; color: #6E6E73; margin-bottom: 24px; }
.lp-body { font-size: 14px; color: #3D3D3F; line-height: 1.8; margin-bottom: 14px; }
.lp-detail { max-width: 680px; margin: 64px auto; padding: 0 20px; }
.lp-detail h2 { font-size: 22px; font-weight: 700; margin-bottom: 16px; }
.lp-inline-link { color: #6366F1; text-decoration: none; }
.lp-inline-link:hover { text-decoration: underline; }
</style>
