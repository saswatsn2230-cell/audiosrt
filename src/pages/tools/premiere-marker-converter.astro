---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const howToJsonLd = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to convert a transcript into Premiere Pro markers",
  "description": "Use AudioSRT to transcribe audio or video and export a Premiere Pro JSON file that maps directly into Premiere's Text-Based Editing panel as frame-accurate transcript markers.",
  "step": [
    { "@type": "HowToStep", "name": "Transcribe in AudioSRT", "text": "Upload your audio or video file. Whisper AI transcribes locally with word-level timestamps. No upload, no queue." },
    { "@type": "HowToStep", "name": "Export as Premiere Pro JSON", "text": "In AudioSRT's Export menu, select Premiere Pro JSON and download the file." },
    { "@type": "HowToStep", "name": "Import into Premiere Pro", "text": "In Premiere Pro, open the Text panel, click the (...) options menu, select Import, then Import Static Transcript. Your transcript appears as frame-accurate markers on the timeline." }
  ]
};
---

<BaseLayout
  title="Convert Transcripts to Premiere Pro Markers — Free | AudioSRT"
  description="Export your transcript directly as a Premiere Pro JSON file. Import into Premiere's Text panel and get frame-accurate timeline markers instantly."
  canonical="https://audiosrt.com/tools/premiere-marker-converter"
  jsonLd={howToJsonLd}
>
  <Header />

  <main class="lp-main">

    <section class="lp-hero">
      <div class="lp-badge">Native Premiere Pro JSON Export</div>
      <h1 class="lp-h1">Convert Transcripts to<br><span class="lp-accent">Premiere Pro Markers</span></h1>
      <p class="lp-intro">AudioSRT exports transcripts directly as Premiere Pro JSON files that map into Premiere's Text-Based Editing panel. Each word carries a frame-accurate timestamp — no manual marker placement, no copy-paste workflows.</p>
      <a href="/tool" class="lp-cta">Convert Transcript Free →</a>
    </section>

    <section class="lp-steps-section">
      <h2>Three steps from audio to Premiere markers</h2>
      <div class="lp-steps">
        <div class="lp-step">
          <div class="lp-step-num">01</div>
          <h3>Transcribe your file</h3>
          <p>Upload MP3, WAV, M4A, MP4, MOV, or WebM. AudioSRT's Whisper AI engine runs locally and produces a word-level transcript with frame-accurate timestamps.</p>
        </div>
        <div class="lp-step">
          <div class="lp-step-num">02</div>
          <h3>Export Premiere Pro JSON</h3>
          <p>Open the Export menu and select Premiere Pro JSON. AudioSRT generates a .json file in the exact format Premiere's Text-Based Editing panel expects.</p>
        </div>
        <div class="lp-step">
          <div class="lp-step-num">03</div>
          <h3>Import into Premiere</h3>
          <p>In Premiere Pro, open <strong>Text panel → (...) → Import → Import Static Transcript</strong>. Your transcript loads as searchable, selectable markers synced to the timeline.</p>
        </div>
      </div>
    </section>

    <!-- Premiere import detail -->
    <section class="lp-detail">
      <h2>The exact Premiere Pro import path</h2>
      <ol class="lp-steps-list">
        <li>Open your sequence in Premiere Pro and switch to the <strong>Text</strong> workspace (Window → Text).</li>
        <li>In the Text panel, click the <strong>(...)</strong> options menu in the top-right corner.</li>
        <li>Select <strong>Import</strong>, then choose <strong>Import Static Transcript</strong>.</li>
        <li>Locate and open the <code>.json</code> file downloaded from AudioSRT.</li>
        <li>Your transcript appears as selectable, searchable words synced frame-accurately to your timeline — ready for Text-Based Editing.</li>
      </ol>
      <p class="lp-detail-note">This workflow works in Premiere Pro 2023 (v23.0) and later. The JSON format AudioSRT exports matches Adobe's public transcript schema exactly.</p>
    </section>

    <section class="lp-features">
      <h2>Why use AudioSRT for Premiere transcripts</h2>
      <div class="lp-feature-grid">
        <div class="lp-feature-card">
          <div class="lp-feature-icon">🎯</div>
          <h3>Frame-accurate timestamps</h3>
          <p>Whisper's word-level timestamps are mapped to millisecond precision. When you click a word in Premiere's Text panel, playback jumps to the exact frame.</p>
        </div>
        <div class="lp-feature-card">
          <div class="lp-feature-icon">✏️</div>
          <h3>Edit before you export</h3>
          <p>Fix misheard words, merge or split lines, and adjust timestamps inside AudioSRT before generating the JSON. The exported file is clean — not a raw AI dump.</p>
        </div>
        <div class="lp-feature-card">
          <div class="lp-feature-icon">🔒</div>
          <h3>Client footage stays private</h3>
          <p>Everything runs in your browser. Client video and audio never touches a third-party server. Safe for NDA-bound productions.</p>
        </div>
        <div class="lp-feature-card">
          <div class="lp-feature-icon">🆓</div>
          <h3>Free to start</h3>
          <p>Audio files are free with no signup. Video uploads and Premiere Pro JSON export are included in the Starter plan — 14-day free trial, no credit card required.</p>
        </div>
      </div>
    </section>

    <section class="lp-cta-section">
      <h2>Ready to build Premiere markers from your transcript?</h2>
      <p>Free for audio. 14-day trial for video + Premiere JSON export.</p>
      <a href="/tool" class="lp-cta">Open AudioSRT →</a>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
.lp-main { font-family: 'Inter', sans-serif; color: #1D1D1F; }
.lp-hero { text-align: center; padding: 80px 20px 60px; max-width: 760px; margin: 0 auto; }
.lp-badge { display: inline-flex; align-items: center; background: #EEEFFD; color: #6366F1; font-size: 12px; font-weight: 500; padding: 5px 14px; border-radius: 20px; border: 0.5px solid #C7C8F9; margin-bottom: 24px; }
.lp-h1 { font-size: clamp(28px, 4.5vw, 46px); font-weight: 700; line-height: 1.15; letter-spacing: -0.8px; margin-bottom: 16px; }
.lp-accent { color: #6366F1; }
.lp-intro { font-size: 15px; color: #6E6E73; line-height: 1.7; margin-bottom: 32px; max-width: 560px; margin-left: auto; margin-right: auto; }
.lp-cta { display: inline-block; background: #6366F1; color: #fff; padding: 13px 28px; border-radius: 10px; font-size: 15px; font-weight: 500; text-decoration: none; transition: background 0.15s; }
.lp-cta:hover { background: #4F46E5; }
.lp-steps-section { padding: 64px 20px; max-width: 900px; margin: 0 auto; background: #F5F5F7; border-radius: 24px; text-align: center; }
.lp-steps-section h2 { font-size: 26px; font-weight: 700; margin-bottom: 40px; letter-spacing: -0.5px; }
.lp-steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; text-align: left; }
@media (max-width: 768px) { .lp-steps { grid-template-columns: 1fr; } }
.lp-step-num { font-size: 44px; font-weight: 800; color: #EEEFFD; letter-spacing: -2px; margin-bottom: 12px; }
.lp-step h3 { font-size: 15px; font-weight: 600; margin-bottom: 8px; }
.lp-step p { font-size: 13px; color: #6E6E73; line-height: 1.6; }

.lp-detail { max-width: 680px; margin: 64px auto; padding: 0 20px; }
.lp-detail h2 { font-size: 22px; font-weight: 700; margin-bottom: 24px; }
.lp-steps-list { padding-left: 20px; }
.lp-steps-list li { font-size: 14px; color: #3D3D3F; line-height: 1.7; margin-bottom: 12px; }
.lp-steps-list strong { color: #1D1D1F; }
.lp-steps-list code { font-size: 12px; background: #F5F5F7; padding: 2px 6px; border-radius: 4px; }
.lp-detail-note { font-size: 12px; color: #A0A0A5; margin-top: 20px; line-height: 1.6; }

.lp-features { padding: 64px 20px; max-width: 900px; margin: 0 auto; }
.lp-features h2 { font-size: 26px; font-weight: 700; text-align: center; margin-bottom: 36px; letter-spacing: -0.5px; }
.lp-feature-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
@media (max-width: 600px) { .lp-feature-grid { grid-template-columns: 1fr; } }
.lp-feature-card { background: #fff; border: 0.5px solid #E5E5E7; border-radius: 14px; padding: 24px; }
.lp-feature-icon { font-size: 24px; margin-bottom: 12px; }
.lp-feature-card h3 { font-size: 15px; font-weight: 600; margin-bottom: 8px; }
.lp-feature-card p { font-size: 13px; color: #6E6E73; line-height: 1.6; }
.lp-cta-section { text-align: center; padding: 64px 20px 80px; }
.lp-cta-section h2 { font-size: 24px; font-weight: 700; margin-bottom: 8px; }
.lp-cta-section p { font-size: 14px; color: #6E6E73; margin-bottom: 24px; }
</style>
