---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const softwareJsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "AudioSRT for Adobe Premiere Pro",
  "applicationCategory": "MultimediaApplication",
  "operatingSystem": "Web Browser",
  "description": "Browser-based audio transcription tool that exports native Adobe Premiere Pro JSON files for Text-Based Editing.",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
};
---

<BaseLayout
  title="AudioSRT + Adobe Premiere Pro Integration — Native JSON Export"
  description="Export transcripts directly into Adobe Premiere Pro's Text-Based Editing panel. Frame-accurate, free, browser-based subtitle and transcript generation."
  canonical="https://audiosrt.com/integrations/adobe-premiere-pro"
  jsonLd={softwareJsonLd}
>
  <Header />

  <main class="lp-main">

    <section class="lp-hero">
      <div class="lp-badge">Native Premiere Pro Integration</div>
      <h1 class="lp-h1">AudioSRT for<br><span class="lp-accent">Adobe Premiere Pro</span></h1>
      <p class="lp-intro">AudioSRT exports your transcript as a native Premiere Pro JSON file that loads directly into Premiere's Text-Based Editing panel — frame-accurate, word-synced, and ready to cut.</p>
      <a href="/tool" class="lp-cta">Generate Transcript Free →</a>
    </section>

    <!-- How the integration works -->
    <section class="lp-detail lp-detail--wide">
      <h2>How the Premiere Pro integration works</h2>
      <p class="lp-body">Premiere Pro's Text-Based Editing panel (available since Premiere Pro 2023) can import transcripts in a specific JSON schema. AudioSRT generates this file exactly — mapping each word's start time, end time, and text to the format Premiere expects. When you import it, every word in the transcript is clickable and seeks to the correct frame in your timeline.</p>
      <p class="lp-body">Frame accuracy here means AudioSRT's timestamps are in milliseconds, and Premiere maps them to your sequence's frame rate automatically. A word at 1:23.456 in a 24fps sequence lands on the correct frame without rounding error.</p>
    </section>

    <!-- Step by step -->
    <section class="lp-steps-section">
      <h2>Step-by-step: from audio to Premiere timeline</h2>
      <div class="lp-steps">
        <div class="lp-step">
          <div class="lp-step-num">01</div>
          <h3>Upload in AudioSRT</h3>
          <p>Drop your MP3, WAV, M4A, MP4, MOV, or WebM file. Whisper AI transcribes locally — your media never leaves your device.</p>
        </div>
        <div class="lp-step">
          <div class="lp-step-num">02</div>
          <h3>Edit the transcript</h3>
          <p>Fix misheard words, adjust timestamps, split or merge subtitle lines. The JSON export reflects exactly what you have in the editor.</p>
        </div>
        <div class="lp-step">
          <div class="lp-step-num">03</div>
          <h3>Export Premiere JSON</h3>
          <p>Click Export → Premiere Pro JSON. Download the .json file — it's formatted to the exact schema Premiere's Text-Based Editing panel uses.</p>
        </div>
      </div>
    </section>

    <!-- Premiere import steps -->
    <section class="lp-detail">
      <h2>Importing into Premiere Pro</h2>
      <ol class="lp-steps-list">
        <li>Open your sequence in Premiere Pro. Go to <strong>Window → Text</strong> to open the Text panel.</li>
        <li>In the Text panel, click the <strong>(...)</strong> options menu at the top right.</li>
        <li>Select <strong>Import</strong>, then <strong>Import Static Transcript</strong>.</li>
        <li>Navigate to and open the <code>.json</code> file from AudioSRT.</li>
        <li>Your full transcript appears in the Text panel with every word clickable and frame-synced to the timeline. Select words, right-click to insert edit points, or use text search to jump to any moment.</li>
      </ol>
      <p class="lp-detail-note">Requires Premiere Pro 2023 (version 23.0) or later. The Text-Based Editing panel was introduced in that release. Earlier versions of Premiere do not have the panel.</p>
    </section>

    <section class="lp-features">
      <h2>What this integration gives you</h2>
      <div class="lp-feature-grid">
        <div class="lp-feature-card">
          <div class="lp-feature-icon">⚡</div>
          <h3>No third-party plugin</h3>
          <p>The JSON file is imported natively through Premiere's own import dialog — no extensions, no plugins, no subscription to a Premiere add-on required.</p>
        </div>
        <div class="lp-feature-card">
          <div class="lp-feature-icon">🎯</div>
          <h3>Word-level seek</h3>
          <p>Click any word in the imported transcript and Premiere's playhead jumps to that exact frame. Edit by selecting words and using Premiere's built-in text-based editing tools.</p>
        </div>
        <div class="lp-feature-card">
          <div class="lp-feature-icon">🔒</div>
          <h3>Safe for client footage</h3>
          <p>AudioSRT runs entirely in your browser. Client video and audio never touches any server. Appropriate for productions under NDA or with sensitive footage.</p>
        </div>
        <div class="lp-feature-card">
          <div class="lp-feature-icon">🆓</div>
          <h3>Free for audio, trial for video</h3>
          <p>Audio transcription and Premiere JSON export from audio files is free, no signup. Video uploads and Premiere JSON export are included in the 14-day Starter trial.</p>
        </div>
      </div>
    </section>

    <section class="lp-cta-section">
      <h2>Start building your Premiere transcript</h2>
      <p>Free for audio. 14-day trial for video — no credit card required.</p>
      <a href="/tool" class="lp-cta">Open AudioSRT →</a>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
.lp-main { font-family: 'Inter', sans-serif; color: #1D1D1F; }
.lp-hero { text-align: center; padding: 80px 20px 60px; max-width: 760px; margin: 0 auto; }
.lp-badge { display: inline-flex; align-items: center; background: #EEEFFD; color: #6366F1; font-size: 12px; font-weight: 500; padding: 5px 14px; border-radius: 20px; border: 0.5px solid #C7C8F9; margin-bottom: 24px; }
.lp-h1 { font-size: clamp(28px, 4.5vw, 46px); font-weight: 700; line-height: 1.15; letter-spacing: -0.8px; margin-bottom: 16px; }
.lp-accent { color: #6366F1; }
.lp-intro { font-size: 15px; color: #6E6E73; line-height: 1.7; margin-bottom: 32px; max-width: 560px; margin-left: auto; margin-right: auto; }
.lp-cta { display: inline-block; background: #6366F1; color: #fff; padding: 13px 28px; border-radius: 10px; font-size: 15px; font-weight: 500; text-decoration: none; transition: background 0.15s; }
.lp-cta:hover { background: #4F46E5; }

.lp-detail { max-width: 680px; margin: 64px auto; padding: 0 20px; }
.lp-detail--wide { max-width: 760px; }
.lp-detail h2 { font-size: 22px; font-weight: 700; margin-bottom: 16px; }
.lp-body { font-size: 14px; color: #3D3D3F; line-height: 1.8; margin-bottom: 14px; }
.lp-steps-list { padding-left: 20px; margin-top: 8px; }
.lp-steps-list li { font-size: 14px; color: #3D3D3F; line-height: 1.7; margin-bottom: 12px; }
.lp-steps-list strong { color: #1D1D1F; }
.lp-steps-list code { font-size: 12px; background: #F5F5F7; padding: 2px 6px; border-radius: 4px; }
.lp-detail-note { font-size: 12px; color: #A0A0A5; margin-top: 20px; line-height: 1.6; }

.lp-steps-section { padding: 64px 20px; max-width: 900px; margin: 0 auto; background: #F5F5F7; border-radius: 24px; text-align: center; }
.lp-steps-section h2 { font-size: 26px; font-weight: 700; margin-bottom: 40px; letter-spacing: -0.5px; }
.lp-steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; text-align: left; }
@media (max-width: 768px) { .lp-steps { grid-template-columns: 1fr; } }
.lp-step-num { font-size: 44px; font-weight: 800; color: #EEEFFD; letter-spacing: -2px; margin-bottom: 12px; }
.lp-step h3 { font-size: 15px; font-weight: 600; margin-bottom: 8px; }
.lp-step p { font-size: 13px; color: #6E6E73; line-height: 1.6; }

.lp-features { padding: 64px 20px; max-width: 900px; margin: 0 auto; }
.lp-features h2 { font-size: 26px; font-weight: 700; text-align: center; margin-bottom: 36px; letter-spacing: -0.5px; }
.lp-feature-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
@media (max-width: 600px) { .lp-feature-grid { grid-template-columns: 1fr; } }
.lp-feature-card { background: #fff; border: 0.5px solid #E5E5E7; border-radius: 14px; padding: 24px; }
.lp-feature-icon { font-size: 24px; margin-bottom: 12px; }
.lp-feature-card h3 { font-size: 15px; font-weight: 600; margin-bottom: 8px; }
.lp-feature-card p { font-size: 13px; color: #6E6E73; line-height: 1.6; }
.lp-cta-section { text-align: center; padding: 64px 20px 80px; }
.lp-cta-section h2 { font-size: 24px; font-weight: 700; margin-bottom: 8px; }
.lp-cta-section p { font-size: 14px; color: #6E6E73; margin-bottom: 24px; }
</style>
