---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const softwareJsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "AudioSRT for DaVinci Resolve",
  "applicationCategory": "MultimediaApplication",
  "operatingSystem": "Web Browser",
  "description": "Browser-based audio transcription tool that exports frame-accurate SRT and VTT subtitle files for DaVinci Resolve.",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
};
---

<BaseLayout
  title="AudioSRT + DaVinci Resolve — Free Subtitle Export"
  description="Generate frame-accurate SRT and VTT subtitle files for DaVinci Resolve. Free, browser-based, no upload required."
  canonical="https://audiosrt.com/integrations/davinci-resolve"
  jsonLd={softwareJsonLd}
>
  <Header />

  <main class="lp-main">

    <section class="lp-hero">
      <div class="lp-badge">SRT · VTT — DaVinci Resolve Compatible</div>
      <h1 class="lp-h1">AudioSRT for<br><span class="lp-accent">DaVinci Resolve</span></h1>
      <p class="lp-intro">Generate frame-accurate SRT and VTT subtitle files from any audio or video file, then import them directly into DaVinci Resolve's Subtitles track. Everything runs in your browser — no upload, no account required.</p>
      <a href="/tool" class="lp-cta">Generate Subtitles Free →</a>
    </section>

    <!-- How it works -->
    <section class="lp-steps-section">
      <h2>From audio to DaVinci Resolve in three steps</h2>
      <div class="lp-steps">
        <div class="lp-step">
          <div class="lp-step-num">01</div>
          <h3>Upload your file</h3>
          <p>Drop any MP3, WAV, M4A, MP4, MOV, or WebM file into AudioSRT. Audio and video are both supported. Nothing leaves your device.</p>
        </div>
        <div class="lp-step">
          <div class="lp-step-num">02</div>
          <h3>Transcribe with Whisper AI</h3>
          <p>AudioSRT runs OpenAI's Whisper model in your browser. You get a word-level transcript with millisecond timestamps — no queue, no upload wait, no subscription.</p>
        </div>
        <div class="lp-step">
          <div class="lp-step-num">03</div>
          <h3>Export SRT and import into Resolve</h3>
          <p>Download the .srt or .vtt file. In DaVinci Resolve, go to <strong>File → Import → Subtitles</strong>. Your subtitle track appears on the timeline, frame-accurate and fully editable.</p>
        </div>
      </div>
    </section>

    <!-- DaVinci import detail -->
    <section class="lp-detail">
      <h2>Importing SRT subtitles into DaVinci Resolve</h2>
      <ol class="lp-steps-list">
        <li>Open your project in DaVinci Resolve and switch to the <strong>Edit</strong> page.</li>
        <li>Go to <strong>File → Import → Subtitles…</strong></li>
        <li>Select the <code>.srt</code> file downloaded from AudioSRT.</li>
        <li>Resolve creates a Subtitles track on the timeline. Each subtitle block is a separate clip you can trim, retime, or restyle.</li>
        <li>Double-click any subtitle clip to edit its text directly in the Inspector. Use the <strong>Subtitles</strong> tab in the Inspector to change font, size, color, and position globally.</li>
      </ol>
      <p class="lp-detail-note">VTT files import the same way. DaVinci Resolve Free and Studio both support SRT/VTT subtitle import. Tested in DaVinci Resolve 18 and later.</p>
    </section>

    <section class="lp-features">
      <h2>What you get with AudioSRT + DaVinci Resolve</h2>
      <div class="lp-feature-grid">
        <div class="lp-feature-card">
          <div class="lp-feature-icon">🎯</div>
          <h3>Frame-accurate timestamps</h3>
          <p>AudioSRT's SRT files use millisecond-precision timestamps. DaVinci maps them to your sequence frame rate — no drift, no off-by-one-frame errors across long timelines.</p>
        </div>
        <div class="lp-feature-card">
          <div class="lp-feature-icon">✏️</div>
          <h3>Edit before you export</h3>
          <p>Fix misheard words, adjust timing, split long lines — all inside AudioSRT. The SRT you import into Resolve is already clean and reviewed, not raw AI output.</p>
        </div>
        <div class="lp-feature-card">
          <div class="lp-feature-icon">🔒</div>
          <h3>Client footage stays private</h3>
          <p>Everything runs inside your browser. Client video and audio never touches any external server — appropriate for productions under NDA or with sensitive content.</p>
        </div>
        <div class="lp-feature-card">
          <div class="lp-feature-icon">∞</div>
          <h3>No file size cap</h3>
          <p>Feature-length films, multi-hour podcast recordings — AudioSRT processes them in natural 30-second VAD-split segments without browser crashes or memory issues.</p>
        </div>
      </div>
    </section>

    <section class="lp-cta-section">
      <h2>Ready to generate subtitles for DaVinci Resolve?</h2>
      <p>Completely free — audio and video, no account required.</p>
      <a href="/tool" class="lp-cta">Open AudioSRT →</a>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
.lp-main { font-family: 'Inter', sans-serif; color: #1D1D1F; }
.lp-hero { text-align: center; padding: 80px 20px 60px; max-width: 760px; margin: 0 auto; }
.lp-badge { display: inline-flex; align-items: center; background: #EEEFFD; color: #6366F1; font-size: 12px; font-weight: 500; padding: 5px 14px; border-radius: 20px; border: 0.5px solid #C7C8F9; margin-bottom: 24px; }
.lp-h1 { font-size: clamp(28px, 4.5vw, 46px); font-weight: 700; line-height: 1.15; letter-spacing: -0.8px; margin-bottom: 16px; }
.lp-accent { color: #6366F1; }
.lp-intro { font-size: 15px; color: #6E6E73; line-height: 1.7; margin-bottom: 32px; max-width: 560px; margin-left: auto; margin-right: auto; }
.lp-cta { display: inline-block; background: #6366F1; color: #fff; padding: 13px 28px; border-radius: 10px; font-size: 15px; font-weight: 500; text-decoration: none; transition: background 0.15s; }
.lp-cta:hover { background: #4F46E5; }
.lp-steps-section { padding: 64px 20px; max-width: 900px; margin: 0 auto; background: #F5F5F7; border-radius: 24px; text-align: center; }
.lp-steps-section h2 { font-size: 26px; font-weight: 700; margin-bottom: 40px; letter-spacing: -0.5px; }
.lp-steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; text-align: left; }
@media (max-width: 768px) { .lp-steps { grid-template-columns: 1fr; } }
.lp-step-num { font-size: 44px; font-weight: 800; color: #EEEFFD; letter-spacing: -2px; margin-bottom: 12px; }
.lp-step h3 { font-size: 15px; font-weight: 600; margin-bottom: 8px; }
.lp-step p { font-size: 13px; color: #6E6E73; line-height: 1.6; }
.lp-detail { max-width: 680px; margin: 64px auto; padding: 0 20px; }
.lp-detail h2 { font-size: 22px; font-weight: 700; margin-bottom: 16px; }
.lp-steps-list { padding-left: 20px; margin-top: 8px; }
.lp-steps-list li { font-size: 14px; color: #3D3D3F; line-height: 1.7; margin-bottom: 12px; }
.lp-steps-list strong { color: #1D1D1F; }
.lp-steps-list code { font-size: 12px; background: #F5F5F7; padding: 2px 6px; border-radius: 4px; }
.lp-detail-note { font-size: 12px; color: #A0A0A5; margin-top: 20px; line-height: 1.6; }
.lp-features { padding: 64px 20px; max-width: 900px; margin: 0 auto; }
.lp-features h2 { font-size: 26px; font-weight: 700; text-align: center; margin-bottom: 36px; letter-spacing: -0.5px; }
.lp-feature-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
@media (max-width: 600px) { .lp-feature-grid { grid-template-columns: 1fr; } }
.lp-feature-card { background: #fff; border: 0.5px solid #E5E5E7; border-radius: 14px; padding: 24px; }
.lp-feature-icon { font-size: 24px; margin-bottom: 12px; }
.lp-feature-card h3 { font-size: 15px; font-weight: 600; margin-bottom: 8px; }
.lp-feature-card p { font-size: 13px; color: #6E6E73; line-height: 1.6; }
.lp-cta-section { text-align: center; padding: 64px 20px 80px; }
.lp-cta-section h2 { font-size: 24px; font-weight: 700; margin-bottom: 8px; }
.lp-cta-section p { font-size: 14px; color: #6E6E73; margin-bottom: 24px; }
</style>
