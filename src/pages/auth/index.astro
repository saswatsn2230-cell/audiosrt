---
---
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign in to AudioSRT</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Inter', sans-serif; }
    body { background: #F5F5F7; min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 20px; }
    .card {
      background: #FFFFFF;
      border: 0.5px solid #E5E5E7;
      border-radius: 20px;
      padding: 40px;
      width: 100%;
      max-width: 400px;
      box-shadow: 0 4px 32px rgba(0,0,0,0.06);
    }
    .logo {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 32px;
      justify-content: center;
    }
    .logo-icon {
      width: 32px;
      height: 32px;
      background: #6366F1;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .logo-text { font-size: 16px; font-weight: 600; color: #1D1D1F; }
    h1 { font-size: 22px; font-weight: 600; color: #1D1D1F; text-align: center; margin-bottom: 6px; letter-spacing: -0.5px; }
    .subtitle { font-size: 13px; color: #6E6E73; text-align: center; margin-bottom: 28px; line-height: 1.5; }
    .trial-badge {
      background: #EEEFFD;
      border: 0.5px solid #C7C8F9;
      border-radius: 10px;
      padding: 12px 16px;
      margin-bottom: 24px;
      text-align: center;
    }
    .trial-badge strong { font-size: 13px; color: #6366F1; display: block; margin-bottom: 2px; }
    .trial-badge span { font-size: 11px; color: #6E6E73; }
    .google-btn {
      width: 100%;
      padding: 12px;
      border: 0.5px solid #E5E5E7;
      border-radius: 10px;
      background: #FFFFFF;
      color: #1D1D1F;
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      transition: border-color 0.15s, box-shadow 0.15s;
      margin-bottom: 20px;
    }
    .google-btn:hover { border-color: #6366F1; box-shadow: 0 0 0 3px rgba(99,102,241,0.08); }
    .divider { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; }
    .divider-line { flex: 1; height: 0.5px; background: #E5E5E7; }
    .divider-text { font-size: 11px; color: #A0A0A5; }
    .input-group { margin-bottom: 14px; }
    .input-label { font-size: 11px; font-weight: 500; color: #6E6E73; display: block; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.3px; }
    .input {
      width: 100%;
      padding: 10px 12px;
      border: 0.5px solid #E5E5E7;
      border-radius: 8px;
      font-size: 13px;
      color: #1D1D1F;
      background: #FFFFFF;
      font-family: 'Inter', sans-serif;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    .input:focus { outline: none; border-color: #6366F1; box-shadow: 0 0 0 3px rgba(99,102,241,0.08); }
    .submit-btn {
      width: 100%;
      padding: 11px;
      background: #6366F1;
      color: #FFFFFF;
      border: none;
      border-radius: 9px;
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      font-family: 'Inter', sans-serif;
      transition: background 0.15s;
      margin-top: 6px;
    }
    .submit-btn:hover { background: #4F46E5; }
    .submit-btn:disabled { background: #A5B4FC; cursor: not-allowed; }
    .toggle-text { text-align: center; font-size: 12px; color: #6E6E73; margin-top: 16px; }
    .toggle-link { color: #6366F1; cursor: pointer; font-weight: 500; }
    .toggle-link:hover { text-decoration: underline; }
    .error-msg { background: #FEF2F2; border: 0.5px solid #FECACA; border-radius: 8px; padding: 10px 12px; font-size: 12px; color: #EF4444; margin-bottom: 14px; display: none; }
    .success-msg { background: #F0FDF4; border: 0.5px solid #BBF7D0; border-radius: 8px; padding: 10px 12px; font-size: 12px; color: #16A34A; margin-bottom: 14px; display: none; }
    .back-link { display: block; text-align: center; font-size: 12px; color: #6E6E73; margin-top: 24px; text-decoration: none; }
    .back-link:hover { color: #6366F1; }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">
      <div class="logo-icon">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M2 12 Q6 4 10 12 Q14 20 18 12 Q22 4 22 12"/>
        </svg>
      </div>
      <span class="logo-text">AudioSRT</span>
    </div>

    <div class="trial-badge">
      <strong>⭐ 14-Day Free Trial Unlocked</strong>
      <span>No credit card required · Cancel anytime</span>
    </div>

    <h1 id="form-title">Create your account</h1>
    <p class="subtitle" id="form-subtitle">Sign up to unlock video uploads, custom fonts, and Premiere Pro export.</p>

    <button class="google-btn" id="googleBtn">
      <svg width="18" height="18" viewBox="0 0 24 24">
        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
        <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
      </svg>
      Continue with Google
    </button>

    <div class="divider">
      <div class="divider-line"></div>
      <span class="divider-text">or</span>
      <div class="divider-line"></div>
    </div>

    <div id="error-msg" class="error-msg"></div>
    <div id="success-msg" class="success-msg"></div>

    <div class="input-group">
      <label class="input-label">Email</label>
      <input type="email" id="email" class="input" placeholder="you@example.com" autocomplete="email">
    </div>

    <div class="input-group">
      <label class="input-label">Password</label>
      <input type="password" id="password" class="input" placeholder="Min. 8 characters" autocomplete="current-password">
    </div>

    <button class="submit-btn" id="submitBtn">Create account</button>

    <p class="toggle-text">
      <span id="toggle-text">Already have an account?</span>
      <span class="toggle-link" id="toggleMode"> Sign in</span>
    </p>

    <a href="/" class="back-link">← Back to home</a>
  </div>

  <script>
    import { supabase, signInWithGoogle, signInWithEmail, signUpWithEmail } from '../../lib/supabase.js'

    let isSignIn = false

    const googleBtn = document.getElementById('googleBtn')
    const submitBtn = document.getElementById('submitBtn')
    const emailInput = document.getElementById('email')
    const passwordInput = document.getElementById('password')
    const errorMsg = document.getElementById('error-msg')
    const successMsg = document.getElementById('success-msg')
    const formTitle = document.getElementById('form-title')
    const formSubtitle = document.getElementById('form-subtitle')
    const toggleMode = document.getElementById('toggleMode')
    const toggleText = document.getElementById('toggle-text')

    function showError(msg) {
      errorMsg.textContent = msg
      errorMsg.style.display = 'block'
      successMsg.style.display = 'none'
    }

    function showSuccess(msg) {
      successMsg.textContent = msg
      successMsg.style.display = 'block'
      errorMsg.style.display = 'none'
    }

    function toggleFormMode() {
      isSignIn = !isSignIn
      if (isSignIn) {
        formTitle.textContent = 'Welcome back'
        formSubtitle.textContent = 'Sign in to access your AudioSRT workspace.'
        submitBtn.textContent = 'Sign in'
        toggleText.textContent = "Don't have an account?"
        toggleMode.textContent = ' Sign up'
      } else {
        formTitle.textContent = 'Create your account'
        formSubtitle.textContent = 'Sign up to unlock video uploads, custom fonts, and Premiere Pro export.'
        submitBtn.textContent = 'Create account'
        toggleText.textContent = 'Already have an account?'
        toggleMode.textContent = ' Sign in'
      }
      errorMsg.style.display = 'none'
      successMsg.style.display = 'none'
    }

    toggleMode.addEventListener('click', toggleFormMode)

    googleBtn.addEventListener('click', async () => {
      try {
        googleBtn.disabled = true
        const span = googleBtn.querySelector('span')
        if (span) span.textContent = 'Redirecting...'
        else googleBtn.textContent = 'Redirecting to Google...'

        const isTauri = typeof window.__TAURI_INTERNALS__ !== 'undefined'
        const redirectTo = isTauri
          ? 'audiosrt://auth/callback'
          : `${window.location.origin}/auth/callback`

        const { data, error } = await supabase.auth.signInWithOAuth({
          provider: 'google',
          options: {
            redirectTo,
            skipBrowserRedirect: isTauri,
            queryParams: {
              access_type: 'offline',
              prompt: 'select_account'
            }
          }
        })

        if (error) throw error

        if (isTauri && data?.url) {
          await window.__TAURI_INTERNALS__.invoke('open_in_browser', { url: data.url })
          googleBtn.disabled = false
          googleBtn.textContent = 'Sign in opened in your browser — come back here after!'
          return
        }
      } catch (err) {
        console.error('[Auth] Google OAuth error:', err.message)
        const errorEl = document.getElementById('error-msg')
        if (errorEl) {
          errorEl.textContent = err.message.includes('already registered')
            ? 'This email is already registered. Please sign in with your password instead, or use the same method you used to sign up.'
            : `Sign in failed: ${err.message}`
          errorEl.style.display = 'block'
        }
        googleBtn.disabled = false
        googleBtn.textContent = 'Continue with Google'
      }
    })

    submitBtn.addEventListener('click', async () => {
      const email = emailInput.value.trim()
      const password = passwordInput.value

      if (!email || !password) {
        showError('Please enter your email and password.')
        return
      }
      if (password.length < 8) {
        showError('Password must be at least 8 characters.')
        return
      }

      submitBtn.disabled = true
      submitBtn.textContent = isSignIn ? 'Signing in...' : 'Creating account...'

      try {
        if (isSignIn) {
          await signInWithEmail(email, password)
          window.location.href = '/tool'
        } else {
          const { data } = await signUpWithEmail(email, password)
          if (data?.session) {
            // Email confirmation disabled — session created immediately
            window.location.href = '/tool'
          } else {
            // Email confirmation required — prompt user to check inbox
            showSuccess('Account created! Check your email to confirm, then sign in.')
            submitBtn.textContent = 'Create account'
            submitBtn.disabled = false
          }
        }
      } catch (err) {
        showError(err.message || 'Something went wrong. Please try again.')
        submitBtn.disabled = false
        submitBtn.textContent = isSignIn ? 'Sign in' : 'Create account'
      }
    })

    // Check if user is already signed in
    supabase.auth.getSession().then(({ data: { session } }) => {
      if (session) {
        window.location.href = '/tool'
      }
    })

  </script>
</body>
</html>
