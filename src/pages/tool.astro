      const subtitleFilter = `subtitles=subtitles.srt:force_style='FontName=${fontFamily},FontSize=${fontSize},PrimaryColour=&HFFFFFF,OutlineColour=&H000000,Outline=2,Alignment=2'`;
      const needsScale = quality !== '1080p';
      const vfFilter   = needsScale ? `scale=${scaleMap[quality]},${subtitleFilter}` : subtitleFilter;

      await ffmpeg.exec([
        '-i', `input.${fileExt}`,
        '-vf', vfFilter,
        '-c:v', 'libx264',
        '-preset', 'ultrafast',
        '-crf', crfMap[bitrate],
        '-tune', 'zerolatency',
        '-c:a', 'copy',
        '-movflags', '+faststart',
        'output.mp4',
