      await ffmpeg.writeFile(`input.${fileExt}`, await fetchFile(selectedFile));
      await ffmpeg.writeFile('subtitles.srt', new TextEncoder().encode(generateSRTContent()));
      if (exportCancelled) return;

      progressEl.textContent = 'Burning subtitles…';
