          <svg id="mini-icon-pause" width="9" height="9" viewBox="0 0 10 10" fill="white" class="hidden" aria-hidden="true"><rect x="1.5" y="1" width="2.5" height="8"/><rect x="6" y="1" width="2.5" height="8"/></svg>
        </button>
        <input id="mini-seek" type="range" min="0" max="100" value="0" step="0.01" aria-label="Seek" />
        <span id="mini-time">0:00 / 0:00</span>
      </div>

      <!-- Subtitle settings panel (real controls — lock overlay temporarily commented out) -->
      <div class="locked-panel">

        <!-- Real subtitle controls — hidden by default, shown for starter/pro -->
        <div id="step-settings" class="settings-panel-visible real-subtitle-settings">
          <div class="settings-bar">
            <div class="cg"><span class="cg-lbl">Lines</span><div class="cg-row">
              <button id="single-line-btn" type="button" class="tgl bg-apple-blue text-white border-apple-blue" style="width:28px;">1</button>
              <button id="double-line-btn" type="button" class="tgl bg-white text-apple-dark border-apple-light-gray" style="width:28px;">2</button>
            </div></div>
            <div class="cg-sep"></div>
            <div class="cg"><span class="cg-lbl">Chars</span><div class="cg-row">
              <input type="number" id="chars-val" min="20" max="80" value="42" class="chars-input" />
              <input id="chars-slider" type="range" min="20" max="80" value="42" class="range-ctrl" style="width:75px;" /></div></div>
            <div class="cg-sep"></div>
            <div class="cg"><span class="cg-lbl">Font</span>
              <select id="font-select" class="sel-ctrl">
                <option value="Inter">Inter</option><option value="Arial">Arial</option>
                <option value="Helvetica">Helvetica</option><option value="Georgia">Georgia</option>
                <option value="Times New Roman">Times New Roman</option>
                <option value="Courier New">Courier New</option>
                <option value="Impact">Impact</option><option value="Verdana">Verdana</option>
                <option value="custom">+ Upload font...</option>
