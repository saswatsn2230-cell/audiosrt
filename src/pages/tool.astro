  async function checkAndRestoreSession() {
    try {
      // Only restore when returning from auth — not on every fresh visit
      const returningFromAuth = sessionStorage.getItem('audiosrt_returning_from_auth');
      if (!returningFromAuth) return false;
      sessionStorage.removeItem('audiosrt_returning_from_auth');

      const [savedState, savedFile] = await Promise.all([
        AudioSRTDB.getState(),
        AudioSRTDB.getFile()
      ]);

      if (!savedState || !savedState.segments || !savedState.segments.length) return false;

      const ageHours = (Date.now() - new Date(savedState.createdAt).getTime()) / (1000 * 60 * 60);
      if (ageHours > 24) { await AudioSRTDB.clearAll(); return false; }

      // Restore segments
      const segs = savedState.segments;
      logicalSegments  = segs.map(s => ({ ...s }));
      displaySegments  = logicalSegments.map(s => ({ ...s }));
      displayToLogical = logicalSegments.map((_, i) => i);
      window._audiosrt.setSegments(segs);

      // Show editor — unhide tool-cols and all panels that normal transcription reveals
      const tc = document.getElementById('tool-cols');
      if (tc) tc.classList.remove('hidden');
      transcriptArea.classList.remove('hidden');
      stepSettings.classList.remove('hidden');
      stepExport.classList.remove('hidden');
      stepTimeline.classList.remove('hidden');

      // Activate Edit step pill (rAF so it runs after MutationObserver callbacks settle)
      requestAnimationFrame(() => {
        document.querySelectorAll('.step-pill').forEach(p => {
          p.classList.remove('active');
          p.style.background = '';
          p.style.color = '';
          p.style.borderRadius = '';
        });
        document.querySelectorAll('.step-pill').forEach(p => {
          if (p.textContent.trim().toLowerCase() === 'edit') {
            p.classList.add('active');
            p.style.background = '#6366F1';
            p.style.color = '#ffffff';
            p.style.borderRadius = '20px';
            p.style.padding = '2px 10px';
          }
        });
      });

      // Restore audio/video file
      let fileRestored = false;
      if (savedFile && savedFile.data) {
        updatePreviewControlsVisibility(savedFile.data);
        updateExportOptions();
        const blobUrl = URL.createObjectURL(savedFile.data);
        const isVid = savedFile.type && savedFile.type.startsWith('video/');
        isVideo = isVid;
        audioPlayer.src = blobUrl;  // triggers loadstart → buildWaveform automatically
        audioPlayer.load();
        audioPlayerWrap.classList.remove('hidden');
        if (isVid) {
          videoPreviewEl.src = blobUrl;
          videoPreviewEl.classList.remove('hidden');
          previewBox.style.background = '';
        }
        fileRestored = true;
      }

      // Show banner
      const filename = (savedFile && savedFile.name) || savedState.filename || 'your file';
      const banner = document.createElement('div');
      banner.style.cssText = 'position:fixed;top:52px;left:50%;transform:translateX(-50%);background:#EEEFFD;color:#6366F1;border:0.5px solid #C7C8F9;padding:8px 20px;border-radius:8px;font-size:12px;font-family:Inter,sans-serif;font-weight:500;z-index:9999;display:flex;align-items:center;gap:10px;box-shadow:0 2px 12px rgba(99,102,241,0.15);max-width:90vw;';
      if (fileRestored) {
        banner.innerHTML = '✓ Transcript &amp; audio restored — <em style="font-style:normal;opacity:0.7;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:200px;">' + filename + '</em><button onclick="this.parentElement.remove()" style="background:none;border:none;color:#6366F1;cursor:pointer;font-size:16px;padding:0;margin-left:4px;line-height:1;flex-shrink:0;">×</button>';
      } else {
        banner.innerHTML = '✓ Transcript restored — <em style="font-style:normal;opacity:0.7;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:200px;">' + filename + '</em><button onclick="this.parentElement.remove()" style="background:none;border:none;color:#6366F1;cursor:pointer;font-size:16px;padding:0;margin-left:4px;line-height:1;flex-shrink:0;">×</button>';
      }
      document.body.appendChild(banner);
      setTimeout(() => banner.remove(), 6000);

      if (savedState.id) {
        AudioSRTDB.getProject(savedState.id).then(p => { if (p) showExpiryCountdown(p); });
      }

      return true;
    } catch(e) { return false; }
  }

  let worker      = null;
  let rafId       = null;
  let monoRef     = null;
  let totalChunks = 1;
  let chunksDone  = 0;
  let chunkQueue  = []; // [{ audioSlice: Float32Array, timeOffset: number }]

  let isVideo        = false;
  let mediaObjectUrl = null;

  let trimInSec  = 0;
  let trimOutSec = Infinity;
  let tlRegionStart = null;
  let tlRegionEnd   = null;

  let subtitleSettings = {
    lines: 1, maxChars: Infinity, font: 'Inter', fontSize: 20,
    color: '#FFFFFF', bold: false, shadow: false, stroke: false, vpos: 85,
  };

  // ── Helpers ───────────────────────────────────────────────────────────────
  function formatBytes(b) {
    if (b < 1024)    return b + ' B';
    if (b < 1048576) return (b / 1024).toFixed(1) + ' KB';
    return (b / 1048576).toFixed(1) + ' MB';
  }

  function formatTimestamp(sec) {
    if (!isFinite(sec) || sec < 0) sec = 0;
    const h  = Math.floor(sec / 3600);
    const m  = Math.floor((sec % 3600) / 60);
    const s  = Math.floor(sec % 60);
    const ms = Math.min(999, Math.round((sec % 1) * 1000));
    const p2 = n => String(n).padStart(2, '0');
    const p3 = n => String(n).padStart(3, '0');
    return `${p2(h)}:${p2(m)}:${p2(s)},${p3(ms)}`;
  }

  function parseTimeInput(str) {
    const s = str.trim().replace(',', '.');
    const parts = s.split(':');
    if (parts.some(p => isNaN(parseFloat(p)))) return NaN;
    if (parts.length === 3) return parseFloat(parts[0]) * 3600 + parseFloat(parts[1]) * 60 + parseFloat(parts[2]);
    if (parts.length === 2) return parseFloat(parts[0]) * 60 + parseFloat(parts[1]);
    return NaN;
  }

  function formatShort(sec) {
    if (!isFinite(sec)) return '0:00';
    return `${Math.floor(sec / 60)}:${String(Math.floor(sec % 60)).padStart(2, '0')}`;
  }

  // ── Core splitting ────────────────────────────────────────────────────────
  function splitSegment(seg, maxChars, lines) {
    const words = seg.text.split(/\s+/).filter(Boolean);
    if (!words.length) return [];
    // No char limit — return as single segment, no splitting
    if (!maxChars || maxChars === Infinity || maxChars >= 999) {
      return [{ start: seg.start, end: seg.end || seg.start + 1, text: seg.text }];
    }

    const pages = [];
    let currentPage = [];
    let currentLine = '';

    for (const word of words) {
      const candidate = currentLine ? currentLine + ' ' + word : word;
      if (candidate.length <= maxChars) {
        currentLine = candidate;
      } else {
        if (currentLine) currentPage.push(currentLine);
        if (currentPage.length >= lines) { pages.push(currentPage); currentPage = []; }
        currentLine = word.length > maxChars ? word.slice(0, maxChars) : word;
      }
    }
    if (currentLine) currentPage.push(currentLine);
    if (currentPage.length) pages.push(currentPage);
    if (!pages.length) return [];

    const totalWords = words.length;
    const totalDur   = Math.max(0, (seg.end || seg.start + 1) - seg.start);
    const secPerWord = totalDur / Math.max(1, totalWords);
    const result     = [];
    let cursor = seg.start;

    for (let i = 0; i < pages.length; i++) {
      const pageText  = pages[i].join('\n');
      const pageWords = pageText.split(/\s+/).filter(Boolean).length;
      const isLast    = i === pages.length - 1;
      const segEnd    = isLast ? (seg.end || seg.start + 1) : cursor + pageWords * secPerWord;
      result.push({ start: cursor, end: segEnd, text: pageText });
      cursor = segEnd;
    }
    return result;
  }

  function appendChunkToLogical(newRawSegs) {
    for (const seg of newRawSegs) {
      if (!seg.text.trim()) continue;
      logicalSegments.push({ ...seg });
    }
  }

  function rebuildDisplaySegments() {
    const { maxChars, lines } = subtitleSettings;
    displaySegments  = [];
    displayToLogical = [];
    for (let li = 0; li < logicalSegments.length; li++) {
      const seg = logicalSegments[li];
      if (!seg.text.trim()) continue;
      for (const part of splitSegment(seg, maxChars, lines)) {
        displaySegments.push(part);
        displayToLogical.push(li);
      }
    }
  }

  // ── Split / Move logic ────────────────────────────────────────────────────
  function flattenToLogical() {
    logicalSegments  = displaySegments.map(s => ({ ...s }));
    displayToLogical = displaySegments.map((_, idx) => idx);
  }

  function splitDisplayAt(rowIdx, cursorOffset) {
    flattenToLogical();
    const seg        = logicalSegments[rowIdx];
    const textBefore = seg.text.slice(0, cursorOffset).trim();
    const textAfter  = seg.text.slice(cursorOffset).trim();
    if (!textBefore || !textAfter) return;

    const wBefore = textBefore.split(/\s+/).filter(Boolean).length;
    const wTotal  = wBefore + textAfter.split(/\s+/).filter(Boolean).length;
    const dur     = Math.max(0, seg.end - seg.start);
    const splitT  = seg.start + (wBefore / Math.max(1, wTotal)) * dur;

    logicalSegments.splice(rowIdx, 1,
      { start: seg.start, end: splitT,  text: textBefore },
      { start: splitT,    end: seg.end, text: textAfter  }
    );
    rebuildDisplaySegments();
    renderTranscript();
    refreshPreviewText(audioPlayer.currentTime);
    transcriptLines.children[rowIdx + 1]?.querySelector('[contenteditable]')?.focus();
  }

  function moveWordUp(rowIdx, wordIdx) {
    if (rowIdx < 1) return;
    flattenToLogical();
    const from      = logicalSegments[rowIdx];
    const to        = logicalSegments[rowIdx - 1];
    const fromWords = from.text.trim().split(/\s+/).filter(Boolean);
    const toWords   = to.text.trim().split(/\s+/).filter(Boolean);
    if (!fromWords.length) return;
    const [word] = fromWords.splice(wordIdx, 1);
    toWords.push(word);
    const totalDur  = Math.max(0, from.end - to.start);
    const boundary  = to.start + (toWords.length / (toWords.length + fromWords.length)) * totalDur;
    logicalSegments[rowIdx - 1] = { start: to.start,  end: boundary, text: toWords.join(' ')   };
    logicalSegments[rowIdx]     = { start: boundary,  end: from.end, text: fromWords.join(' ')  };
    if (!fromWords.length) logicalSegments.splice(rowIdx, 1);
    rebuildDisplaySegments();
    renderTranscript();
    refreshPreviewText(audioPlayer.currentTime);
  }

  function moveWordDown(rowIdx, wordIdx) {
    if (rowIdx >= displaySegments.length - 1) return;
    flattenToLogical();
    const from      = logicalSegments[rowIdx];
    const to        = logicalSegments[rowIdx + 1];
    const fromWords = from.text.trim().split(/\s+/).filter(Boolean);
    const toWords   = to.text.trim().split(/\s+/).filter(Boolean);
    if (!fromWords.length) return;
    const [word] = fromWords.splice(wordIdx, 1);
    toWords.unshift(word);
    const totalDur  = Math.max(0, to.end - from.start);
    const boundary  = from.start + (fromWords.length / (fromWords.length + toWords.length)) * totalDur;
    logicalSegments[rowIdx]     = { start: from.start, end: boundary, text: fromWords.join(' ') };
    logicalSegments[rowIdx + 1] = { start: boundary,   end: to.end,   text: toWords.join(' ')   };
    if (!fromWords.length) logicalSegments.splice(rowIdx, 1);
    rebuildDisplaySegments();
    renderTranscript();
    refreshPreviewText(audioPlayer.currentTime);
  }

  // ── Multi-word selection move ─────────────────────────────────────────────
  let multiWordPopup = null;

  function removeMultiWordPopup() {
    if (multiWordPopup) { multiWordPopup.remove(); multiWordPopup = null; }
  }

  function moveWordsUp(rowIdx, selectedText) {
    if (rowIdx < 1) return;
    flattenToLogical();
    const from = logicalSegments[rowIdx];
    const to   = logicalSegments[rowIdx - 1];
    const selWords   = selectedText.trim().split(/\s+/).filter(Boolean);
    const fromWords  = from.text.trim().split(/\s+/).filter(Boolean);
    // Remove selected words from source (first occurrence of contiguous sequence)
    const selStr = selWords.join(' ');
    const newFromText = from.text.replace(selStr, '').replace(/\s+/g, ' ').trim();
    const newToText   = to.text.trim() + (to.text.trim() ? ' ' : '') + selStr;
    const totalDur = Math.max(0, from.end - to.start);
    const toWordCount  = newToText.split(/\s+/).filter(Boolean).length;
    const allWordCount = toWordCount + (newFromText.split(/\s+/).filter(Boolean).length);
    const boundary = to.start + (toWordCount / Math.max(1, allWordCount)) * totalDur;
    logicalSegments[rowIdx - 1] = { start: to.start,  end: boundary,  text: newToText };
    logicalSegments[rowIdx]     = { start: boundary,   end: from.end,  text: newFromText };
    if (!newFromText) logicalSegments.splice(rowIdx, 1);
    rebuildDisplaySegments();
    renderTranscript();
    refreshPreviewText(audioPlayer.currentTime);
  }

  function moveWordsDown(rowIdx, selectedText) {
    if (rowIdx >= logicalSegments.length - 1) return;
    flattenToLogical();
    const from = logicalSegments[rowIdx];
    const to   = logicalSegments[rowIdx + 1];
    const selStr     = selectedText.trim().split(/\s+/).filter(Boolean).join(' ');
    const newFromText = from.text.replace(selStr, '').replace(/\s+/g, ' ').trim();
    const newToText   = selStr + (to.text.trim() ? ' ' : '') + to.text.trim();
    const totalDur = Math.max(0, to.end - from.start);
    const fromWordCount = newFromText.split(/\s+/).filter(Boolean).length;
    const allWordCount  = fromWordCount + newToText.split(/\s+/).filter(Boolean).length;
    const boundary = from.start + (fromWordCount / Math.max(1, allWordCount)) * totalDur;
    logicalSegments[rowIdx]     = { start: from.start, end: boundary, text: newFromText };
    logicalSegments[rowIdx + 1] = { start: boundary,   end: to.end,   text: newToText  };
    if (!newFromText) logicalSegments.splice(rowIdx, 1);
    rebuildDisplaySegments();
    renderTranscript();
    refreshPreviewText(audioPlayer.currentTime);
  }

  function showMultiWordMovePopup(rowEl, rowIdx, selectedText) {
    removeMultiWordPopup();
    const canUp   = rowIdx > 0;
    const canDown = rowIdx < displaySegments.length - 1;
    if (!canUp && !canDown) return;

    const popup = document.createElement('div');
    popup.style.cssText = 'position:fixed;z-index:9999;background:#fff;border-radius:6px;box-shadow:0 2px 8px rgba(0,0,0,0.14);overflow:hidden;display:flex;align-items:center;pointer-events:auto;';
    const btnStyle = 'background:none;border:none;padding:5px 10px;font-size:11px;font-weight:500;cursor:pointer;color:#1D1D1F;font-family:Inter,sans-serif;white-space:nowrap;display:flex;align-items:center;gap:3px;';
    if (canUp)   popup.innerHTML += `<button class="mw-up" style="${btnStyle}">↑ Move up</button>`;
    if (canUp && canDown) popup.innerHTML += '<div style="width:0.5px;height:20px;background:#E5E5E7;flex-shrink:0;"></div>';
    if (canDown) popup.innerHTML += `<button class="mw-dn" style="${btnStyle}">↓ Move down</button>`;

    const rect = rowEl.getBoundingClientRect();
    popup.style.top  = (rect.top - 34) + 'px';
    popup.style.left = (rect.left + rect.width / 2 - 60) + 'px';

    popup.querySelector('.mw-up')?.addEventListener('click', () => { removeMultiWordPopup(); moveWordsUp(rowIdx, selectedText); });
    popup.querySelector('.mw-dn')?.addEventListener('click', () => { removeMultiWordPopup(); moveWordsDown(rowIdx, selectedText); });

    document.body.appendChild(popup);
    multiWordPopup = popup;
  }

  document.addEventListener('mouseup', (e) => {
    if (e.target?.closest && e.target.closest('[id="subtitle-row-lock"]')) return;
    const selection   = window.getSelection();
    const selectedText = selection?.toString().trim() ?? '';
    if (!selectedText || selectedText.split(/\s+/).length < 2) { removeMultiWordPopup(); return; }
    const rowEl = selection.anchorNode?.parentElement?.closest('[data-display-idx]');
    if (!rowEl) { removeMultiWordPopup(); return; }
    const rowIdx = parseInt(rowEl.dataset.displayIdx);
    if (isNaN(rowIdx)) return;
    showMultiWordMovePopup(rowEl, rowIdx, selectedText);
  });

  document.addEventListener('mousedown', (e) => {
    if (!multiWordPopup?.contains(e.target)) removeMultiWordPopup();
  });

  // ── Floating pill ─────────────────────────────────────────────────────────
  const pill = document.createElement('div');
  pill.style.cssText = [
    'position:fixed', 'z-index:9999', 'display:none', 'opacity:0',
    'background:#fff', 'border-radius:6px',
    'box-shadow:0 2px 8px rgba(0,0,0,0.12)',
    'transition:opacity 150ms ease',
    'overflow:hidden', 'pointer-events:auto',
    'align-items:center',
  ].join(';');
  document.body.appendChild(pill);

  function showPill(anchorRect) {
    pill.style.display = 'flex';
    requestAnimationFrame(() => {
      const pw = pill.offsetWidth;
      const ph = pill.offsetHeight;
      let left = anchorRect.left + anchorRect.width / 2 - pw / 2;
      let top  = anchorRect.top - ph - 6;
      left = Math.max(4, Math.min(left, window.innerWidth - pw - 4));
      top  = Math.max(4, top);
      pill.style.left = left + 'px';
      pill.style.top  = top  + 'px';
      pill.style.opacity = '1';
    });
  }

  function hidePill() {
    pill.style.opacity = '0';
    setTimeout(() => { if (pill.style.opacity === '0') pill.style.display = 'none'; }, 160);
  }

  document.addEventListener('click', (e) => { if (!pill.contains(e.target)) hidePill(); });
  transcriptLines.addEventListener('scroll', hidePill);

  function pillBtn(label, title, onClick) {
    const b = document.createElement('button');
    b.type  = 'button';
    b.title = title;
    b.style.cssText = 'display:flex;align-items:center;justify-content:center;width:28px;height:26px;border:none;background:none;cursor:pointer;padding:0;color:#6366F1;font-size:15px;line-height:1;';
    b.innerHTML = label;
    b.addEventListener('mousedown', e => e.preventDefault());
    b.addEventListener('click', (e) => { e.stopPropagation(); onClick(); });
    return b;
  }

  // FIX 4 — single click detects word position, shows scissors + arrows
  function handleTextMouseUp(textEl, rowIdx) {
    const sel = window.getSelection();
    if (!sel || !sel.rangeCount) { hidePill(); return; }
    const range = sel.getRangeAt(0);

    // Compute cursor offset in text
    const preRange = range.cloneRange();
    preRange.selectNodeContents(textEl);
    preRange.setEnd(range.startContainer, range.startOffset);
    const cursorOffset = preRange.toString().length;
    const fullText     = textEl.textContent || '';
    const wordMatches  = [...fullText.matchAll(/\S+/g)];
    if (!wordMatches.length) { hidePill(); return; }

    // Find which word the cursor is on
    let wordIdx = -1;
    for (let wi = 0; wi < wordMatches.length; wi++) {
      const m = wordMatches[wi];
      if (cursorOffset >= m.index && cursorOffset <= m.index + m[0].length) {
        wordIdx = wi;
        break;
      }
    }
    // If cursor is between words, pick the nearest word
    if (wordIdx === -1) {
      let best = 0, bestDist = Infinity;
      for (let wi = 0; wi < wordMatches.length; wi++) {
        const m = wordMatches[wi];
        const mid = m.index + m[0].length / 2;
        const d = Math.abs(cursorOffset - mid);
        if (d < bestDist) { bestDist = d; best = wi; }
      }
      wordIdx = best;
    }

    const capturedRow    = rowIdx;
    const capturedOffset = cursorOffset;
    const lastWordIdx    = wordMatches.length - 1;
    const isFirst        = wordIdx === 0;
    const isLast         = wordIdx === lastWordIdx;
    const isMiddle       = !isFirst && !isLast;
    const canUp          = rowIdx > 0;
    const canDown        = rowIdx < displaySegments.length - 1;
    const before         = fullText.slice(0, cursorOffset).trim();
    const after          = fullText.slice(cursorOffset).trim();
    const canSplit       = !!(before && after);

    if (!canSplit && !canUp && !canDown) { hidePill(); return; }

    const scissorsSVG = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/>
      <line x1="20" y1="4" x2="8.12" y2="15.88"/>
      <line x1="14.47" y1="14.48" x2="20" y2="20"/>
      <line x1="8.12" y1="8.12" x2="12" y2="12"/>
    </svg>`;

    pill.innerHTML = '';
    // Scissors: always show if valid split
    if (canSplit) {
      pill.appendChild(pillBtn(scissorsSVG, 'Split line here', () => { hidePill(); splitDisplayAt(capturedRow, capturedOffset); }));
    }
    // ↑ if cursor is on first word and row above exists
    if (isFirst && canUp) {
      pill.appendChild(pillBtn('↑', 'Move word to line above', () => { hidePill(); moveWordUp(capturedRow, 0); }));
    }
    // ↓ if cursor is on last word and row below exists
    if (isLast && canDown) {
      pill.appendChild(pillBtn('↓', 'Move word to line below', () => { hidePill(); moveWordDown(capturedRow, lastWordIdx); }));
    }

    if (!pill.children.length) { hidePill(); return; }

    let anchorRect = range.getBoundingClientRect();
    if (!anchorRect.width && !anchorRect.height) anchorRect = textEl.getBoundingClientRect();
    showPill(anchorRect);
  }

  // ── Transcript UI ─────────────────────────────────────────────────────────

  // Builds and returns a single transcript row DOM node for displaySegments[i].
  // Extracted so both full-render and progressive-append can share the same logic.
  function buildTranscriptRow(seg, i) {
    const row = document.createElement('div');
    row.className = 'flex gap-2 items-start';
    row.dataset.displayIdx = String(i);
    row.style.cursor = 'pointer';

    const tsInput = document.createElement('input');
    tsInput.type      = 'text';
    tsInput.value     = formatTimestamp(seg.start);
    tsInput.className = 'w-32 shrink-0 px-2 py-1.5 rounded-lg border border-transparent hover:border-apple-light-gray bg-apple-bg focus:outline-none focus:border-apple-blue text-xs text-apple-gray font-mono cursor-text text-center';
    tsInput.title     = 'Click to seek audio; edit to change start time (HH:MM:SS,mmm)';

    const textEl = document.createElement('div');
    textEl.className       = 'flex-1 px-3 py-1.5 rounded-lg border border-transparent hover:border-apple-light-gray bg-apple-bg focus:outline-none focus:border-apple-blue text-sm text-apple-dark cursor-text whitespace-pre-wrap';
    textEl.contentEditable = 'true';
    textEl.textContent     = seg.text;

    row.addEventListener('click', (e) => {
      if (e.target === tsInput || e.target === textEl) return;
      if (isFinite(audioPlayer.duration)) audioPlayer.currentTime = Math.max(0, seg.start);
      refreshPreviewText(seg.start);
    });
    tsInput.addEventListener('focus', () => {
      if (isFinite(audioPlayer.duration)) audioPlayer.currentTime = Math.max(0, seg.start);
      refreshPreviewText(seg.start);
    });
    tsInput.addEventListener('change', () => {
      const parsed = parseTimeInput(tsInput.value);
      if (!isNaN(parsed)) {
        displaySegments[i].start = parsed;
        logicalSegments[displayToLogical[i]].start = parsed;
        if (i > 0) {
          displaySegments[i - 1].end = parsed;
          logicalSegments[displayToLogical[i - 1]].end = parsed;
        }
        tsInput.value = formatTimestamp(parsed);
      } else {
        tsInput.value = formatTimestamp(displaySegments[i].start);
      }
      refreshPreviewText(audioPlayer.currentTime);
    });
    textEl.addEventListener('mouseup',  () => handleTextMouseUp(textEl, i));
    textEl.addEventListener('keydown',  ()  => hidePill());
    textEl.addEventListener('input', () => {
      displaySegments[i].text = textEl.textContent;
      const li = displayToLogical[i];
      logicalSegments[li].text = displaySegments
        .filter((_, idx) => displayToLogical[idx] === li)
        .map(d => d.text.trim())
        .join(' ');
      refreshPreviewText(audioPlayer.currentTime);
    });

    row.appendChild(tsInput);
    row.appendChild(textEl);
    return row;
  }

  // Full render — clears the list and redraws every row from scratch.
  // Used when the user edits settings, splits/merges, or loads a saved project.
  function renderTranscript() {
    autoSave();
    transcriptLines.innerHTML = '';
    displaySegments.forEach((seg, i) => {
      transcriptLines.appendChild(buildTranscriptRow(seg, i));
    });
    applySubtitleRowLock(window._audiosrt.currentPlan || 'free');
  }

  // Progressive append — adds only rows from fromDisplayIdx onward.
  // Never clears existing DOM, never moves scroll, never disturbs the active cursor.
  // Called after each transcription chunk completes during live transcription.
  function renderTranscriptAppend(fromDisplayIdx) {
    const activeEl           = document.activeElement;
    const cursorWasInList    = transcriptLines.contains(activeEl);
    let   savedRange         = null;
    if (cursorWasInList && window.getSelection) {
      const sel = window.getSelection();
      if (sel && sel.rangeCount > 0) savedRange = sel.getRangeAt(0).cloneRange();
    }

    for (let i = fromDisplayIdx; i < displaySegments.length; i++) {
      transcriptLines.appendChild(buildTranscriptRow(displaySegments[i], i));
    }

    // Restore selection so the user's cursor position is exactly unchanged
    if (cursorWasInList && savedRange && activeEl && activeEl.isConnected) {
      try {
        const sel = window.getSelection();
        sel.removeAllRanges();
        sel.addRange(savedRange);
        activeEl.focus({ preventScroll: true });
      } catch (_) {}
    }

    applySubtitleRowLock(window._audiosrt.currentPlan || 'free');
  }

  function updatePreviewControlsVisibility(file) {
    const vid = file && file.type && file.type.startsWith('video/');
    document.querySelectorAll('.video-only-control').forEach(el => { el.style.display = vid ? 'flex' : 'none'; });
    const bgCtrl = document.querySelector('.bg-control');
    if (bgCtrl) bgCtrl.style.display = vid ? 'none' : 'flex';
  }

  const FREE_ROW_LIMIT = 20;

  function applySubtitleRowLock(plan) {
    const rows = Array.from(transcriptLines.querySelectorAll(':scope > .flex'));
    const existingLock = document.getElementById('subtitle-row-lock');
    if (existingLock) existingLock.remove();

    if (plan === 'starter' || plan === 'pro') {
      rows.forEach(r => { r.style.opacity = ''; r.style.pointerEvents = ''; r.style.userSelect = ''; });
      return;
    }

    if (rows.length <= FREE_ROW_LIMIT) return;

    rows.forEach((r, i) => {
      if (i >= FREE_ROW_LIMIT) {
        r.style.opacity = '0.3';
        r.style.pointerEvents = 'none';
        r.style.userSelect = 'none';
      } else {
        r.style.opacity = '';
        r.style.pointerEvents = '';
        r.style.userSelect = '';
      }
    });

    const lockDiv = document.createElement('div');
    lockDiv.id = 'subtitle-row-lock';
    lockDiv.style.cssText = 'position:sticky;bottom:0;left:0;right:0;height:180px;background:rgba(255,255,255,0.55);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;padding:20px;border-top:0.5px solid rgba(99,102,241,0.15);z-index:10;margin-top:-60px;';
    lockDiv.innerHTML = '<div style="font-size:20px;">🔒</div>'
      + '<div style="font-size:13px;font-weight:600;color:#1D1D1F;text-align:center;">You\'ve previewed 20 subtitle lines</div>'
      + '<div style="font-size:11px;color:#6E6E73;text-align:center;max-width:260px;line-height:1.5;">Unlock all ' + rows.length + ' lines with full timestamp editing, split controls, and more.</div>'
      + '<a href="/auth" class="subtitle-lock-trial-btn" style="background:#6366F1;color:#fff;font-size:12px;font-weight:500;padding:8px 20px;border-radius:8px;font-family:Inter,sans-serif;margin-top:4px;border:none;cursor:pointer;text-decoration:none;display:inline-block;">Start 14-day free trial →</a>'
      + '<div style="font-size:10px;color:#A0A0A5;">No credit card required · Cancel anytime</div>';
    transcriptLines.appendChild(lockDiv);
  }

  window._audiosrt.applySubtitleRowLock = (plan) => applySubtitleRowLock(plan);

  function onSettingsChange() {
    if (!logicalSegments.length) {
      if (!rawSegments.length) return;
      appendChunkToLogical(rawSegments);
    }
    rebuildDisplaySegments();
    renderTranscript();
    refreshPreviewText(audioPlayer.currentTime);
  }

  // ── Preview ───────────────────────────────────────────────────────────────
  function applyPreviewStyles() {
    previewSub.style.fontFamily       = subtitleSettings.font;
    previewSub.style.fontSize         = subtitleSettings.fontSize + 'px';
    previewSub.style.color            = subtitleSettings.color;
    previewSub.style.fontWeight       = subtitleSettings.bold ? 'bold' : 'normal';
    // shadow/stroke now managed by FIX 5e/5f sub-panels — don't overwrite here
    previewSub.style.top       = 'auto';
    previewSub.style.bottom    = 'auto';
    previewSub.style.transform = 'none';
    const vpos = subtitleSettings.vpos;
    if (vpos < 35) {
      previewSub.style.top  = vpos + '%';
      vposLabel.textContent = 'Top';
    } else if (vpos < 65) {
      previewSub.style.top       = '50%';
      previewSub.style.transform = 'translateY(-50%)';
      vposLabel.textContent      = 'Center';
    } else {
      previewSub.style.bottom = (100 - vpos) + '%';
      vposLabel.textContent   = 'Bottom';
    }
  }

  function refreshPreviewText(t) {
    if (t === undefined) t = audioPlayer.currentTime;
    const seg = displaySegments.find(d => t >= d.start && t < d.end)
              || (t < 0.2 && displaySegments.length ? displaySegments[0] : null);
    previewSub.textContent = seg ? seg.text : '';
  }

  function startRafSync() {
    if (rafId) return;
    function tick() {
      const t = Math.max(0, audioPlayer.currentTime - 0.1);
      const seg = displaySegments.find(d => t >= d.start && t < d.end)
                || (audioPlayer.currentTime < 0.15 && displaySegments.length ? displaySegments[0] : null);
      previewSub.textContent = seg ? seg.text : '';
      rafId = requestAnimationFrame(tick);
    }
    rafId = requestAnimationFrame(tick);
  }
  function stopRafSync() {
    if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
  }

  // ── Mini player ───────────────────────────────────────────────────────────
  function updateMiniUI() {
    const playing = !audioPlayer.paused;
    miniIconPlay.classList.toggle('hidden', playing);
    miniIconPause.classList.toggle('hidden', !playing);
    const dur = audioPlayer.duration || 0;
    const cur = audioPlayer.currentTime;
    miniSeek.value       = dur > 0 ? (cur / dur) * 100 : 0;
    miniTime.textContent = `${formatShort(cur)} / ${formatShort(dur)}`;
  }

  miniPlayBtn.addEventListener('click', () => {
    if (audioPlayer.paused) audioPlayer.play(); else audioPlayer.pause();
  });

  let seekDragging = false;
  miniSeek.addEventListener('mousedown',  () => { seekDragging = true; });
  miniSeek.addEventListener('touchstart', () => { seekDragging = true; }, { passive: true });
  miniSeek.addEventListener('input', () => {
    const dur = audioPlayer.duration;
    if (isFinite(dur) && dur > 0) audioPlayer.currentTime = (miniSeek.value / 100) * dur;
  });
  miniSeek.addEventListener('change', () => { seekDragging = false; });

  audioPlayer.addEventListener('timeupdate',     () => { if (!seekDragging) updateMiniUI(); });
  audioPlayer.addEventListener('play',           () => { updateMiniUI(); startRafSync(); });
  audioPlayer.addEventListener('pause',          () => { updateMiniUI(); stopRafSync(); });
  audioPlayer.addEventListener('ended',          () => { updateMiniUI(); stopRafSync(); });
  audioPlayer.addEventListener('loadedmetadata', updateMiniUI);

  // ── File handling ─────────────────────────────────────────────────────────
  function setFile(file) {
    if (!file) return;
    const ext = file.name.split('.').pop().toLowerCase();
    const videoExts = ['mp4','mov','webm','avi','mkv'];
    const audioExts = ['mp3','wav','m4a','ogg','opus','flac','aac','weba'];
    isVideo = videoExts.includes(ext) || file.type.startsWith('video/');
    const isAudio = audioExts.includes(ext) || file.type.startsWith('audio/');
    if (!isVideo && !isAudio) {
      alert('Please select an audio or video file (MP3, WAV, M4A, OGG, OPUS, MP4, MOV, WebM).');
      return;
    }
    // Video upload requires Starter or Pro plan
    if (isVideo) {
      const plan = window._audiosrt?.currentPlan || window.currentUserPlan || 'free';
      if (plan !== 'starter' && plan !== 'pro') {
        alert('Video uploads are available on the Starter Trial and Pro plans.\n\nSign up for a free 14-day trial to unlock video transcription — no credit card required.');
        fileInput.value = '';
        return;
      }
    }
    selectedFile = file;
    updatePreviewControlsVisibility(file);
    updateExportOptions();
    updateNoiseReductionVisibility();
    fileName.textContent = file.name;
    try { sessionStorage.setItem('audiosrt_filename', file.name); } catch(e) {}
    fileSize.textContent = formatBytes(file.size);
    AudioSRTDB.saveProject(file, []).catch(e => console.warn('IndexedDB project save failed:', e));
    fileInfo.classList.remove('hidden');
    transcribeBtn.disabled = false;
    if (mediaObjectUrl) URL.revokeObjectURL(mediaObjectUrl);
    mediaObjectUrl = URL.createObjectURL(file);
    audioPlayer.src = mediaObjectUrl;
    audioPlayerWrap.classList.remove('hidden');
    if (isVideo) {
      videoPreviewEl.src = mediaObjectUrl;
      videoPreviewEl.classList.remove('hidden');
      previewBox.style.background = '';
    } else {
      videoPreviewEl.src = '';
      videoPreviewEl.classList.add('hidden');
      if (!previewBox.style.background) previewBox.style.background = '#000';
    }
  }

  dropZone.addEventListener('click',   (e) => { if (!e.target.closest('#remove-file') && !e.target.closest('#file-info')) fileInput.click(); });
  dropZone.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') fileInput.click(); });
  fileInput.addEventListener('change', e => setFile(e.target.files[0]));
  dropZone.addEventListener('dragover', e => {
    e.preventDefault();
    dropZone.classList.add('border-apple-blue', 'bg-blue-50/30');
  });
  dropZone.addEventListener('dragleave', () => {
    dropZone.classList.remove('border-apple-blue', 'bg-blue-50/30');
  });
  dropZone.addEventListener('drop', e => {
    e.preventDefault();
    dropZone.classList.remove('border-apple-blue', 'bg-blue-50/30');
    setFile(e.dataTransfer.files[0]);
  });

  removeFileBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    selectedFile = null;
    fileInput.value = '';
    fileInfo.classList.add('hidden');
    transcribeBtn.disabled = true;
    rawSegments      = [];
    logicalSegments  = [];
    displaySegments  = [];
    displayToLogical = [];
    monoRef = null; totalChunks = 1; chunksDone = 0; chunkQueue = [];
    isVideo = false;
    if (mediaObjectUrl) { URL.revokeObjectURL(mediaObjectUrl); mediaObjectUrl = null; }
    videoPreviewEl.src = '';
    videoPreviewEl.classList.add('hidden');
    previewBox.style.background = '#000';
    trimInSec = 0; trimOutSec = Infinity; tlRegionStart = null; tlRegionEnd = null;
    stopRafSync();
    toolCols.classList.add('hidden');
    stepSettings.classList.add('hidden');
    stepExport.classList.add('hidden');
    stepTimeline.classList.add('hidden');
    if (worker) { worker.terminate(); worker = null; }
    audioPlayer.src = '';
    updateMiniUI();
  });

  // ── Progress ──────────────────────────────────────────────────────────────
  const timeProgressWrap = document.getElementById('time-progress-wrap');
  const timeProgressBar  = document.getElementById('time-progress-bar');
  const timeElapsed      = document.getElementById('time-elapsed');
  const timeTotal        = document.getElementById('time-total');

  function setProgress(pct, label) {
    progressBar.style.width = pct + '%';
    progressPct.textContent = pct + '%';
    statusText.textContent  = label;

    // Parse "Transcribing… (Xs / Ys)" from chunk_callback progress messages
    const m = label.match(/\((\d+)s\s*\/\s*(\d+)s\)/);
    if (m) {
      const elapsed = parseInt(m[1]);
      const total   = parseInt(m[2]);
      const frac    = Math.min(1, elapsed / total);
      timeProgressWrap.style.display = 'block';
      timeProgressBar.style.width    = (frac * 100).toFixed(1) + '%';
      timeElapsed.textContent        = formatTime(elapsed);
      timeTotal.textContent          = formatTime(total);
    } else if (pct === 100 || pct === 0) {
      timeProgressWrap.style.display = 'none';
    }
  }

  function formatTime(sec) {
    const m = Math.floor(sec / 60);
    const s = sec % 60;
    return m > 0 ? `${m}m ${s}s` : `${s}s`;
  }
  function showError(msg) {
    setProgress(0, 'Error: ' + msg);
    progressBar.classList.add('bg-red-500');
    progressBar.classList.remove('bg-apple-blue');
    transcribeBtn.disabled = false;
  }

  // ── VAD-based audio segmentation ─────────────────────────────────────────
  // Slices mono 16kHz Float32Array at natural silence boundaries within a
  // 25–35 second soft window, so Whisper never receives an unnatural mid-word
  // cut. Falls back to the target midpoint when no clear silence is found.
  function vadSegmentAudio(mono, sampleRate) {
    const MIN_S   = 25, MAX_S = 35, TARGET_S = 30;
    const minSamp = MIN_S    * sampleRate;
    const maxSamp = MAX_S    * sampleRate;

    // Compute RMS energy in 20ms analysis windows
    const winLen = Math.round(0.020 * sampleRate);
    const numWin = Math.ceil(mono.length / winLen);
    const rms    = new Float32Array(numWin);
    for (let w = 0; w < numWin; w++) {
      const s = w * winLen, e = Math.min(s + winLen, mono.length);
      let sq = 0;
      for (let i = s; i < e; i++) sq += mono[i] * mono[i];
      rms[w] = Math.sqrt(sq / (e - s));
    }

    const segments = [];
    let pos = 0;
    while (pos < mono.length) {
      if (mono.length - pos <= maxSamp) {
        segments.push({ sampleStart: pos, sampleEnd: mono.length });
        break;
      }
      // Search for the quietest 20ms window between [pos+MIN, pos+MAX]
      const searchS = pos + minSamp;
      const searchE = Math.min(pos + maxSamp, mono.length);
      const wS = Math.floor(searchS / winLen);
      const wE = Math.ceil(searchE / winLen);
      let bestW    = Math.floor((pos + TARGET_S * sampleRate) / winLen);
      let lowestRms = Infinity;
      for (let w = wS; w < wE && w < numWin; w++) {
        if (rms[w] < lowestRms) { lowestRms = rms[w]; bestW = w; }
      }
      const cut = Math.min(bestW * winLen, mono.length);
      segments.push({ sampleStart: pos, sampleEnd: cut });
      pos = cut;
    }
    return segments;
  }

  // ── Sequential chunk queue ────────────────────────────────────────────────
  function buildChunkQueue(mono, sampleRate) {
    const segs = vadSegmentAudio(mono, sampleRate);
    return segs.map(({ sampleStart, sampleEnd }) => ({
      audioSlice: mono.slice(sampleStart, sampleEnd),
      timeOffset: sampleStart / sampleRate,
    }));
  }

  function dispatchNextChunk() {
    if (chunksDone >= chunkQueue.length) return;
    const { audioSlice, timeOffset } = chunkQueue[chunksDone];
    // Transfer the buffer — zero-copy, worker owns it after this call
    const transfer = audioSlice.slice();
    worker.postMessage(
      { type: 'transcribe', audioBuffer: transfer, sampleRate: 16000,
        timeOffset, chunkIndex: chunksDone, totalChunks },
      [transfer.buffer]
    );
  }

  // ── Noise reduction ───────────────────────────────────────────────────────
  // Shows the toggle only for audio files; video files skip it.
  function updateNoiseReductionVisibility() {
    const wrap = document.getElementById('noise-reduction-wrap');
    if (!wrap) return;
    const isAudio = selectedFile && selectedFile.type && selectedFile.type.startsWith('audio/');
    wrap.style.display = isAudio ? 'flex' : 'none';
  }

  async function enhanceAudio(audioBuffer) {
    // Spectral gate: compute short-time RMS across 50ms frames and zero out frames
    // below noise floor (estimated from the quietest 10% of frames).
    const sr     = audioBuffer.sampleRate;
    const ch     = audioBuffer.numberOfChannels;
    const len    = audioBuffer.length;
    const frameSize = Math.round(sr * 0.05); // 50 ms frames

    const offCtx = new OfflineAudioContext(ch, len, sr);

    // Copy source into offline context
    const srcNode = offCtx.createBufferSource();
    srcNode.buffer = audioBuffer;

    // High-pass filter — removes rumble/hum below 80 Hz
    const hpf = offCtx.createBiquadFilter();
    hpf.type            = 'highpass';
    hpf.frequency.value = 80;
    hpf.Q.value         = 0.7;

    // Compressor — evens out dynamic range
    const comp = offCtx.createDynamicsCompressor();
    comp.threshold.value = -30;
    comp.knee.value      = 10;
    comp.ratio.value     = 4;
    comp.attack.value    = 0.003;
    comp.release.value   = 0.25;

    srcNode.connect(hpf);
    hpf.connect(comp);
    comp.connect(offCtx.destination);
    srcNode.start(0);

    const rendered = await offCtx.startRendering();

    // Spectral gate on the rendered buffer (mono channel 0 as reference)
    const refData = rendered.getChannelData(0);
    const numFrames = Math.ceil(len / frameSize);
    const rms = new Float32Array(numFrames);
    for (let f = 0; f < numFrames; f++) {
      const start = f * frameSize;
      const end   = Math.min(start + frameSize, len);
      let sum = 0;
      for (let i = start; i < end; i++) sum += refData[i] * refData[i];
      rms[f] = Math.sqrt(sum / (end - start));
    }
    const sorted = Float32Array.from(rms).sort();
    const noiseFloor = sorted[Math.floor(sorted.length * 0.10)] * 2.5;

    // Gate: zero frames below noise floor
    for (let c = 0; c < rendered.numberOfChannels; c++) {
      const data = rendered.getChannelData(c);
      for (let f = 0; f < numFrames; f++) {
        if (rms[f] < noiseFloor) {
          const start = f * frameSize;
          const end   = Math.min(start + frameSize, len);
          data.fill(0, start, end);
        }
      }
    }
    return rendered;
  }

  transcribeBtn.addEventListener('click', async () => {
    if (!selectedFile) return;
    transcribeBtn.disabled = true;
    stopRafSync();

    toolCols.classList.remove('hidden');
    stepSettings.classList.add('hidden');
    stepExport.classList.add('hidden');
    progressArea.classList.remove('hidden');
    transcriptArea.classList.add('hidden');
    transcriptLines.innerHTML = '';
    rawSegments      = [];
    logicalSegments  = [];
    displaySegments  = [];
    displayToLogical = [];
    monoRef = null;
    progressBar.classList.remove('bg-red-500');
    progressBar.classList.add('bg-apple-blue');
    setProgress(3, 'Reading audio file…');

    const noiseToggle = document.getElementById('noise-reduction-toggle');
    const useNoiseReduction = noiseToggle?.checked && selectedFile.type.startsWith('audio/');

    try {
      const arrayBuffer = await selectedFile.arrayBuffer();
      const audioCtx    = new AudioContext({ sampleRate: 16000 });
      let decoded       = await audioCtx.decodeAudioData(arrayBuffer);

      if (useNoiseReduction) {
        setProgress(8, 'Reducing noise…');
        decoded = await enhanceAudio(decoded);
      }

      const numCh = decoded.numberOfChannels;
      const len   = decoded.length;
      const mono  = new Float32Array(len);
      for (let ch = 0; ch < numCh; ch++) {
        const chan = decoded.getChannelData(ch);
        for (let i = 0; i < len; i++) mono[i] += chan[i];
      }
      if (numCh > 1) for (let i = 0; i < len; i++) mono[i] /= numCh;
      audioCtx.close();

      monoRef    = mono;
      chunkQueue = buildChunkQueue(mono, 16000);
      totalChunks = chunkQueue.length;
      chunksDone  = 0;

      if (totalChunks > 1) {
        const totalSec = Math.round(mono.length / 16000);
        setProgress(4, `Splitting ${Math.round(totalSec / 60)}m audio into ${totalChunks} natural segments…`);
      }
      setProgress(5, 'Starting transcription worker…');
      if (!worker) worker = new Worker('/transcription-worker.js', { type: 'module' });

      worker.onerror = (e) => {
        console.error('[worker]', e);
        showError(e.message || 'Worker crashed. Refresh and try again.');
        worker = null;
        transcribeBtn.disabled = false;
      };

      worker.onmessage = (e) => {
        const msg = e.data;
        if (msg.type === 'progress') {
          const overall = Math.round(
            (chunksDone / totalChunks + msg.percent / 100 / totalChunks) * 100
          );
          const prefix = totalChunks > 1 ? `Chunk ${chunksDone + 1}/${totalChunks} — ` : '';
          setProgress(overall, prefix + msg.message);

        } else if (msg.type === 'complete') {
          rawSegments.push(...msg.transcript);

          // Track how many display rows existed before this chunk lands
          const prevDisplayCount = displaySegments.length;

          appendChunkToLogical(msg.transcript);
          rebuildDisplaySegments();

          // Progressive append: only render new rows, never clear existing DOM.
          // If the transcript panel is already visible (mid-transcription editing),
          // append rows without disturbing scroll position or active cursor.
          if (!transcriptArea.classList.contains('hidden')) {
            renderTranscriptAppend(prevDisplayCount);
          }

          // Persist immediately — user can restore this chunk even if later ones fail
          autoSave();
          chunksDone++;

          if (chunksDone < totalChunks) {
            setProgress(
              Math.round((chunksDone / totalChunks) * 100),
              `Chunk ${chunksDone}/${totalChunks} done — processing next…`
            );
            dispatchNextChunk();
          } else {
            // All chunks done — open edit view if not already open
            setProgress(100, 'Done!');
            if (transcriptArea.classList.contains('hidden')) {
              // First time reveal: do a full render since nothing is in the DOM yet
              renderTranscript();
              progressArea.classList.add('hidden');
              transcriptArea.classList.remove('hidden');
              stepSettings.classList.remove('hidden');
              stepExport.classList.remove('hidden');
              stepTimeline.classList.remove('hidden');
              applyPreviewStyles();
              refreshPreviewText(0);
              renderTemplates();
              initTimeline();
            } else {
              // Panel was already open from a prior chunk — just hide the progress ring
              progressArea.classList.add('hidden');
            }
            transcribeBtn.disabled = false;
            monoRef = null;
          }

        } else if (msg.type === 'error') {
          console.error('[worker]', msg.message);
          showError(msg.message);
          transcribeBtn.disabled = false;
        }
      };

      dispatchNextChunk();
    } catch (err) {
      console.error(err);
      showError(err.message || 'Could not decode audio. Try a different file.');
      transcribeBtn.disabled = false;
    }
  });

