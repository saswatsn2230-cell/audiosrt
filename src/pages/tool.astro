            <div class="cg-sep"></div>
            <div class="cg"><span class="cg-lbl">Size: <span id="fontsize-val">20px</span></span>
              <input id="fontsize-slider" type="range" min="12" max="48" value="20" class="range-ctrl" style="width:50px;" /></div>
            <div class="cg-sep"></div>
            <div class="cg"><span class="cg-lbl">Color: <span id="color-hex">#FFFFFF</span></span>
              <input id="text-color" type="color" value="#ffffff" class="color-ctrl" /></div>
            <div class="cg-sep"></div>
