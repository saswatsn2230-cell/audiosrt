  // ── FFmpeg MP4 export ─────────────────────────────────────────────────────
  document.getElementById('export-video-btn')?.addEventListener('click', async () => {
    if (!selectedFile || !selectedFile.type.startsWith('video/')) return;
    exportCancelled = false;

    const btn          = document.getElementById('export-video-btn');
    const cancelBtn    = document.getElementById('cancel-video-export-btn');
    const progressWrap = document.getElementById('video-export-progress-wrap');
    const progressBar  = document.getElementById('video-export-progress-bar');
    const progressEl   = document.getElementById('video-export-progress');

    btn.disabled = true;
    btn.textContent = 'Loading…';
    cancelBtn.style.display = 'block';
    progressWrap.style.display = 'block';
    progressBar.style.width = '0%';
    progressEl.textContent = 'Loading video engine (first load ~30s)…';

    try {
      const { FFmpeg }               = await import('/node_modules/@ffmpeg/ffmpeg/dist/esm/index.js');
      const { fetchFile, toBlobURL } = await import('/node_modules/@ffmpeg/util/dist/esm/index.js');

      const ffmpeg = new FFmpeg();
      ffmpegInstance = ffmpeg;
      ffmpeg.on('log', ({ message }) => { console.log('[FFmpeg]', message); });
      ffmpeg.on('progress', ({ progress }) => {
        const pct = Math.round(Math.min(progress, 1) * 100);
        progressBar.style.width = pct + '%';
        progressEl.textContent = `Processing: ${pct}%`;
        btn.textContent = `${pct}%…`;
      });

      const baseURL = 'https://cdn.jsdelivr.net/npm/@ffmpeg/core@0.12.6/dist/esm';
      await ffmpeg.load({
        coreURL:   await toBlobURL(`${baseURL}/ffmpeg-core.js`,   'text/javascript'),
        wasmURL:   await toBlobURL(`${baseURL}/ffmpeg-core.wasm`, 'application/wasm'),
        workerURL: '/ffmpeg-worker.js',
      });
      if (exportCancelled) return;

      progressEl.textContent = 'Preparing files…';
      progressBar.style.width = '5%';

      const quality  = document.querySelector('.video-opt.active[data-quality]')?.dataset.quality  || '1080p';
