  function downloadBlob(content, filename, mime) {
    const blob = new Blob([content], { type: mime });
    const a = Object.assign(document.createElement('a'), {
      href: URL.createObjectURL(blob), download: filename,
    });
    a.click();
    URL.revokeObjectURL(a.href);
  }

  function baseName() {
    return selectedFile?.name?.replace(/\.[^.]+$/, '') || 'transcript';
  }

  downloadSrtBtn.addEventListener('click', () => {
    const tIn  = trimInSec;
    const tOut = isFinite(trimOutSec) ? trimOutSec : Infinity;
    const segs = displaySegments.filter(s => s.text.trim() && s.end > tIn && s.start < tOut);
    let out = '', n = 1;
    segs.forEach(seg => {
      const adjStart = Math.max(seg.start - tIn, 0);
      const adjEnd   = Math.max(seg.end   - tIn, 0.001);
      out += `${n++}\n${formatTimestamp(adjStart)} --> ${formatTimestamp(adjEnd)}\n${seg.text}\n\n`;
    });
    downloadBlob(out, baseName() + '.srt', 'text/plain');
  });

  downloadTxtBtn.addEventListener('click', () => {
    downloadBlob(displaySegments.map(d => d.text).join('\n'), baseName() + '.txt', 'text/plain');
  });

  downloadPproBtn.addEventListener('click', () => {
    const transcript = displaySegments.filter(s => s.text.trim()).map(seg => {
      const words = seg.text.split(/\s+/).filter(Boolean);
      const dur   = Math.max(0, seg.end - seg.start);
      const wDur  = words.length ? dur / words.length : 0;
      return {
        startTime: parseFloat(seg.start.toFixed(3)),
        endTime:   parseFloat(seg.end.toFixed(3)),
        text:      seg.text,
        words: words.map((w, wi) => ({
          word:      w,
          startTime: parseFloat((seg.start + wi * wDur).toFixed(3)),
          endTime:   parseFloat((seg.start + (wi + 1) * wDur).toFixed(3)),
        })),
      };
    });
    downloadBlob(JSON.stringify({ version: '1.0', transcript }, null, 2), baseName() + '.json', 'application/json');
  });

