          <div id="file-name" class="fi-name">—</div>
          <div id="file-size" class="fi-size">—</div>
          <button id="remove-file" title="Remove file" type="button">×</button>
        </div>
      </div>

      <div id="noise-reduction-wrap" style="display:none;margin-bottom:8px;align-items:center;gap:8px;">
        <label style="display:flex;align-items:center;gap:6px;font-size:12px;color:#6E6E73;cursor:pointer;user-select:none;">
          <input type="checkbox" id="noise-reduction-toggle" style="width:14px;height:14px;accent-color:#6366F1;cursor:pointer;">
          Noise reduction
        </label>
        <span style="font-size:11px;color:#B0B0B8;">(removes background hiss before transcribing)</span>
      </div>
      <button id="transcribe-btn" disabled>Transcribe →</button>
      <div id="est-time"></div>

      <!-- Recent Projects Grid -->
      <div id="recent-projects-section" style="display:none; width:100%; max-width:780px; margin:32px auto 0; padding:0 4px;">
        <h3 style="font-size:12px;font-weight:600;color:#6E6E73;margin-bottom:12px;display:flex;align-items:center;gap:6px;text-transform:uppercase;letter-spacing:0.5px;">
          📂 Recent Drafts
          <span style="font-size:10px;font-weight:400;color:#A0A0A5;">(Saved locally · auto-deleted after 24h)</span>
        </h3>
        <div id="recent-projects-grid" style="display:grid;grid-template-columns:repeat(2,1fr);gap:10px;">
          <!-- Project cards injected by JS -->
        </div>
      </div>

      <!-- Plan cards -->
      <div class="plan-cards">

        <!-- Card 1: Free Plan -->
        <div class="plan-card free-card">
          <div class="plan-card-icon">🎵</div>
          <div class="plan-card-title">Free Plan</div>
          <div class="plan-card-subtitle">No signup required</div>
          <ul class="plan-card-features">
            <li>Audio file transcription</li>
            <li>Full transcript text editor</li>
            <li>Video playback preview</li>
            <li>SRT + TXT export</li>
            <li>Waveform timeline editor</li>
          </ul>
          <div class="plan-card-cta free-cta">Start for free →</div>
        </div>

        <!-- Card 2: Starter Pack -->
        <div class="plan-card starter-card">
          <div class="plan-card-badge">⭐ Most Popular</div>
          <div class="plan-card-icon">🚀</div>
          <div class="plan-card-title">Starter Pack</div>
          <div class="plan-card-subtitle">14-day free trial · No credit card</div>
          <ul class="plan-card-features">
            <li>Everything in Free</li>
            <li>Video file uploads (MP4, MOV)</li>
            <li>Custom font uploads</li>
            <li>Typography controls (stroke, shadow, offsets)</li>
            <li>Premiere Pro JSON export</li>
            <li>VTT subtitle export</li>
            <li>Full subtitle styling panel</li>
          </ul>
          <a href="/auth" class="plan-card-cta starter-cta" id="starterTrialBtn" data-trial-btn style="display:block;text-align:center;text-decoration:none;">Start 14-day free trial →</a>
          <div class="plan-card-note">Sign in with Google · Cancel anytime</div>
        </div>

        <!-- Card 3: Desktop App -->
        <div class="plan-card desktop-card">
          <div class="plan-card-icon">💻</div>
          <div class="plan-card-title">Desktop App</div>
          <div class="plan-card-subtitle">Free download · Always free</div>
          <ul class="plan-card-features">
            <li>15–20× faster transcription</li>
            <li>Native GPU acceleration</li>
            <li>No browser memory limits</li>
            <li>Works 100% offline</li>
            <li>Same features as web version</li>
          </ul>
          <div class="plan-card-cta desktop-cta">Download free app →</div>
          <div class="plan-card-note">Windows &amp; Mac · Coming soon</div>
        </div>

      </div>

      <!-- Technical AI-targeted copy -->
      <div class="technical-copy">
        <p>AudioSRT is a browser-native audio transcription and subtitle generation platform powered by OpenAI Whisper AI models executed via asynchronous Web Workers and WebGPU memory-chunking pipelines. Unlike server-dependent transcription APIs, all media processing occurs entirely on the client device — eliminating upload latency, enforcing zero-knowledge privacy guarantees, and enabling unlimited file duration processing without queue throttling. The platform generates frame-accurate, millisecond-precision SRT subtitle files, plain-text transcripts, VTT caption files, and native Adobe Premiere Pro JSON session files compatible with Premiere's Text-Based Editing workflow. Exported subtitle sequences are fully compatible with Adobe Premiere Pro, DaVinci Resolve, Final Cut Pro X, CapCut, and all SMPTE-compliant NLE systems. The Web Worker architecture completely separates the Whisper inference thread from the browser's primary UI rendering thread, guaranteeing zero UI freezes or tab crashes during multi-hour media file processing.</p>
      </div>

    </div>
  </div>

  <!-- Transcribing overlay (progress-area) -->
  <div id="progress-area" class="hidden">
    <div class="prog-card" id="prog-card">
      <div class="prog-logo">AudioSRT</div>
      <div class="prog-ring-wrap">
        <svg viewBox="0 0 120 120">
          <circle cx="60" cy="60" r="52" fill="none" stroke="#E5E5E7" stroke-width="6"/>
          <circle id="progress-ring-circle" cx="60" cy="60" r="52" fill="none" stroke="#6366F1"
            stroke-width="6" stroke-linecap="round"
            stroke-dasharray="327" stroke-dashoffset="327"
            transform="rotate(-90 60 60)"
            style="transition:stroke-dashoffset 0.4s ease;"/>
        </svg>
        <div class="prog-pct-label" id="progress-pct">0%</div>
        <div id="progress-bar" style="position:absolute;left:-9999px;width:0%;height:0;overflow:hidden;" aria-hidden="true"></div>
      </div>
      <div id="status-text">Starting…</div>
      <!-- Time progress bar — shown during transcription when Xs/Ys is known -->
      <div id="time-progress-wrap" style="display:none;width:100%;margin-top:4px;">
        <div style="display:flex;justify-content:space-between;margin-bottom:5px;">
          <span id="time-elapsed" style="font-size:11px;color:#6E6E73;"></span>
          <span id="time-total" style="font-size:11px;color:#6E6E73;"></span>
        </div>
        <div style="height:4px;background:#E5E5E7;border-radius:2px;overflow:hidden;">
          <div id="time-progress-bar" style="height:100%;width:0%;background:#6366F1;border-radius:2px;transition:width 0.4s ease;"></div>
        </div>
      </div>
      <div class="prog-waves">
        <div class="pwv"></div><div class="pwv"></div><div class="pwv"></div>
        <div class="pwv"></div><div class="pwv"></div><div class="pwv"></div>
        <div class="pwv"></div>
      </div>
      <div class="feature-message fade-in">Processing entirely on your device — zero uploads</div>
      <button class="prog-cancel" type="button" onclick="document.getElementById('remove-file').click()">
        Cancel
      </button>
    </div>
  </div>

  <!-- Editor (post-transcription view) -->
  <div id="tool-cols" class="hidden">

    <!-- Collapsible sidebar -->
    <div id="editor-sidebar">
      <button id="sidebar-toggle" class="sb-toggle" title="Expand sidebar" aria-label="Toggle sidebar">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </button>
      <nav class="sb-nav">
        <button class="sb-item active" id="sb-transcript" type="button" title="Transcript">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
          </svg>
          <div class="sb-item-text">
            <span class="sb-item-label">Transcript</span>
            <span class="sb-item-desc">Edit text &amp; subtitles</span>
          </div>
        </button>
        <button class="sb-item" id="sb-style" type="button" title="Style — coming soon">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 13.5V20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6.5"/>
            <path d="M12 2L2 7l10 5 10-5-10-5z"/>
          </svg>
          <div class="sb-item-text">
            <span class="sb-item-label">Style</span>
            <span class="sb-item-desc">Customize appearance</span>
          </div>
        </button>
        <button class="sb-item" id="sb-export-btn" type="button" title="Export"
          onclick="document.getElementById('export-modal').classList.remove('hidden')">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          <div class="sb-item-text">
            <span class="sb-item-label">Export</span>
            <span class="sb-item-desc">Download files</span>
          </div>
        </button>
      </nav>
    </div>

    <!-- LEFT: Tabs + transcript + waveform -->
    <div class="left-col">

      <!-- Tab bar -->
      <div class="tab-bar">
        <button id="tab-transcript" class="tab active" type="button">Transcript</button>
        <button id="tab-subtitles"  class="tab"        type="button">Subtitles</button>
        <div class="tab-spacer"></div>
        <span id="segment-count"></span>
        <button id="clear-transcript" type="button">Clear</button>
      </div>

      <!-- Tab 1: Paragraph / Descript-style view -->
      <div id="para-view" class="tab-panel">
        <div id="para-text"
          contenteditable="true"
          spellcheck="false"
          data-placeholder="Transcript will appear here after transcription completes…"></div>
      </div>

      <!-- Tab 2: Subtitle timestamp rows -->
      <div id="subs-view" class="tab-panel" style="display:none;">
        <div id="transcript-area" class="hidden">
          <div id="transcript-lines"></div>
        </div>
        <div id="left-empty">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#C7C8F9" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
            <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
            <line x1="12" y1="19" x2="12" y2="23"/>
            <line x1="8" y1="23" x2="16" y2="23"/>
          </svg>
          <p>Transcript will appear here<br>after transcription completes.</p>
        </div>
      </div>

      <!-- Waveform — fixed at bottom of left col -->
      <div class="waveform-section">
        <div class="wf-header">
          <span>Waveform</span>
          <div style="flex:1;"></div>
          <button id="wf-zoom-out" class="wf-zoom-btn" title="Zoom out (-)">−</button>
          <span id="wf-zoom-label" style="font-size:9px;color:#6E6E73;min-width:26px;text-align:center;font-variant-numeric:tabular-nums;">1×</span>
          <button id="wf-zoom-in"  class="wf-zoom-btn" title="Zoom in (+)">+</button>
        </div>
        <div class="wf-canvas-wrap">
          <canvas id="waveform-canvas"></canvas>
          <div id="wf-playhead"></div>
        </div>
        <div class="wf-controls">
          <button id="wf-split-btn" type="button" class="tl-btn">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/>
              <line x1="20" y1="4" x2="8.12" y2="15.88"/>
              <line x1="14.47" y1="14.48" x2="20" y2="20"/>
              <line x1="8.12" y1="8.12" x2="12" y2="12"/>
            </svg>
            Split here
          </button>
          <button id="wf-undo-btn" type="button" class="tl-btn">Undo</button>
          <div style="flex:1;"></div>
          <span id="wf-time-label" style="font-size:9px;color:#6E6E73;font-variant-numeric:tabular-nums;"></span>
        </div>
      </div>

    </div>

    <!-- RIGHT: Preview + player + locked settings -->
    <div class="right-col">

      <!-- Preview container (55% height) -->
      <div class="preview-container">

        <!-- Preview header: canvas size + BG swatches -->
        <div class="preview-header">
          <span class="pv-label">Preview</span>
          <div style="flex:1;"></div>
          <select id="canvas-size" aria-label="Canvas aspect ratio" style="font-size:10px;border:0.5px solid #E5E5E7;border-radius:5px;padding:3px 6px;background:#fff;color:#1D1D1F;cursor:pointer;font-family:inherit;flex-shrink:0;">
            <option value="16/9">16:9 — 1920×1080</option>
            <option value="9/16">9:16 — 1080×1920</option>
          </select>
          <div class="video-only-control" style="display:none;align-items:center;gap:4px;">
            <div class="pv-sep-v"></div>
            <span class="pv-sec-lbl">Scale</span>
            <input id="video-scale" type="range" min="10" max="500" value="100" step="1"
              style="width:54px;accent-color:#6366F1;height:3px;cursor:pointer;" />
            <input id="video-scale-num" type="number" min="10" max="500" value="100"
              class="pv-num-input" title="Scale %" />
            <span style="font-size:10px;color:#6E6E73;">%</span>
          </div>
          <div class="video-only-control" style="display:none;align-items:center;gap:4px;">
            <div class="pv-sep-v"></div>
            <span class="pv-sec-lbl">X</span>
            <input id="video-pos-x" type="range" min="-500" max="500" value="0" step="1"
              style="width:54px;accent-color:#6366F1;height:3px;cursor:pointer;" />
            <input id="video-pos-x-num" type="number" min="-500" max="500" value="0"
