     which the global handler calls after plan is resolved. -->

<script>
(() => {
  // DOM refs
  const dropZone        = document.getElementById('drop-zone');
  const fileInput       = document.getElementById('file-input');
  const fileInfo        = document.getElementById('file-info');
  const fileName        = document.getElementById('file-name');
  const fileSize        = document.getElementById('file-size');
  const removeFileBtn   = document.getElementById('remove-file');
  const transcribeBtn   = document.getElementById('transcribe-btn');
  const videoPreviewEl  = document.getElementById('video-preview-el');
  const canvasSizeEl    = document.getElementById('canvas-size');
  const templateGrid    = document.getElementById('template-grid');
  const stepTimeline    = document.getElementById('step-timeline');
  const timelineCanvas  = document.getElementById('timeline-canvas');
  const timelineWrap    = document.getElementById('timeline-wrap');
  const timelinePlayhead = document.getElementById('timeline-playhead');
  const timelineRegion   = document.getElementById('timeline-region');
  const trimInEl        = document.getElementById('trim-in');
  const trimOutEl       = document.getElementById('trim-out');
  const tlTrimInLabel   = document.getElementById('tl-trim-in-label');
  const tlTrimOutLabel  = document.getElementById('tl-trim-out-label');
  const tlDurationLabel = document.getElementById('tl-duration-label');
  const timelineSplitBtn = document.getElementById('timeline-split-btn');
  const timelineDeleteBtn = document.getElementById('timeline-delete-btn');

  const toolCols    = document.getElementById('tool-cols');
  const stepSettings = document.getElementById('step-settings');
  const stepExport   = document.getElementById('step-export');

  const progressBar  = document.getElementById('progress-bar');
  const progressPct  = document.getElementById('progress-pct');
  const statusText   = document.getElementById('status-text');
  const progressArea = document.getElementById('progress-area');

  const audioPlayerWrap = document.getElementById('audio-player-wrap');
  const audioPlayer     = document.getElementById('audio-player');
  const transcriptArea  = document.getElementById('transcript-area');
  const transcriptLines = document.getElementById('transcript-lines');
  const clearTranscript = document.getElementById('clear-transcript');

  const miniPlayBtn   = document.getElementById('mini-play-btn');
  const miniIconPlay  = document.getElementById('mini-icon-play');
  const miniIconPause = document.getElementById('mini-icon-pause');
  const miniSeek      = document.getElementById('mini-seek');
  const miniTime      = document.getElementById('mini-time');

  const singleLineBtn  = document.getElementById('single-line-btn');
  const doubleLineBtn  = document.getElementById('double-line-btn');
  const charsSlider    = document.getElementById('chars-slider');
  const charsVal       = document.getElementById('chars-val');
  const fontSelect     = document.getElementById('font-select');
  const fontsizeSlider = document.getElementById('fontsize-slider');
  const fontsizeVal    = document.getElementById('fontsize-val');
  const textColor      = document.getElementById('text-color');
  const colorHex       = document.getElementById('color-hex');
  const boldBtn        = document.getElementById('bold-btn');
  const shadowBtn      = document.getElementById('shadow-btn');
  const strokeBtn      = document.getElementById('stroke-btn');
  const vposSlider     = document.getElementById('vpos-slider');
  const vposLabel      = document.getElementById('vpos-label');

  const bgBtns     = document.querySelectorAll('.bg-btn');
  const previewBox = document.getElementById('preview-box');
  const previewSub = document.getElementById('preview-subtitle');

  const downloadSrtBtn  = document.getElementById('download-srt-btn');
  const downloadTxtBtn  = document.getElementById('download-txt-btn');
  const downloadPproBtn = document.getElementById('download-ppro-btn');

  // ── State ────────────────────────────────────────────────────────────────
  let selectedFile = null;
  let rawSegments = [];
  let logicalSegments = [];
  let displaySegments = [];
  let displayToLogical = [];

  // Expose globals for auth module cross-script access
  window._audiosrt = window._audiosrt || {};
  window._audiosrt.getSegments = () => logicalSegments;
  window._audiosrt.setSegments = (segs) => {
    logicalSegments = segs.map(s => ({ ...s }));
    displaySegments = logicalSegments.map(s => ({ ...s }));
    displayToLogical = logicalSegments.map((_, i) => i);
  };
  window._audiosrt.showEditor = () => {
    const tc = document.getElementById('tool-cols');
    if (tc) tc.classList.remove('hidden');
  };
  window._audiosrt.renderTranscript = () => {
    if (typeof renderTranscript === 'function') renderTranscript();
  };

  // ── IndexedDB persistence ─────────────────────────────────────────────────
  const AudioSRTDB = {
    dbName: 'audiosrt_db',
    version: 2,
    db: null,

    async open() {
      if (this.db) return this.db;
      return new Promise((resolve, reject) => {
        const req = indexedDB.open(this.dbName, this.version);
        req.onupgradeneeded = (e) => {
          const db = e.target.result;
          if (db.objectStoreNames.contains('files')) db.deleteObjectStore('files');
          if (db.objectStoreNames.contains('state')) db.deleteObjectStore('state');
          if (!db.objectStoreNames.contains('projects')) {
            db.createObjectStore('projects', { keyPath: 'id' });
          }
        };
        req.onsuccess = (e) => { this.db = e.target.result; resolve(this.db); };
        req.onerror = () => reject(req.error);
      });
    },

    generateId() {
      return `proj_${Date.now()}_${Math.random().toString(36).substring(2, 7)}`;
    },

    async saveProject(file, segments) {
      const db = await this.open();
      const existing = await this.getProjectByName(file.name);
      const id = existing ? existing.id : this.generateId();
      return new Promise((resolve, reject) => {
        const tx = db.transaction('projects', 'readwrite');
        tx.objectStore('projects').put({
          id,
          fileName: file.name,
          fileType: file.type,
          fileSize: file.size,
          fileData: file,
          segments,
          subtitleCount: segments.length,
          createdAt: existing ? existing.createdAt : new Date().toISOString(),
          updatedAt: new Date().toISOString(),
        });
        tx.oncomplete = () => resolve(id);
        tx.onerror = () => reject(tx.error);
      });
    },

    async getAllProjects() {
      const db = await this.open();
      return new Promise((resolve, reject) => {
        const tx = db.transaction('projects', 'readonly');
        const req = tx.objectStore('projects').getAll();
        req.onsuccess = () => resolve(req.result || []);
        req.onerror = () => reject(req.error);
      });
    },

    async getProject(id) {
      const db = await this.open();
      return new Promise((resolve, reject) => {
        const tx = db.transaction('projects', 'readonly');
        const req = tx.objectStore('projects').get(id);
        req.onsuccess = () => resolve(req.result || null);
        req.onerror = () => reject(req.error);
      });
    },

    async getProjectByName(filename) {
      const projects = await this.getAllProjects();
      return projects.find(p => p.fileName === filename) || null;
    },

    async deleteProject(id) {
      const db = await this.open();
      return new Promise((resolve, reject) => {
        const tx = db.transaction('projects', 'readwrite');
        tx.objectStore('projects').delete(id);
        tx.oncomplete = () => resolve(true);
        tx.onerror = () => reject(tx.error);
      });
    },

    async cleanupExpired() {
      const EXPIRY_MS = 86_400_000;
      const now = Date.now();
      try {
        const projects = await this.getAllProjects();
        for (const p of projects) {
          if (now - new Date(p.createdAt).getTime() > EXPIRY_MS) {
            await this.deleteProject(p.id);
          }
        }
      } catch(e) {}
    },

    getTimeRemaining(project) {
      const remaining = 86_400_000 - (Date.now() - new Date(project.createdAt).getTime());
      if (remaining <= 0) return null;
      const hours = Math.floor(remaining / 3_600_000);
      const minutes = Math.floor((remaining % 3_600_000) / 60_000);
      const seconds = Math.floor((remaining % 60_000) / 1_000);
      return { ms: remaining, hours, minutes, seconds, text: `Expires in ${hours}h ${minutes}m ${seconds}s` };
    },

    async clearAll() {
      const db = await this.open();
      return new Promise((resolve) => {
        const tx = db.transaction('projects', 'readwrite');
        tx.objectStore('projects').clear();
        tx.oncomplete = () => resolve(true);
      });
    },

    // Shims so existing checkAndRestoreSession works unchanged
    async getState() {
      const projects = await this.getAllProjects();
      if (!projects.length) return null;
      projects.sort((a, b) => new Date(b.updatedAt) - new Date(a.updatedAt));
      const p = projects[0];
      return { segments: p.segments, filename: p.fileName, createdAt: p.createdAt, savedAt: new Date(p.updatedAt).getTime(), id: p.id };
    },

    async getFile() {
      const projects = await this.getAllProjects();
      if (!projects.length) return null;
      projects.sort((a, b) => new Date(b.updatedAt) - new Date(a.updatedAt));
      const p = projects[0];
      return { data: p.fileData, name: p.fileName, type: p.fileType };
    }
  };

  let autoSaveTimer = null;
  function autoSave() {
    if (!selectedFile || !logicalSegments.length) return;
    clearTimeout(autoSaveTimer);
    autoSaveTimer = setTimeout(async () => {
      // Always save locally
      await AudioSRTDB.saveProject(selectedFile, logicalSegments).catch(() => {});

      // Cloud sync for Starter/Pro users
      const plan = window.currentUserPlan;
      const userId = window._audiosrt?.userId;
      const accessToken = window._audiosrt?.accessToken;
      if (userId && accessToken && (plan === 'starter' || plan === 'pro')) {
        try {
          const { syncProjectToCloud } = await import('/src/lib/sync.js');
          const projectId = selectedFile.name.replace(/[^a-z0-9]/gi, '_');
          await syncProjectToCloud(userId, projectId, {
            filename: selectedFile.name,
            segments: logicalSegments,
            settings: getCurrentSubtitleSettings(),
          }, accessToken);
        } catch(e) { /* non-critical */ }
      }
    }, 3000);
  }

  function getCurrentSubtitleSettings() {
    return {
      fontSize:   document.getElementById('font-size-slider')?.value,
      fontFamily: document.getElementById('font-select')?.value,
      textColor:  document.getElementById('color-picker')?.value,
      position:   document.getElementById('position-slider')?.value,
    };
  }

  function clearSession() {
    AudioSRTDB.clearAll().catch(() => {});
    ['audiosrt_filename','audiosrt_pending_segments','audiosrt_pending_redirect','audiosrt_returning_from_auth'].forEach(k => sessionStorage.removeItem(k));
  }

  document.addEventListener('DOMContentLoaded', () => { AudioSRTDB.cleanupExpired().catch(() => {}); });

  async function showExpiryCountdown(project) {
    // project can be passed directly or fetched from most recent
    if (!project) {
      const state = await AudioSRTDB.getState();
      if (!state) return;
      project = await AudioSRTDB.getProject(state.id);
    }
    if (!project) return;
    const timeLeft = AudioSRTDB.getTimeRemaining(project);
    if (!timeLeft) return;

    document.getElementById('expiry-countdown')?.remove();

    const countdown = document.createElement('span');
    countdown.id = 'expiry-countdown';
    countdown.style.cssText = 'font-size:10px;color:#A0A0A5;white-space:nowrap;';
    countdown.innerHTML = '<span id="countdown-text">' + timeLeft.text + '</span>';

    const newFileBtn = document.getElementById('new-file-btn');
    if (newFileBtn) {
      newFileBtn.title = timeLeft.text;
      newFileBtn.parentNode?.insertBefore(countdown, newFileBtn.nextSibling);
    } else {
      const topbar = document.getElementById('topbar');
      if (topbar) topbar.appendChild(countdown);
    }

    const projId = project.id;
    const interval = setInterval(async () => {
      const latest = await AudioSRTDB.getProject(projId);
      const updated = latest ? AudioSRTDB.getTimeRemaining(latest) : null;
      const textEl = document.getElementById('countdown-text');
      if (!updated) {
        clearInterval(interval);
        countdown.remove();
        if (latest) await AudioSRTDB.deleteProject(projId);
        const expiredBanner = document.createElement('div');
        expiredBanner.style.cssText = 'position:fixed;top:52px;left:50%;transform:translateX(-50%);background:#FEF2F2;color:#EF4444;border:0.5px solid #FECACA;padding:8px 20px;border-radius:8px;font-size:12px;font-family:Inter,sans-serif;font-weight:500;z-index:9999;';
        expiredBanner.textContent = 'Your cached project has expired. Please upload your file again.';
        document.body.appendChild(expiredBanner);
        setTimeout(() => { expiredBanner.remove(); window.location.href = '/tool'; }, 4000);
        return;
      }
      if (textEl) textEl.textContent = updated.text;
      const nfb = document.getElementById('new-file-btn');
      if (nfb) nfb.title = updated.text;
    }, 60_000);
  }

  function getTimeAgo(dateStr) {
    const diff = Date.now() - new Date(dateStr).getTime();
    const mins = Math.floor(diff / 60000);
    const hours = Math.floor(diff / 3600000);
    if (mins < 1) return 'just now';
    if (mins < 60) return `${mins}m ago`;
    if (hours < 24) return `${hours}h ago`;
    return 'yesterday';
  }

