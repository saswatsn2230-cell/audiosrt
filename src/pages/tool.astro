            <span style="font-size:10px;color:#6E6E73;">px</span>
          </div>
          <div class="video-only-control" style="display:none;align-items:center;gap:4px;">
            <div class="pv-sep-v"></div>
            <span class="pv-sec-lbl">Y</span>
            <input id="video-pos-y" type="range" min="-500" max="500" value="0" step="1"
              style="width:54px;accent-color:#6366F1;height:3px;cursor:pointer;" />
            <input id="video-pos-y-num" type="number" min="-500" max="500" value="0"
              class="pv-num-input" title="Y offset (px)" />
            <span style="font-size:10px;color:#6E6E73;">px</span>
          </div>
          <div class="bg-control" style="display:flex;align-items:center;gap:4px;">
            <div class="pv-sep-v"></div>
            <span class="pv-sec-lbl">BG</span>
            <div class="pv-bg-swatches">
              <button class="pv-bg-swatch active" data-pv-bg="#000000" style="background:#000;" title="Black"></button>
              <button class="pv-bg-swatch" data-pv-bg="#1a1a1a" style="background:#1a1a1a;" title="Dark Gray"></button>
              <button class="pv-bg-swatch" data-pv-bg="#FFFFFF" style="background:#fff;border-color:#D1D5DB;" title="White"></button>
              <button class="pv-bg-swatch" data-pv-bg="#00B140" style="background:#00B140;" title="Green Screen"></button>
            </div>
          </div>
        </div>

        <!-- Preview screen wrapper (centers preview box) -->
        <div class="preview-screen-wrapper">
          <div id="preview-box" class="preview-screen">
            <video id="video-preview-el" class="hidden" muted playsinline></video>
            <div id="preview-subtitle"></div>
          </div>
        </div>

      </div>

      <!-- Draggable resize handle -->
      <div class="resize-handle" id="previewResizeHandle">
        <div class="resize-handle-bar"></div>
      </div>

      <!-- Player controls (52px fixed) -->
      <div class="player-controls">
