        <div class="info-pill"><span class="pill-icon">🔒</span><span>Audio never uploaded to any server</span></div>
        <div class="info-pill"><span class="pill-icon">∞</span><span>No file size or length limits</span></div>
      </div>

      <input id="file-input" type="file"
        accept="audio/*,video/*,.mp3,.wav,.m4a,.ogg,.opus,.flac,.aac,.weba,.mp4,.mov,.webm,.avi,.mkv"
        style="position:fixed;left:-9999px;width:0;height:0;overflow:hidden;" />

      <div id="drop-zone" role="button" tabindex="0" aria-label="Upload audio or video file">
        <!-- Default state -->
        <div id="dz-default">
          <div class="dz-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="17 8 12 3 7 8"/>
              <line x1="12" y1="3" x2="12" y2="15"/>
            </svg>
          </div>
