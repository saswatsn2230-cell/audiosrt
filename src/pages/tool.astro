      const delta      = e.clientY - startY;
      const colH       = rightColEl.getBoundingClientRect().height;
      const newH       = Math.min(colH - 120, Math.max(120, startH + delta));
      previewContainer.style.height = newH + 'px';
      previewContainer.style.flex   = 'none';
    });
    document.addEventListener('mouseup', () => {
      if (!isResizing) return;
      isResizing = false;
      resizeHandle.classList.remove('dragging');
      document.body.style.cursor     = '';
      document.body.style.userSelect = '';
    });
  }

  // ── FIX 1 — smart object-fit based on ratio match ─────────────────────────
  function updateVideoFit() {
    if (!videoPreviewEl || !videoPreviewEl.videoWidth) return;
    const videoRatio  = videoPreviewEl.videoWidth / videoPreviewEl.videoHeight;
    const canvasRatio = canvasSizeEl.value === '9/16' ? 9 / 16 : 16 / 9;
    const match = Math.abs(videoRatio - canvasRatio) < 0.05;
    videoPreviewEl.style.objectFit = match ? 'cover' : 'contain';
  }
  videoPreviewEl.addEventListener('loadedmetadata', updateVideoFit);

  // ── Video transform: scale (10–500%) + X/Y position, slider ↔ number input
  const videoScaleSlider = document.getElementById('video-scale');
  const videoScaleNum    = document.getElementById('video-scale-num');
  const videoPosXSlider  = document.getElementById('video-pos-x');
  const videoPosXNum     = document.getElementById('video-pos-x-num');
  const videoPosYSlider  = document.getElementById('video-pos-y');
  const videoPosYNum     = document.getElementById('video-pos-y-num');

  let vidScale = 100, vidX = 0, vidY = 0;

  function applyVideoTransform() {
    if (!videoPreviewEl) return;
    videoPreviewEl.style.transform       = `scale(${vidScale / 100}) translate(${vidX}px, ${vidY}px)`;
    videoPreviewEl.style.transformOrigin = 'center center';
  }

  function clamp(v, lo, hi) { return Math.min(hi, Math.max(lo, isNaN(v) ? lo : v)); }

  // Track which modifier keys are held for precision mode
  let precisionKey = false;
  document.addEventListener('keydown', e => { if (e.ctrlKey || e.metaKey) precisionKey = true; });
  document.addEventListener('keyup',   e => { if (!e.ctrlKey && !e.metaKey) precisionKey = false; });

  function wirePair(slider, numInput, lo, hi, set) {
    let prevVal = parseInt(slider.value) || 0;
    slider.addEventListener('input', () => {
      let v = clamp(parseInt(slider.value), lo, hi);
      if (precisionKey) {
        // Precision mode: allow only ±1 step from last committed value
        v = clamp(prevVal + Math.sign(v - prevVal), lo, hi);
        slider.value = v; // snap slider thumb back to precision value
      }
      prevVal = v;
      set(v); numInput.value = v; applyVideoTransform();
    });
    numInput.addEventListener('input', () => {
      const v = clamp(parseInt(numInput.value), lo, hi);
      set(v); prevVal = v;
      slider.value = clamp(v, parseInt(slider.min), parseInt(slider.max));
      applyVideoTransform();
    });
    numInput.addEventListener('blur', () => {
      const v = clamp(parseInt(numInput.value), lo, hi);
      numInput.value = v; set(v); prevVal = v;
      slider.value = clamp(v, parseInt(slider.min), parseInt(slider.max));
      applyVideoTransform();
    });
  }

  wirePair(videoScaleSlider, videoScaleNum,  10, 500, v => { vidScale = v; });
  wirePair(videoPosXSlider,  videoPosXNum, -500, 500, v => { vidX = v; });
  wirePair(videoPosYSlider,  videoPosYNum, -500, 500, v => { vidY = v; });
  applyVideoTransform();

  // ── Caption templates ─────────────────────────────────────────────────────
  const TEMPLATES = [
    { name: 'Classic White', font: 'Arial',       color: '#FFFFFF', bold: false, shadow: false, stroke: false, fontSize: 20, vpos: 85 },
    { name: 'YouTube Bold',  font: 'Arial',       color: '#FFFFFF', bold: true,  shadow: false, stroke: true,  fontSize: 22, vpos: 85 },
    { name: 'TikTok Viral',  font: 'Arial',       color: '#FFFC00', bold: true,  shadow: false, stroke: true,  fontSize: 24, vpos: 80 },
    { name: 'Podcast Clean', font: 'Inter',       color: '#1D1D1F', bold: false, shadow: false, stroke: false, fontSize: 18, vpos: 85 },
    { name: 'Netflix Style', font: 'Arial',       color: '#FFFFFF', bold: true,  shadow: true,  stroke: false, fontSize: 22, vpos: 90 },
    { name: 'Bold Impact',   font: 'Impact',      color: '#FFFFFF', bold: false, shadow: false, stroke: true,  fontSize: 26, vpos: 85 },
    { name: 'Minimal Modern',font: 'Inter',       color: '#E5E5EA', bold: false, shadow: false, stroke: false, fontSize: 16, vpos: 85 },
    { name: 'Neon Glow',     font: 'Arial',       color: '#00FFAA', bold: true,  shadow: true,  stroke: false, fontSize: 22, vpos: 85 },
    { name: 'Typewriter',    font: 'Courier New', color: '#FFFFFF', bold: false, shadow: false, stroke: false, fontSize: 18, vpos: 85 },
    { name: 'Gradient Pop',  font: 'Arial',       color: '#FF6B6B', bold: true,  shadow: true,  stroke: false, fontSize: 24, vpos: 80 },
  ];

  let activeTemplate = null;

  function applyTemplate(tpl) {
    activeTemplate = tpl.name;
    subtitleSettings.font     = tpl.font;
    subtitleSettings.color    = tpl.color;
    subtitleSettings.bold     = tpl.bold;
    subtitleSettings.shadow   = tpl.shadow;
    subtitleSettings.stroke   = tpl.stroke;
    subtitleSettings.fontSize = tpl.fontSize;
    subtitleSettings.vpos     = tpl.vpos;
    fontSelect.value = tpl.font;
    textColor.value  = tpl.color;
    colorHex.textContent = tpl.color.toUpperCase();
    fontsizeSlider.value = tpl.fontSize;
    fontsizeVal.textContent = tpl.fontSize + 'px';
    vposSlider.value = tpl.vpos;
    [boldBtn, shadowBtn, strokeBtn].forEach((btn, i) => {
      const active = [tpl.bold, tpl.shadow, tpl.stroke][i];
      btn.classList.toggle('active', active);
    });
    applyPreviewStyles();
    templateGrid.querySelectorAll('.tpl-card').forEach(c => {
      c.classList.toggle('ring-2', c.dataset.tpl === activeTemplate);
      c.classList.toggle('ring-apple-blue', c.dataset.tpl === activeTemplate);
    });
  }

  function renderTemplates() {
    if (templateGrid.childElementCount) return;
    TEMPLATES.forEach(tpl => {
      const card = document.createElement('button');
      card.type = 'button';
      card.dataset.tpl = tpl.name;
      card.className = 'tpl-card text-left px-3 py-2 rounded-xl border border-apple-light-gray bg-white hover:bg-gray-50 transition-colors';
      card.innerHTML = `<span class="block text-xs font-medium text-apple-dark leading-tight">${tpl.name}</span>
        <span class="block text-xs text-apple-gray mt-0.5">${tpl.font} · ${tpl.bold ? 'Bold' : 'Regular'}${tpl.stroke ? ' · Stroke' : ''}${tpl.shadow ? ' · Shadow' : ''}</span>`;
      card.addEventListener('click', () => applyTemplate(tpl));
      templateGrid.appendChild(card);
    });
  }

  // ── Timeline ──────────────────────────────────────────────────────────────
  let tlCtx = null;
  let tlDraggingPlayhead = false;
  let tlDraggingTrimIn   = false;
  let tlDraggingTrimOut  = false;
  let tlRegionDragStart  = null;

  function tlDuration() { return isFinite(audioPlayer.duration) ? audioPlayer.duration : 0; }
  function tlPxToSec(px) { const w = timelineWrap.offsetWidth; return w > 0 ? (px / w) * tlDuration() : 0; }
  function tlSecToPct(sec) { const d = tlDuration(); return d > 0 ? (sec / d) * 100 : 0; }
  function tlFormatShort(s) {
    if (!isFinite(s)) return '—';
    const m = Math.floor(s / 60), ss = Math.floor(s % 60);
    return `${m}:${String(ss).padStart(2,'0')}`;
  }

  function drawTimeline() {
    if (!tlCtx) return;
    const w = timelineCanvas.width, h = timelineCanvas.height;
    tlCtx.clearRect(0, 0, w, h);
    const dur = tlDuration();
    if (!dur) return;

    const inPx  = (trimInSec / dur) * w;
    const outPx = Math.min((Math.min(trimOutSec, dur) / dur) * w, w);
    tlCtx.fillStyle = 'rgba(255,255,255,0.05)';
    tlCtx.fillRect(0, 0, inPx, h);
    tlCtx.fillRect(outPx, 0, w - outPx, h);

    const segH = h * 0.35;
    displaySegments.forEach(seg => {
      const x1 = (seg.start / dur) * w;
      const x2 = (seg.end   / dur) * w;
      tlCtx.fillStyle = 'rgba(99,102,241,0.5)';
      tlCtx.fillRect(x1, h - segH, Math.max(1, x2 - x1 - 1), segH);
    });

    const tickInterval = dur > 600 ? 60 : dur > 120 ? 30 : 10;
    tlCtx.fillStyle = 'rgba(100,100,100,0.4)';
    for (let t = tickInterval; t < dur; t += tickInterval) {
      const x = (t / dur) * w;
      tlCtx.fillRect(Math.round(x), 0, 1, 6);
    }
  }

  function updateTrimLabels() {
    const dur = tlDuration();
    trimInSec  = Math.max(0, Math.min(trimInSec, dur));
    trimOutSec = Math.max(trimInSec + 0.1, Math.min(trimOutSec, dur));
    tlTrimInLabel.textContent   = `In: ${tlFormatShort(trimInSec)}`;
    tlTrimOutLabel.textContent  = `Out: ${tlFormatShort(Math.min(trimOutSec, dur))}`;
    tlDurationLabel.textContent = `Duration: ${tlFormatShort(Math.min(trimOutSec, dur) - trimInSec)}`;
    trimInEl.style.left   = tlSecToPct(trimInSec)  + '%';
    trimOutEl.style.right = (100 - tlSecToPct(Math.min(trimOutSec, tlDuration()))) + '%';
    timelinePlayhead.style.left = tlSecToPct(audioPlayer.currentTime) + '%';
    drawTimeline();
  }

  function initTimeline() {
    const dpr = window.devicePixelRatio || 1;
    timelineCanvas.width  = timelineWrap.offsetWidth  * dpr;
    timelineCanvas.height = timelineWrap.offsetHeight * dpr;
    tlCtx = timelineCanvas.getContext('2d');
    tlCtx.scale(dpr, dpr);
    trimInSec  = 0;
    trimOutSec = tlDuration();
    updateTrimLabels();
  }

  audioPlayer.addEventListener('timeupdate', () => {
    timelinePlayhead.style.left = tlSecToPct(audioPlayer.currentTime) + '%';
  });
  audioPlayer.addEventListener('loadedmetadata', () => {
    if (!stepTimeline.classList.contains('hidden')) {
      trimOutSec = audioPlayer.duration;
      updateTrimLabels();
    }
  });

  function getTimelineX(e) {
    const rect = timelineWrap.getBoundingClientRect();
    return Math.max(0, Math.min((e.clientX - rect.left), rect.width));
  }

  timelineWrap.addEventListener('pointerdown', (e) => {
    const x = getTimelineX(e);
    const w = timelineWrap.offsetWidth;
    const inPx  = (trimInSec / tlDuration()) * w;
    const outPx = (Math.min(trimOutSec, tlDuration()) / tlDuration()) * w;
    if (Math.abs(x - inPx) <= 10) {
      tlDraggingTrimIn = true;
    } else if (Math.abs(x - outPx) <= 10) {
      tlDraggingTrimOut = true;
    } else {
      tlDraggingPlayhead = true;
      tlRegionDragStart = tlPxToSec(x);
      const sec = tlPxToSec(x);
      if (isFinite(audioPlayer.duration)) audioPlayer.currentTime = sec;
      timelineRegion.style.display = 'none';
      tlRegionStart = null; tlRegionEnd = null;
    }
    timelineWrap.setPointerCapture(e.pointerId);
    e.preventDefault();
  });

  timelineWrap.addEventListener('pointermove', (e) => {
    const x   = getTimelineX(e);
    const sec = tlPxToSec(x);
    const dur = tlDuration();
    if (tlDraggingTrimIn) {
      trimInSec = Math.max(0, Math.min(sec, trimOutSec - 0.1));
      updateTrimLabels();
    } else if (tlDraggingTrimOut) {
      trimOutSec = Math.max(trimInSec + 0.1, Math.min(sec, dur));
      updateTrimLabels();
    } else if (tlDraggingPlayhead) {
      if (isFinite(dur)) audioPlayer.currentTime = Math.max(0, Math.min(sec, dur));
      if (tlRegionDragStart !== null && Math.abs(sec - tlRegionDragStart) > 0.2) {
        tlRegionStart = Math.min(sec, tlRegionDragStart);
        tlRegionEnd   = Math.max(sec, tlRegionDragStart);
        const l = tlSecToPct(tlRegionStart), r = tlSecToPct(tlRegionEnd);
        timelineRegion.style.display = 'block';
        timelineRegion.style.left  = l + '%';
        timelineRegion.style.width = (r - l) + '%';
      }
    }
  });

  timelineWrap.addEventListener('pointerup', () => {
    tlDraggingPlayhead = false;
    tlDraggingTrimIn   = false;
    tlDraggingTrimOut  = false;
  });

  timelineSplitBtn.addEventListener('click', () => {
    const t = audioPlayer.currentTime;
    const idx = displaySegments.findIndex(s => t >= s.start && t < s.end);
    if (idx < 0) return;
    const offset = Math.round((t - displaySegments[idx].start) /
      Math.max(0.001, displaySegments[idx].end - displaySegments[idx].start) *
      displaySegments[idx].text.length);
    splitDisplayAt(idx, offset);
    drawTimeline();
  });

  timelineDeleteBtn.addEventListener('click', () => {
    if (tlRegionStart === null || tlRegionEnd === null) {
      alert('Drag on the timeline to select a region first.');
      return;
    }
    if (!confirm(`Delete all subtitle segments between ${tlFormatShort(tlRegionStart)} and ${tlFormatShort(tlRegionEnd)}?`)) return;
    logicalSegments = logicalSegments.filter(s => !(s.start >= tlRegionStart && s.end <= tlRegionEnd));
    rebuildDisplaySegments();
    renderTranscript();
    refreshPreviewText(audioPlayer.currentTime);
    tlRegionStart = null; tlRegionEnd = null;
    timelineRegion.style.display = 'none';
    drawTimeline();
  });

  // ── Init ──────────────────────────────────────────────────────────────────
  // Wire renderTranscript into global accessor now that it's defined
  window._audiosrt.renderTranscript = () => renderTranscript();

  // ── Cloud project restore (Starter/Pro users, cross-device) ──────────────
  async function checkCloudProjects(userId, accessToken) {
    const { loadProjectsFromCloud } = await import('/src/lib/sync.js');
    const cloudProjects = await loadProjectsFromCloud(userId, accessToken);
    if (!cloudProjects.length) return false;

    const section = document.getElementById('recent-projects-section');
    const grid    = document.getElementById('recent-projects-grid');
    if (!section || !grid) return false;

    let added = 0;
    cloudProjects.forEach(project => {
      let parsed = {};
      try { parsed = JSON.parse(project.subtitle_data || '{}'); } catch(e) {}
      const segments = parsed.segments || [];
      if (!segments.length) return;

      const card = document.createElement('div');
      card.style.cssText = 'display:flex;align-items:center;justify-content:space-between;gap:10px;background:#FFFFFF;border:0.5px solid #E5E5E7;border-radius:12px;padding:12px 14px;';
      card.innerHTML = `
        <div style="display:flex;align-items:center;gap:10px;flex:1;min-width:0;">
          <div style="width:34px;height:34px;background:#EEEFFD;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:18px;">☁️</div>
          <div>
            <div style="font-size:12px;font-weight:500;color:#1D1D1F;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:180px;">${project.project_name || 'Untitled'}</div>
            <div style="font-size:10px;color:#6E6E73;">${segments.length} lines · Synced from cloud</div>
            <div style="font-size:10px;color:#6366F1;margin-top:2px;">📎 Re-link your media file to continue</div>
          </div>
        </div>
        <label style="background:#6366F1;color:#fff;border-radius:7px;padding:6px 12px;font-size:11px;font-weight:500;cursor:pointer;font-family:Inter,sans-serif;white-space:nowrap;flex-shrink:0;">
          Link File
          <input type="file" accept="audio/*,video/*" style="display:none;">
        </label>
      `;

      const fi = card.querySelector('input[type="file"]');
      fi?.addEventListener('change', async (e) => {
        const file = e.target.files?.[0];
        if (!file) return;

        window._audiosrt.setSegments(segments);
        selectedFile = file;
        await AudioSRTDB.saveProject(file, segments).catch(() => {});
        updatePreviewControlsVisibility(file);
        updateExportOptions();
        updateNoiseReductionVisibility();

        const blobUrl = URL.createObjectURL(file);
        const isVid = file.type.startsWith('video/');
        if (isVid) {
          videoPreviewEl.src = blobUrl;
          videoPreviewEl.classList.remove('hidden');
          isVideo = true;
        }
        audioPlayer.src = blobUrl;

        // Show editor
        const tc = document.getElementById('tool-cols');
        if (tc) tc.classList.remove('hidden');
        [transcriptArea, stepSettings, stepExport, stepTimeline].forEach(el => el?.classList.remove('hidden'));
        const uploadScreen = document.getElementById('upload-screen');
        if (uploadScreen) uploadScreen.style.display = 'none';

        requestAnimationFrame(() => {
          const editPill = document.getElementById('tb-step-edit');
          if (editPill) { editPill.style.background = '#6366F1'; editPill.style.color = '#fff'; editPill.style.borderRadius = '20px'; }
        });

        renderTranscript();
        applyPreviewStyles();
        refreshPreviewText(0);
      });

      grid.insertBefore(card, grid.firstChild);
      added++;
    });

    if (added > 0) section.style.display = 'block';
    return added > 0;
  }

  // Restore session if returning from auth, otherwise show recent project card
  (async () => {
    const restored = await checkAndRestoreSession();
    if (restored) {
      renderTranscript();
      applyPreviewStyles();
      refreshPreviewText(0);
    } else {
      await renderRecentProjects();
      // If Starter/Pro user and has no local session, check cloud
      const userId = window._audiosrt?.userId;
      const accessToken = window._audiosrt?.accessToken;
      if (userId && accessToken) {
        await checkCloudProjects(userId, accessToken);
      }
    }
  })();

  // Restore transcription state after auth redirect
  function checkRestoredState() {
    const restored = new URLSearchParams(window.location.search).get('restored');
    const savedSegments = sessionStorage.getItem('audiosrt_pending_segments');
    if (!restored || !savedSegments) return;
    try {
      const segs = JSON.parse(savedSegments);
      if (!segs || !segs.length) return;
      window._audiosrt.setSegments(segs);
      window._audiosrt.showEditor();
      renderTranscript();
      const msg = document.createElement('div');
      msg.style.cssText = 'position:fixed;top:52px;left:50%;transform:translateX(-50%);background:#EEEFFD;color:#6366F1;border:0.5px solid #C7C8F9;padding:8px 16px;border-radius:8px;font-size:12px;z-index:9999;font-family:Inter,sans-serif;white-space:nowrap;';
      msg.textContent = '✓ Account created! Your transcript has been restored.';
      document.body.appendChild(msg);
      setTimeout(() => msg.remove(), 4000);
      sessionStorage.removeItem('audiosrt_pending_segments');
      sessionStorage.removeItem('audiosrt_pending_redirect');
      window.history.replaceState({}, '', '/tool');
    } catch(e) {}
  }
  checkRestoredState();

  applyPreviewStyles();
})();
</script>

<script>
// ── UI layer: progress ring, upload↔editor, topbar, drop zone state ──
(function () {
  const circumference = 2 * Math.PI * 52; // r=52 → ~326.7

  // Progress ring — smooth interpolation + stall detection
  const ring = document.getElementById('progress-ring-circle');
  const bar  = document.getElementById('progress-bar');
  if (ring && bar) {
    let ringPct = 0, ringRaf = null, stallTimer = null;

    function animateRing(targetPct) {
      const startPct  = ringPct;
      const startOff  = circumference * (1 - startPct);
      const endOff    = circumference * (1 - targetPct);
      const t0        = performance.now();
      const dur       = 400;
      if (ringRaf) cancelAnimationFrame(ringRaf);
      function step(now) {
        const p = Math.min((now - t0) / dur, 1);
        const e = p < 0.5 ? 2*p*p : -1+(4-2*p)*p;
        ring.style.strokeDashoffset = String(startOff + (endOff - startOff) * e);
        if (p < 1) ringRaf = requestAnimationFrame(step);
        else { ringPct = targetPct; ringRaf = null; }
      }
      ringRaf = requestAnimationFrame(step);
      // Reset stall detection
      ring.classList.remove('ring-stalling');
      if (stallTimer) clearTimeout(stallTimer);
      if (targetPct > 0 && targetPct < 1) {
        stallTimer = setTimeout(() => ring.classList.add('ring-stalling'), 3000);
      }
    }

    new MutationObserver(() => {
      const pct = parseFloat(bar.style.width) / 100 || 0;
      animateRing(pct);
      const card = document.getElementById('prog-card');
      if (card) card.classList.toggle('done', pct >= 1);
    }).observe(bar, { attributes: true, attributeFilter: ['style'] });
  }

  // FIX 2 — Rotating feature messages
  const featureMsgs = [
    "Processing entirely on your device — zero uploads",
    "Export frame-accurate SRT subtitles for any NLE",
    "Download Premiere Pro JSON for text-based editing",
    "Edit and correct your transcript word by word",
    "Choose from animated caption templates",
    "Export clean plain text for blog posts or show notes",
    "Your audio and video never leave your device",
    "Split, trim and export exactly the clip you need"
  ];
  let msgIdx = 0, msgTimer = null;
  function startMessageRotation() {
    const el = document.querySelector('.feature-message');
    if (!el) return;
    msgIdx = 0;
    el.textContent = featureMsgs[0];
    el.classList.remove('fade-out'); el.classList.add('fade-in');
    if (msgTimer) clearInterval(msgTimer);
    msgTimer = setInterval(() => {
      el.classList.remove('fade-in'); el.classList.add('fade-out');
      setTimeout(() => {
        msgIdx = (msgIdx + 1) % featureMsgs.length;
        el.textContent = featureMsgs[msgIdx];
        el.classList.remove('fade-out'); el.classList.add('fade-in');
      }, 400);
    }, 5000);
  }
  function stopMessageRotation() { if (msgTimer) { clearInterval(msgTimer); msgTimer = null; } }

  // Watch progress-area visibility to start/stop rotation
  const progArea = document.getElementById('progress-area');
  if (progArea) {
    new MutationObserver(() => {
      if (!progArea.classList.contains('hidden')) startMessageRotation();
      else stopMessageRotation();
    }).observe(progArea, { attributes: true, attributeFilter: ['class'] });
  }

  // Upload screen ↔ editor (MutationObserver on tool-cols.hidden class)
  const toolCols    = document.getElementById('tool-cols');
  const uploadScreen = document.getElementById('upload-screen');
  const leftEmpty   = document.getElementById('left-empty');
  const transcriptArea = document.getElementById('transcript-area');
  const transcriptLines = document.getElementById('transcript-lines');

  // Step pill elements
  const stepUpload    = document.getElementById('tb-step-upload');
  const stepTranscribe = document.getElementById('tb-step-transcribe');
  const stepEdit      = document.getElementById('tb-step-edit');
  const stepExportPill = document.getElementById('tb-step-export');
  const progressArea  = document.getElementById('progress-area');

  function setActiveStep(step) {
    [stepUpload, stepTranscribe, stepEdit, stepExportPill].forEach(el => el && el.classList.remove('active'));
    const target = { upload: stepUpload, transcribe: stepTranscribe, edit: stepEdit, export: stepExportPill }[step];
    if (target) target.classList.add('active');
  }

  const newFileBtn = document.getElementById('new-file-btn');
  if (newFileBtn) {
    newFileBtn.addEventListener('click', async () => {
      if (!confirm('Start with a new file? Your current transcription will be cleared.')) return;
      await AudioSRTDB.clearAll().catch(() => {});
      ['audiosrt_filename','audiosrt_pending_segments','audiosrt_pending_redirect'].forEach(k => sessionStorage.removeItem(k));
      window.location.href = '/tool';
    });
  }

  if (toolCols && uploadScreen) {
    new MutationObserver(() => {
      const editorOpen = !toolCols.classList.contains('hidden');
      uploadScreen.style.display = editorOpen ? 'none' : '';
      if (newFileBtn) newFileBtn.style.display = editorOpen ? 'inline-flex' : 'none';
    }).observe(toolCols, { attributes: true, attributeFilter: ['class'] });
  }

  if (progressArea) {
    new MutationObserver(() => {
      const transcribing = !progressArea.classList.contains('hidden');
      const editorOpen   = toolCols && !toolCols.classList.contains('hidden');
      if (transcribing) setActiveStep('transcribe');
      else if (editorOpen) setActiveStep('edit');
      else setActiveStep('upload');
    }).observe(progressArea, { attributes: true, attributeFilter: ['class'] });
  }

  if (toolCols) {
    new MutationObserver(() => {
      const editorOpen = !toolCols.classList.contains('hidden');
      if (!editorOpen) setActiveStep('upload');
    }).observe(toolCols, { attributes: true, attributeFilter: ['class'] });
  }

  // Topbar filename
  const fileNameEl      = document.getElementById('file-name');
  const topbarFilename  = document.getElementById('topbar-filename');
  if (fileNameEl && topbarFilename) {
    new MutationObserver(() => {
      const name = fileNameEl.textContent?.trim() || '';
      topbarFilename.textContent = name;
      topbarFilename.style.display = name ? '' : 'none';
    }).observe(fileNameEl, { childList: true, characterData: true, subtree: true });
  }

  // Segment count badge
  const segCount = document.getElementById('segment-count');
  if (transcriptLines && segCount) {
    new MutationObserver(() => {
      const count = transcriptLines.children.length;
      segCount.textContent = count > 0 ? count + ' segments' : '';
      segCount.style.display = count > 0 ? '' : 'none';
    }).observe(transcriptLines, { childList: true });
  }

  // Left panel empty state
  if (transcriptArea && leftEmpty) {
    new MutationObserver(() => {
      const visible = !transcriptArea.classList.contains('hidden');
      leftEmpty.style.display = visible ? 'none' : '';
    }).observe(transcriptArea, { attributes: true, attributeFilter: ['class'] });
  }

  // Drop zone has-file state
  const dropZone = document.getElementById('drop-zone');
  const fileInfo = document.getElementById('file-info');
  if (dropZone && fileInfo) {
    new MutationObserver(() => {
      dropZone.classList.toggle('has-file', !fileInfo.classList.contains('hidden'));
    }).observe(fileInfo, { attributes: true, attributeFilter: ['class'] });
  }

  // Static info line below Transcribe button
  const estTimeEl = document.getElementById('est-time');
  if (estTimeEl) {
    estTimeEl.textContent = 'Processing speed depends on your device specs · Desktop app is 15–20× faster';
  }

  // Close export modal on backdrop click
  const exportModal = document.getElementById('export-modal');
  if (exportModal) {
    exportModal.addEventListener('click', (e) => {
      if (e.target === exportModal) exportModal.classList.add('hidden');
    });
  }

  // Close export modal on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      exportModal && exportModal.classList.add('hidden');
    }
  });
})();
</script>

<script>
// ── Editor: Tabs + Sidebar + Para view + Word highlight + Waveform + Shortcuts ──
(function () {
  const audioEl    = document.getElementById('audio-player');
  const paraView   = document.getElementById('para-view');
  const subsView   = document.getElementById('subs-view');
  const paraText   = document.getElementById('para-text');
  const tabTr      = document.getElementById('tab-transcript');
  const tabSb      = document.getElementById('tab-subtitles');
  const tlLines    = document.getElementById('transcript-lines');
  const wfCanvas   = document.getElementById('waveform-canvas');
  const wfPH       = document.getElementById('wf-playhead');
  const wfWrap     = document.querySelector('.wf-canvas-wrap');
  const wfSplitBt  = document.getElementById('wf-split-btn');
  const wfUndoBt   = document.getElementById('wf-undo-btn');
  const wfZoomInB  = document.getElementById('wf-zoom-in');
  const wfZoomOutB = document.getElementById('wf-zoom-out');
  const wfZoomLbl  = document.getElementById('wf-zoom-label');
  const wfTimeLbl  = document.getElementById('wf-time-label');
  const sidebar    = document.getElementById('editor-sidebar');
  const sbToggle   = document.getElementById('sidebar-toggle');
  const sbStyle    = document.getElementById('sb-style');
  const previewBox = document.getElementById('preview-box');

  if (!audioEl) return;

  // ── Sidebar ───────────────────────────────────────────────────────────────
  if (sidebar && sbToggle) {
    sbToggle.addEventListener('click', () => {
      const exp = sidebar.classList.toggle('expanded');
      sbToggle.title = exp ? 'Collapse sidebar' : 'Expand sidebar';
      const chevron = sbToggle.querySelector('svg');
      if (chevron) chevron.style.transform = exp ? 'rotate(180deg)' : '';
    });
  }
  if (sbStyle) {
    sbStyle.addEventListener('click', () => {
      const rect = sbStyle.getBoundingClientRect();
      const tip  = document.createElement('div');
      tip.textContent = 'Style panel — coming soon';
      tip.style.cssText = 'position:fixed;left:' + (rect.right + 8) + 'px;top:' + (rect.top + rect.height / 2 - 14) + 'px;'
        + 'background:#1D1D1F;color:#fff;font-size:11px;padding:5px 10px;border-radius:6px;z-index:9999;pointer-events:none;white-space:nowrap;';
      document.body.appendChild(tip);
      setTimeout(() => tip.remove(), 1800);
    });
  }

  // ── Tabs ──────────────────────────────────────────────────────────────────
  let activeTab = 'transcript'; // track for word highlighting
  if (tabTr && tabSb && paraView && subsView) {
    tabTr.addEventListener('click', () => {
      activeTab = 'transcript';
      paraView.style.display = '';
      subsView.style.display = 'none';
      tabTr.classList.add('active');
      tabSb.classList.remove('active');
      rebuildPara(); // FIX 2 — sync on tab switch
    });
    tabSb.addEventListener('click', () => {
      activeTab = 'subtitles';
      paraView.style.display = 'none';
      subsView.style.display = '';
      tabSb.classList.add('active');
      tabTr.classList.remove('active');
    });
  }

  // ── Canvas size → resize preview-screen (1920×1080 / 1080×1920) ──────────
  const canvasSel    = document.getElementById('canvas-size');
  const previewScreen = previewBox;
  // Landscape: 16:9 (1920×1080) — width fills container, height auto
  // Portrait:  9:16 (1080×1920) — height fills container, width auto
  function updateCanvasSize(val) {
    if (!previewScreen) return;
    if (val === '9/16') {
      previewScreen.style.aspectRatio = '9/16';
      previewScreen.style.width       = 'auto';
      previewScreen.style.height      = '100%';
    } else {
      previewScreen.style.aspectRatio = '16/9';
      previewScreen.style.width       = '100%';
      previewScreen.style.height      = 'auto';
    }
  }
  if (canvasSel) {
    canvasSel.addEventListener('change', () => updateCanvasSize(canvasSel.value));
    updateCanvasSize(canvasSel.value);
  }

  // ── Preview BG swatches ───────────────────────────────────────────────────
  document.querySelectorAll('.pv-bg-swatch').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.pv-bg-swatch').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      if (previewBox) previewBox.style.background = btn.dataset.pvBg;
    });
  });

  // ── Paragraph view ────────────────────────────────────────────────────────
  function parseTs(s) {
    if (!s) return 0;
    const parts = s.replace(',', '.').split(':');
    if (parts.length === 3) return +parts[0] * 3600 + +parts[1] * 60 + +parts[2];
    if (parts.length === 2) return +parts[0] * 60 + +parts[1];
    return parseFloat(s) || 0;
  }

  let rebuilding = false;
  let paraEditing = false;
  let isEditingTranscript = false;
  function rebuildPara() {
    if (!tlLines || !paraText) return;
    rebuilding = true;
    const rows = tlLines.children;
    paraText.innerHTML = '';
    if (!rows.length) { rebuilding = false; return; }
    const segs = [];
    for (const row of rows) {
      const tsIn = row.querySelector('input[type="text"]');
      const txEl = row.querySelector('[contenteditable]');
      if (!tsIn || !txEl) continue;
      segs.push({ start: parseTs(tsIn.value), text: txEl.textContent || '' });
    }
    segs.forEach((seg, si) => {
      const end   = si < segs.length - 1 ? segs[si + 1].start : seg.start + 10;
      const words = seg.text.trim().split(/\s+/).filter(Boolean);
      if (!words.length) return;
      const wDur  = Math.max(0.01, (end - seg.start) / words.length);
      words.forEach((w, wi) => {
        const span = document.createElement('span');
        span.className        = 'word';
        span.textContent      = w;
        span.dataset.start    = String(seg.start + wi * wDur);
        span.dataset.end      = String(seg.start + (wi + 1) * wDur);
        span.dataset.row          = String(si);
        span.dataset.segmentIndex = String(si);
        span.dataset.wordIndex    = String(wi);
        span.addEventListener('click', () => {
          const t = parseFloat(span.dataset.start);
          if (isFinite(t)) audioEl.currentTime = t;
        });
        paraText.appendChild(span);
        paraText.appendChild(document.createTextNode(' '));
      });
    });
    rebuilding = false;
    // eslint-disable-next-line no-console
    console.log('[word-highlight] Built', paraText.querySelectorAll('.word[data-start]').length, 'word spans');
  }

  if (tlLines) {
    new MutationObserver(() => { if (!rebuilding && !paraEditing && !isEditingTranscript) rebuildPara(); })
      .observe(tlLines, { childList: true, subtree: true, characterData: true });
  }

  // ── FIX 2 — Sync para-text edits back to transcript-lines ────────────────
  if (paraText && tlLines) {
    paraText.addEventListener('input', () => {
      if (rebuilding) return;
      paraEditing = true;
      // Group word spans by data-row (segment index)
      const byRow = {};
      paraText.querySelectorAll('.word[data-row]').forEach(span => {
        const row = span.dataset.row;
        if (!byRow[row]) byRow[row] = [];
        byRow[row].push(span.textContent.trim());
      });
      // Update each transcript-lines row's contenteditable
      Object.entries(byRow).forEach(([rowIdx, words]) => {
        const tlRow = tlLines.children[parseInt(rowIdx)];
        if (!tlRow) return;
        const txEl = tlRow.querySelector('[contenteditable]');
        if (!txEl) return;
        const newText = words.join(' ');
        if (txEl.textContent !== newText) {
          txEl.textContent = newText;
          txEl.dispatchEvent(new Event('input', { bubbles: true }));
        }
      });
      paraEditing = false;
    });
  }

  // ── Word highlighting — FIX 3 + cursor-jump fix ──────────────────────────
  let lastActiveWord = null;

  // Track editing state so timeupdate never touches DOM while user types
  if (paraText) {
    paraText.addEventListener('focus', () => { isEditingTranscript = true; });
    paraText.addEventListener('blur',  () => {
      isEditingTranscript = false;
      // Trigger one highlight pass after editing ends
      highlightWord();
    });
    // Also treat any click inside para-text as editing
    paraText.addEventListener('mousedown', () => { isEditingTranscript = true; });
  }

  function highlightWord() {
    // Skip entirely while user is editing — never touch DOM during text input
    if (isEditingTranscript) return;
    // Only run when transcript tab is visible
    if (!paraText || !paraView || paraView.style.display === 'none') return;
    const t = audioEl.currentTime;
    const allWords = paraText.querySelectorAll('.word[data-start]');
    if (!allWords.length) return;
    let found = null;
    for (const w of allWords) {
      w.classList.remove('word-active');
      const s = parseFloat(w.getAttribute('data-start'));
      const e = parseFloat(w.getAttribute('data-end'));
      if (t >= s && t < e) found = w;
    }
    if (found) {
      found.classList.add('word-active');
      if (found !== lastActiveWord) {
        found.scrollIntoView({ behavior:'smooth', block:'nearest', inline:'nearest' });
      }
    }
    lastActiveWord = found;
  }
  audioEl.addEventListener('timeupdate', () => {
    // eslint-disable-next-line no-console
    console.log('[word-highlight] timeupdate:', audioEl.currentTime.toFixed(2));
    highlightWord();
  });
  audioEl.addEventListener('seeked', highlightWord);

  // ── Waveform state ────────────────────────────────────────────────────────
  let wfPeaks = null, wfCtx = null, wfDur = 0;
  let wfZoom = 1, wfScrollOff = 0;
  let wfRaf = null, wfDragging = false;

  // ── Waveform zoom ─────────────────────────────────────────────────────────
  function setZoom(level) {
    wfZoom = Math.max(1, Math.min(32, level));
    const viewDur = wfDur / wfZoom;
    wfScrollOff = Math.max(0, Math.min(audioEl.currentTime - viewDur / 2, wfDur - viewDur));
    if (wfZoomLbl) wfZoomLbl.textContent = wfZoom <= 1 ? '1×' : wfZoom + '×';
    drawWf();
  }
  function zoomIn()  { setZoom(wfZoom * 2); }
  function zoomOut() { setZoom(wfZoom / 2); }

  wfZoomInB  && wfZoomInB.addEventListener('click',  zoomIn);
  wfZoomOutB && wfZoomOutB.addEventListener('click', zoomOut);

  // ── Canvas sizing ─────────────────────────────────────────────────────────
  function initWfCanvas() {
    if (!wfWrap || !wfCanvas) return;
    const dpr  = devicePixelRatio || 1;
    const rect = wfWrap.getBoundingClientRect();
    if (!rect.width || !rect.height) return;
    wfCanvas.width  = rect.width  * dpr;
    wfCanvas.height = rect.height * dpr;
    wfCtx = wfCanvas.getContext('2d');
    wfCtx.scale(dpr, dpr);
  }

  // ── Draw waveform ─────────────────────────────────────────────────────────
  function drawWf() {
    if (!wfCtx || !wfWrap || !wfCanvas) return;
    const dpr = devicePixelRatio || 1;
    const W   = wfCanvas.width  / dpr;
    const H   = wfCanvas.height / dpr;
    wfCtx.clearRect(0, 0, W, H);
    if (!wfPeaks || !wfPeaks.length || !wfDur) { updateWfPH(); return; }

    const viewDur   = wfDur / wfZoom;
    const viewStart = Math.max(0, Math.min(wfScrollOff, wfDur - viewDur));
    const cur       = isFinite(audioEl.currentTime) ? audioEl.currentTime : 0;
    const playedPct = viewDur > 0 ? Math.max(0, Math.min((cur - viewStart) / viewDur, 1)) : 0;

    const nBars = Math.max(1, Math.floor(W / 3));
    for (let i = 0; i < nBars; i++) {
      const frac   = i / nBars;
      const sec    = viewStart + frac * viewDur;
      const pkFrac = sec / wfDur;
      const amp    = wfPeaks[Math.min(Math.floor(pkFrac * wfPeaks.length), wfPeaks.length - 1)] || 0;
      const bH     = Math.max(2, amp * H * 0.85);
      wfCtx.fillStyle = frac <= playedPct ? '#6366F1' : 'rgba(99,102,241,0.35)';
      wfCtx.fillRect(frac * W, (H - bH) / 2, 2, bH);
    }
    updateWfPH();
  }

  function updateWfPH() {
    if (!wfWrap || !wfPH) return;
    const viewDur   = wfDur / wfZoom;
    const viewStart = Math.max(0, wfScrollOff);
    const cur       = isFinite(audioEl.currentTime) ? audioEl.currentTime : 0;
    const pct       = viewDur > 0 ? Math.max(0, Math.min((cur - viewStart) / viewDur, 1)) : 0;
    wfPH.style.left = (pct * wfWrap.offsetWidth) + 'px';
    if (wfTimeLbl) {
      const m = Math.floor(cur / 60);
      const s = Math.floor(cur % 60);
      wfTimeLbl.textContent = m + ':' + String(s).padStart(2, '0');
    }
  }

  // ── RAF loop (plays audio) ────────────────────────────────────────────────
  function wfRafTick() {
    if (wfZoom > 1) {
      const viewDur = wfDur / wfZoom;
      const cur     = audioEl.currentTime;
      wfScrollOff   = Math.max(0, Math.min(cur - viewDur * 0.4, wfDur - viewDur));
    }
    drawWf();
    wfRaf = requestAnimationFrame(wfRafTick);
  }
  function startWfRaf() { if (!wfRaf) wfRaf = requestAnimationFrame(wfRafTick); }
  function stopWfRaf()  { if (wfRaf)  { cancelAnimationFrame(wfRaf); wfRaf = null; } }

  audioEl.addEventListener('play',   startWfRaf);
  audioEl.addEventListener('pause',  () => { stopWfRaf(); drawWf(); });
  audioEl.addEventListener('ended',  () => { stopWfRaf(); drawWf(); });
  audioEl.addEventListener('seeked', () => { if (audioEl.paused) drawWf(); });

  // ── Build waveform from blob ───────────────────────────────────────────────
  async function buildWaveform(src) {
    if (!src || !src.startsWith('blob:')) return;
    try {
      const resp  = await fetch(src);
      const buf   = await resp.arrayBuffer();
      const ctx   = new AudioContext();
      const dec   = await ctx.decodeAudioData(buf);
      ctx.close();
      wfDur = dec.duration;
      const ch   = dec.getChannelData(0);
      const bins = 1024;
      const step = Math.max(1, Math.floor(ch.length / bins));
      const peaks = new Float32Array(bins);
      for (let i = 0; i < bins; i++) {
        let pk = 0;
        for (let j = 0; j < step; j++) {
          const v = Math.abs(ch[i * step + j] || 0);
          if (v > pk) pk = v;
        }
        peaks[i] = pk;
      }
      let mx = 0.001;
      for (let i = 0; i < bins; i++) if (peaks[i] > mx) mx = peaks[i];
      for (let i = 0; i < bins; i++) peaks[i] /= mx;
      wfPeaks = peaks;
      wfZoom = 1; wfScrollOff = 0;
      if (wfZoomLbl) wfZoomLbl.textContent = '1×';
      initWfCanvas();
      drawWf();
    } catch (e) { console.warn('[waveform]', e); }
  }

  audioEl.addEventListener('loadstart', () => {
    wfPeaks = null; wfDur = 0; wfZoom = 1; wfScrollOff = 0;
    if (wfCtx && wfCanvas) {
      const dpr = devicePixelRatio || 1;
      wfCtx.clearRect(0, 0, wfCanvas.width / dpr, wfCanvas.height / dpr);
    }
    if (wfPH) wfPH.style.left = '0';
    if (wfZoomLbl) wfZoomLbl.textContent = '1×';
    setTimeout(() => {
      const src = audioEl.src;
      if (src && src.startsWith('blob:')) { initWfCanvas(); buildWaveform(src); }
    }, 50);
  });
  audioEl.addEventListener('loadedmetadata', () => {
    if (!wfDur && isFinite(audioEl.duration)) wfDur = audioEl.duration;
  });

  // ── Waveform pointer interaction ──────────────────────────────────────────
  function seekByX(x) {
    if (!wfDur || !wfWrap) return;
    const viewDur = wfDur / wfZoom;
    const vs      = Math.max(0, wfScrollOff);
    audioEl.currentTime = vs + Math.max(0, Math.min(x / wfWrap.offsetWidth, 1)) * viewDur;
  }

  if (wfWrap) {
    wfWrap.addEventListener('pointerdown', (e) => {
      const rect = wfWrap.getBoundingClientRect();
      const x    = e.clientX - rect.left;
      const phX  = parseFloat(wfPH.style.left) || 0;
      if (Math.abs(x - phX) <= 8) {
        wfDragging = true;
        wfWrap.setPointerCapture(e.pointerId);
        e.preventDefault();
      } else {
        seekByX(x);
      }
    });
    wfWrap.addEventListener('pointermove', (e) => {
      if (!wfDragging) return;
      const rect = wfWrap.getBoundingClientRect();
      seekByX(e.clientX - rect.left);
    });
    wfWrap.addEventListener('pointerup',     () => { wfDragging = false; });
    wfWrap.addEventListener('pointercancel', () => { wfDragging = false; });
  }

  if (window.ResizeObserver && wfWrap) {
    new ResizeObserver(() => { if (wfCtx || wfPeaks) { initWfCanvas(); drawWf(); } })
      .observe(wfWrap);
  }

  wfSplitBt && wfSplitBt.addEventListener('click', () => document.getElementById('timeline-split-btn')?.click());
  wfUndoBt  && wfUndoBt.addEventListener('click',  () => document.execCommand('undo'));

  // ── Keyboard shortcuts ────────────────────────────────────────────────────
  document.addEventListener('keydown', (e) => {
    const tgt = e.target;
    const editing = tgt.isContentEditable || tgt.tagName === 'INPUT' || tgt.tagName === 'TEXTAREA' || tgt.tagName === 'SELECT';

    if (e.code === 'Space' && !editing) {
      e.preventDefault();
      audioEl.paused ? audioEl.play().catch(() => {}) : audioEl.pause();
      return;
    }
    if ((e.key === 'ArrowRight' || e.key === 'ArrowLeft') && !editing) {
      e.preventDefault();
      const d = (e.key === 'ArrowRight' ? 1 : -1) * (e.shiftKey ? 5 : 0.5);
      audioEl.currentTime = Math.max(0, Math.min(wfDur || 1e9, audioEl.currentTime + d));
      return;
    }
    if ((e.key === '+' || e.key === '=') && !editing) { zoomIn();  return; }
    if (e.key === '-'                    && !editing) { zoomOut(); return; }
    if (e.ctrlKey && !e.shiftKey && e.key === 'k') {
      e.preventDefault();
      document.getElementById('timeline-split-btn')?.click();
      return;
    }
    if (e.ctrlKey && e.shiftKey && (e.key === 'Z' || e.key === 'z')) { document.execCommand('redo');  return; }
    if (e.ctrlKey && !e.shiftKey && e.key === 'z')                    { document.execCommand('undo'); return; }
  });

})();
</script>

</BaseLayout>
