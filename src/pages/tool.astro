          <p class="dz-sub">MP3, WAV, M4A, MP4, MOV, WebM — any file size</p>
          <p class="dz-priv">🔒 Your file never leaves your device</p>
        </div>
        <!-- File selected state -->
        <div id="file-info" class="hidden">
